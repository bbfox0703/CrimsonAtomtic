<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="540"
        d:DesignHeight="280"
        x:Class="CrimsonAtomtic.Ui.Views.ChallengeBulkOpProgressDialog"
        Title="Drop Sealed Abyss Artifacts"
        Width="540" Height="300"
        MinWidth="420" MinHeight="240"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/MainIcon.ico">

  <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,*,Auto">
    <TextBlock Grid.Row="0"
               Name="HeaderText"
               FontWeight="Bold"
               Text="Sweeping save…"
               Margin="0,0,0,8" />

    <TextBlock Grid.Row="1"
               Name="PhaseText"
               Opacity="0.75"
               Text="Initializing…"
               Margin="0,0,0,12" />

    <ProgressBar Grid.Row="2"
                 Name="Progress"
                 Minimum="0"
                 Maximum="1"
                 Value="0"
                 Height="16" />

    <TextBlock Grid.Row="3"
               Name="StatusText"
               Text="Click Cancel to abort. Already-applied changes are kept; reload the save without writing to revert."
               TextWrapping="Wrap"
               Margin="0,12,0,0"
               VerticalAlignment="Top" />

    <StackPanel Grid.Row="4"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,12,0,0">
      <Button Name="ActionButton"
              Content="Cancel"
              Click="OnActionClick"
              MinWidth="96"
              IsDefault="True" />
    </StackPanel>
  </Grid>
</Window>

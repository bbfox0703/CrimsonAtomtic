<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CrimsonAtomtic.Ui.ViewModels"
        xmlns:svc="using:CrimsonAtomtic.Ui.Services"
        mc:Ignorable="d"
        d:DesignWidth="1100"
        d:DesignHeight="600"
        x:Class="CrimsonAtomtic.Ui.Views.ItemPickerWindow"
        x:DataType="vm:ItemPickerViewModel"
        Title="{DynamicResource ItemPickerWindowTitle}"
        Icon="/Assets/MainIcon.ico"
        Width="1080" Height="600"
        MinWidth="600" MinHeight="320">

  <Grid RowDefinitions="Auto,Auto,Auto,*"
        Margin="12">

    <!-- Top action bar (unified Add-Item flow). Names the picked item
         and where it lands; the "from X" half is pushed live from the
         main window as the user reselects inventory rows. Hidden in
         per-row mode (e.g. the Sockets gem-picker). -->
    <Border Grid.Row="0"
            IsVisible="{Binding ShowTopActionBar}"
            Background="#22FFFFFF"
            CornerRadius="4"
            Padding="8"
            Margin="0,0,0,8">
      <StackPanel Spacing="4">
        <Button Content="{Binding AddActionText}"
                Command="{Binding AddSelectedCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Padding="8,6"
                FontWeight="SemiBold" />
        <!-- "Go to item in save": jump the main window to the selected
             item's slot in the loaded save (catalog-browse counterpart
             of Find Items' per-row "Go"). Routed through the picker VM's
             GotoItemRequested event so this window stays decoupled from
             MainWindowViewModel. -->
        <Button Content="{DynamicResource ItemPickerGotoButton}"
                ToolTip.Tip="{DynamicResource ItemPickerGotoTip}"
                Command="{Binding GotoSelectedCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Padding="8,4" />
        <TextBlock Text="{Binding TopActionHint}"
                   Opacity="0.6"
                   TextWrapping="Wrap"
                   IsVisible="{Binding TopActionHint, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
      </StackPanel>
    </Border>

    <TextBox Grid.Row="1"
             Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
             PlaceholderText="{DynamicResource ItemPickerSearchPlaceholder}" />

    <TextBlock Grid.Row="2"
               Text="{Binding ResultsCountText}"
               Opacity="0.6"
               Margin="2,6,0,8" />

    <DataGrid Grid.Row="3"
              ItemsSource="{Binding Results}"
              SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
              IsReadOnly="True"
              CanUserResizeColumns="True"
              CanUserSortColumns="True"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column"
              AutoGenerateColumns="False">
      <DataGrid.Columns>
        <!-- Icon column. Image source resolves lazily through the
             ItemKeyToIconConverter singleton (binds value to the
             active IconProvider's cache). Width = 48 + a couple of
             px padding; icons are 64×64 in CRIMSON-DESERT-SAVE-EDITOR but we
             render them at 40×40 so the row stays compact. Empty
             when no icon directory is configured / file missing —
             Image.Source = null hides the bitmap and the StackPanel
             leaves a placeholder gap. -->
        <DataGridTemplateColumn Header="{DynamicResource ItemPickerColIcon}" Width="56">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="vm:ItemPickerRow">
              <Image Source="{Binding ItemKey, Converter={x:Static svc:ItemKeyToIconConverter.Instance}}"
                     Width="40" Height="40"
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="{DynamicResource ItemPickerColKey}"
                            Binding="{Binding ItemKey}"
                            Width="100" />
        <DataGridTextColumn Header="{DynamicResource ItemPickerColStringKey}"
                            Binding="{Binding StringKey}"
                            Width="280" />
        <DataGridTextColumn Header="{DynamicResource ItemPickerColNameEnglish}"
                            Binding="{Binding NameEnglish}"
                            Width="*" />
        <!-- Secondary name column: only visible when the user has
             picked a secondary language. Header includes the lang
             code so it's obvious which translation this is. -->
        <DataGridTextColumn Header="{Binding $parent[Window].((vm:ItemPickerViewModel)DataContext).SecondaryNameHeader}"
                            Binding="{Binding NameSecondary}"
                            Width="*"
                            IsVisible="{Binding $parent[Window].((vm:ItemPickerViewModel)DataContext).HasSecondary}" />
        <!-- Per-row copy buttons. K = ItemKey (the u32 the save schema
             stores), S = string_key (iteminfo's internal id), N =
             English name, N₂ = secondary name. V₂ is hidden when no
             secondary language is loaded. -->
        <DataGridTemplateColumn Header="{DynamicResource ItemPickerColCopy}"
                                Width="160">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="vm:ItemPickerRow">
              <StackPanel Orientation="Horizontal"
                          Spacing="2"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Left">
                <Button Content="K"
                        ToolTip.Tip="{DynamicResource ItemPickerCopyKeyTip}"
                        Padding="6,2"
                        MinHeight="0"
                        Tag="{Binding ItemKeyText}"
                        Click="OnCopyButtonClick" />
                <Button Content="S"
                        ToolTip.Tip="{DynamicResource ItemPickerCopyStringKeyTip}"
                        Padding="6,2"
                        MinHeight="0"
                        Tag="{Binding StringKey}"
                        Click="OnCopyButtonClick" />
                <Button Content="N"
                        ToolTip.Tip="{DynamicResource ItemPickerCopyNameTip}"
                        Padding="6,2"
                        MinHeight="0"
                        Tag="{Binding NameEnglish}"
                        Click="OnCopyButtonClick" />
                <Button Content="N₂"
                        ToolTip.Tip="{DynamicResource ItemPickerCopyNameSecondaryTip}"
                        Padding="6,2"
                        MinHeight="0"
                        Tag="{Binding NameSecondary}"
                        Click="OnCopyButtonClick"
                        IsVisible="{Binding $parent[Window].((vm:ItemPickerViewModel)DataContext).HasSecondary}" />
                <!-- "+ Bag" button: add this item to the inventory list
                     the main window is currently showing. Routed
                     through the picker VM's AddItemRequested event so
                     this window stays decoupled from MainWindowViewModel
                     (callers that want a read-only picker just don't
                     subscribe). The actual clone-and-patch happens in
                     MainWindowViewModel.AddItemToCurrentListAsync. -->
                <Button Content="{Binding $parent[Window].((vm:ItemPickerViewModel)DataContext).ActionButtonLabel, FallbackValue='+ Bag'}"
                        ToolTip.Tip="{Binding $parent[Window].((vm:ItemPickerViewModel)DataContext).ActionButtonTooltip,
                                              FallbackValue={DynamicResource ItemPickerAddToBagTip}}"
                        IsVisible="{Binding $parent[Window].((vm:ItemPickerViewModel)DataContext).ShowPerRowAction}"
                        Padding="6,2"
                        MinHeight="0"
                        Tag="{Binding ItemKey}"
                        Click="OnAddToBagClick" />
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</Window>

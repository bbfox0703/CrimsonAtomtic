<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CrimsonAtomtic.Ui.ViewModels"
        x:Class="CrimsonAtomtic.Ui.Views.SocketEditorWindow"
        x:DataType="vm:SocketEditorViewModel"
        Title="{DynamicResource MenuEditItemSockets}"
        Width="1320" Height="600"
        MinWidth="900" MinHeight="380"
        FontSize="{Binding $parent[Window].FontSize, FallbackValue=14}">

  <DockPanel LastChildFill="True" Margin="12">
    <TextBlock DockPanel.Dock="Top"
               Text="{DynamicResource SocketEditorHeader}"
               TextWrapping="Wrap"
               Opacity="0.7"
               Margin="0,0,0,8" />

    <!-- Filter input: substring match against bag / item name (en +
         secondary) / item key / current gem name / gem key. Case-
         insensitive. Bound to SearchText; ApplyFilter runs on every
         change via the partial OnSearchTextChanged. -->
    <Grid DockPanel.Dock="Top"
          ColumnDefinitions="Auto,*,Auto"
          ColumnSpacing="8"
          Margin="0,0,0,8">
      <TextBlock Grid.Column="0"
                 Text="{DynamicResource SocketEditorFilterLabel}"
                 VerticalAlignment="Center"
                 Opacity="0.8" />
      <TextBox Grid.Column="1"
               Text="{Binding SearchText, Mode=TwoWay}"
               PlaceholderText="{DynamicResource SocketEditorFilterWatermark}"
               HorizontalAlignment="Stretch" />
      <TextBlock Grid.Column="2"
                 Text="{Binding FilterCountText}"
                 VerticalAlignment="Center"
                 Opacity="0.6"
                 MinWidth="160" />
    </Grid>

    <!-- Apply-Set toolbar: pick an item, pick a set, click Apply.
         Set overwrites slots 0..N-1 (N = set's gem count); slots
         past N are left alone. -->
    <Grid DockPanel.Dock="Top"
          ColumnDefinitions="Auto,*,Auto,2*,Auto,Auto"
          ColumnSpacing="8"
          Margin="0,0,0,10">
      <TextBlock Grid.Column="0"
                 Text="{DynamicResource SocketEditorApplySetItemLabel}"
                 VerticalAlignment="Center"
                 Opacity="0.8" />
      <ComboBox Grid.Column="1"
                ItemsSource="{Binding ApplySetTargets}"
                SelectedItem="{Binding SelectedTarget}"
                DisplayMemberBinding="{Binding DisplayName}"
                HorizontalAlignment="Stretch" />
      <TextBlock Grid.Column="2"
                 Text="{DynamicResource SocketEditorApplySetSetLabel}"
                 VerticalAlignment="Center"
                 Opacity="0.8" />
      <ComboBox Grid.Column="3"
                ItemsSource="{Binding AvailableGemSets}"
                SelectedItem="{Binding SelectedSet}"
                DisplayMemberBinding="{Binding DisplayName}"
                HorizontalAlignment="Stretch" />
      <Button Grid.Column="4"
              Content="{DynamicResource SocketEditorApplySetApply}"
              Command="{Binding ApplyGemSetCommand}"
              MinWidth="80" />
      <Button Grid.Column="5"
              Content="{DynamicResource SocketEditorApplySetEditCustom}"
              ToolTip.Tip="{DynamicResource SocketEditorApplySetEditCustomTip}"
              Click="OnEditCustomGemSetsClick"
              MinWidth="120" />
    </Grid>

    <Grid DockPanel.Dock="Bottom"
          ColumnDefinitions="*,Auto"
          ColumnSpacing="12"
          Margin="0,8,0,0">
      <TextBlock Grid.Column="0"
                 Text="{Binding StatusMessage}"
                 Opacity="0.7"
                 VerticalAlignment="Center"
                 TextTrimming="CharacterEllipsis" />
      <Button Grid.Column="1"
              Content="{DynamicResource SocketEditorClose}"
              Click="OnCloseClick"
              MinWidth="80" />
    </Grid>

    <DataGrid ItemsSource="{Binding Sockets}"
              AutoGenerateColumns="False"
              CanUserResizeColumns="True"
              CanUserSortColumns="False"
              GridLinesVisibility="Horizontal"
              IsReadOnly="True"
              HeadersVisibility="Column">
      <DataGrid.Columns>
        <DataGridTextColumn Header="{DynamicResource SocketEditorColBag}"
                            Binding="{Binding BagLabel}"
                            Width="140" />
        <!-- Item-name column. Shows English / secondary together
             (e.g. "Wooden Sword / 木劍") via the pre-formatted
             ItemName property; the filter matches each language
             independently via SocketRow.ItemNameEnglish +
             ItemNameSecondary. -->
        <DataGridTextColumn Header="{DynamicResource SocketEditorColItem}"
                            Binding="{Binding ItemName}"
                            Width="260"
                            MinWidth="120" />
        <DataGridTextColumn Header="{DynamicResource SocketEditorColItemKey}"
                            Binding="{Binding ItemKey}"
                            Width="90" />
        <DataGridTextColumn Header="{DynamicResource SocketEditorColSocket}"
                            Binding="{Binding SocketIndex}"
                            Width="60" />
        <DataGridTextColumn Header="{DynamicResource SocketEditorColState}"
                            Binding="{Binding StateLabel}"
                            Width="170" />
        <DataGridTextColumn Header="{DynamicResource SocketEditorColCurrentGem}"
                            Binding="{Binding DisplayGemName}"
                            Width="220"
                            MinWidth="120" />
        <DataGridTextColumn Header="{DynamicResource SocketEditorColCurrentGemKey}"
                            Binding="{Binding DisplayGemKeyText}"
                            Width="90" />
        <!-- Action column hosts three buttons whose IsVisible / CanExecute
             route by row state. Fill (empty slots), Change + Clear
             (filled slots). The picker callback is the same for Fill
             and Change — the editor VM disambiguates by row.IsFilled
             when the picked gem comes back. -->
        <DataGridTemplateColumn Header="{DynamicResource SocketEditorColAction}"
                                Width="220">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate DataType="vm:SocketRow">
              <StackPanel Orientation="Horizontal" Spacing="4"
                          VerticalAlignment="Center">
                <Button Content="{DynamicResource SocketEditorFillGem}"
                        ToolTip.Tip="{DynamicResource SocketEditorFillGemTip}"
                        Command="{Binding FillGemCommand}"
                        IsVisible="{Binding !IsFilled}"
                        Padding="6,2" MinHeight="0" />
                <Button Content="{DynamicResource SocketEditorChangeGem}"
                        ToolTip.Tip="{DynamicResource SocketEditorChangeGemTip}"
                        Command="{Binding ChangeGemCommand}"
                        IsVisible="{Binding IsFilled}"
                        Padding="6,2" MinHeight="0" />
                <Button Content="{DynamicResource SocketEditorClearGem}"
                        ToolTip.Tip="{DynamicResource SocketEditorClearGemTip}"
                        Command="{Binding ClearGemCommand}"
                        IsVisible="{Binding IsFilled}"
                        Padding="6,2" MinHeight="0" />
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="{DynamicResource SocketEditorColApplied}"
                            Binding="{Binding LastError}"
                            Width="200" />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CrimsonAtomtic.Ui.ViewModels"
        x:Class="CrimsonAtomtic.Ui.Views.SocketEditorWindow"
        x:DataType="vm:SocketEditorViewModel"
        Title="{StaticResource MenuEditItemSockets}"
        Width="980" Height="560"
        MinWidth="720" MinHeight="380"
        FontSize="{Binding $parent[Window].FontSize, FallbackValue=14}">

  <DockPanel LastChildFill="True" Margin="12">
    <TextBlock DockPanel.Dock="Top"
               Text="{StaticResource SocketEditorHeader}"
               TextWrapping="Wrap"
               Opacity="0.7"
               Margin="0,0,0,8" />

    <Grid DockPanel.Dock="Bottom"
          ColumnDefinitions="*,Auto"
          ColumnSpacing="12"
          Margin="0,8,0,0">
      <TextBlock Grid.Column="0"
                 Text="{Binding StatusMessage}"
                 Opacity="0.7"
                 VerticalAlignment="Center"
                 TextTrimming="CharacterEllipsis" />
      <Button Grid.Column="1"
              Content="{StaticResource SocketEditorClose}"
              Click="OnCloseClick"
              MinWidth="80" />
    </Grid>

    <DataGrid ItemsSource="{Binding Sockets}"
              AutoGenerateColumns="False"
              CanUserResizeColumns="True"
              CanUserSortColumns="False"
              GridLinesVisibility="Horizontal"
              IsReadOnly="True"
              HeadersVisibility="Column">
      <DataGrid.Columns>
        <DataGridTextColumn Header="{StaticResource SocketEditorColBag}"
                            Binding="{Binding BagLabel}"
                            Width="140" />
        <DataGridTextColumn Header="{StaticResource SocketEditorColItem}"
                            Binding="{Binding ItemName}"
                            Width="2*" />
        <DataGridTextColumn Header="{StaticResource SocketEditorColItemKey}"
                            Binding="{Binding ItemKey}"
                            Width="90" />
        <DataGridTextColumn Header="{StaticResource SocketEditorColSocket}"
                            Binding="{Binding SocketIndex}"
                            Width="60" />
        <DataGridTextColumn Header="{StaticResource SocketEditorColState}"
                            Binding="{Binding StateLabel}"
                            Width="170" />
        <DataGridTextColumn Header="{StaticResource SocketEditorColCurrentGem}"
                            Binding="{Binding DisplayGemName}"
                            Width="2*" />
        <DataGridTextColumn Header="{StaticResource SocketEditorColCurrentGemKey}"
                            Binding="{Binding DisplayGemKeyText}"
                            Width="90" />
        <!-- Action column hosts three buttons whose IsVisible / CanExecute
             route by row state. Fill (empty slots), Change + Clear
             (filled slots). The picker callback is the same for Fill
             and Change — the editor VM disambiguates by row.IsFilled
             when the picked gem comes back. -->
        <DataGridTemplateColumn Header="{StaticResource SocketEditorColAction}"
                                Width="220">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate DataType="vm:SocketRow">
              <StackPanel Orientation="Horizontal" Spacing="4"
                          VerticalAlignment="Center">
                <Button Content="{StaticResource SocketEditorFillGem}"
                        ToolTip.Tip="{StaticResource SocketEditorFillGemTip}"
                        Command="{Binding FillGemCommand}"
                        IsVisible="{Binding !IsFilled}"
                        Padding="6,2" MinHeight="0" />
                <Button Content="{StaticResource SocketEditorChangeGem}"
                        ToolTip.Tip="{StaticResource SocketEditorChangeGemTip}"
                        Command="{Binding ChangeGemCommand}"
                        IsVisible="{Binding IsFilled}"
                        Padding="6,2" MinHeight="0" />
                <Button Content="{StaticResource SocketEditorClearGem}"
                        ToolTip.Tip="{StaticResource SocketEditorClearGemTip}"
                        Command="{Binding ClearGemCommand}"
                        IsVisible="{Binding IsFilled}"
                        Padding="6,2" MinHeight="0" />
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="{StaticResource SocketEditorColApplied}"
                            Binding="{Binding LastError}"
                            Width="200" />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</Window>

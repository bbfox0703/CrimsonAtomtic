<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CrimsonAtomtic.Ui.ViewModels"
        mc:Ignorable="d"
        d:DesignWidth="1100"
        d:DesignHeight="600"
        x:Class="CrimsonAtomtic.Ui.Views.CharacterPickerWindow"
        x:DataType="vm:CharacterPickerViewModel"
        Title="{StaticResource CharacterPickerWindowTitle}"
        Icon="/Assets/MainIcon.ico"
        Width="1080" Height="600"
        MinWidth="600" MinHeight="320">

  <Grid RowDefinitions="Auto,Auto,Auto,*"
        Margin="12">

    <!-- Linkage caveat banner. Shown for both browse-only and pick
         mode — the same characterinfo.pabgb key can map to different
         concrete entities under different schema field roles, so the
         user should cross-verify before trusting the resolved name. -->
    <Border Grid.Row="0"
            Background="#3D2418"
            BorderBrush="#FFD088"
            BorderThickness="0,0,0,1"
            Padding="10,8"
            Margin="0,0,0,8">
      <TextBlock Text="{StaticResource CharacterPickerWarning}"
                 Foreground="#FFD088"
                 TextWrapping="Wrap" />
    </Border>

    <TextBox Grid.Row="1"
             Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
             PlaceholderText="{StaticResource CharacterPickerSearchPlaceholder}" />

    <TextBlock Grid.Row="2"
               Text="{Binding ResultsCountText}"
               Opacity="0.6"
               Margin="2,6,0,8" />

    <DataGrid Grid.Row="3"
              ItemsSource="{Binding Results}"
              IsReadOnly="True"
              CanUserResizeColumns="True"
              CanUserSortColumns="True"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column"
              AutoGenerateColumns="False">
      <DataGrid.Columns>
        <!-- Portrait column. Bound directly to the row's Portrait
             property (populated asynchronously via StartPortraitLoad
             on the thread pool). Cells stay blank until the load
             completes or permanently when no portrait matched above
             PortraitProvider.MinAcceptableScore. -->
        <DataGridTemplateColumn Header="{StaticResource CharacterPickerColPortrait}" Width="60">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="vm:CharacterPickerRow">
              <Image Source="{Binding Portrait}"
                     Width="48" Height="48"
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="{StaticResource CharacterPickerColKey}"
                            Binding="{Binding CharacterKey}"
                            Width="100" />
        <DataGridTextColumn Header="{StaticResource CharacterPickerColInternal}"
                            Binding="{Binding InternalName}"
                            Width="280" />
        <DataGridTextColumn Header="{StaticResource CharacterPickerColNameEnglish}"
                            Binding="{Binding NameEnglish}"
                            Width="*" />
        <!-- Secondary name column: only visible when the user has
             picked a secondary language. Header includes the lang
             code so it's obvious which translation this is. -->
        <DataGridTextColumn Header="{Binding $parent[Window].((vm:CharacterPickerViewModel)DataContext).SecondaryNameHeader}"
                            Binding="{Binding NameSecondary}"
                            Width="*"
                            IsVisible="{Binding $parent[Window].((vm:CharacterPickerViewModel)DataContext).HasSecondary}" />
        <!-- Per-row copy buttons: K = CharacterKey (the u32 the save
             schema stores), S = internal name, N = English display
             name, N₂ = secondary display name (hidden when no
             secondary). Mirrors Browse Items copy semantics. -->
        <DataGridTemplateColumn Header="{StaticResource CharacterPickerColCopy}"
                                Width="140">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="vm:CharacterPickerRow">
              <StackPanel Orientation="Horizontal"
                          Spacing="2"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Left">
                <Button Content="K"
                        ToolTip.Tip="{StaticResource CharacterPickerCopyKeyTip}"
                        Padding="6,2"
                        MinHeight="0"
                        Tag="{Binding CharacterKeyText}"
                        Click="OnCopyButtonClick" />
                <Button Content="S"
                        ToolTip.Tip="{StaticResource CharacterPickerCopyInternalTip}"
                        Padding="6,2"
                        MinHeight="0"
                        Tag="{Binding InternalName}"
                        Click="OnCopyButtonClick" />
                <Button Content="N"
                        ToolTip.Tip="{StaticResource CharacterPickerCopyNameTip}"
                        Padding="6,2"
                        MinHeight="0"
                        Tag="{Binding NameEnglish}"
                        Click="OnCopyButtonClick" />
                <Button Content="N₂"
                        ToolTip.Tip="{StaticResource CharacterPickerCopyNameSecondaryTip}"
                        Padding="6,2"
                        MinHeight="0"
                        Tag="{Binding NameSecondary}"
                        Click="OnCopyButtonClick"
                        IsVisible="{Binding $parent[Window].((vm:CharacterPickerViewModel)DataContext).HasSecondary}" />
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <!-- Pick column. Visible only when the VM was constructed in
             pick mode (IsPickMode=true), i.e. invoked from the edit
             panel's "Pick character…" button. Clicking the per-row
             Pick raises CharacterPickerViewModel.PickConfirmed and the
             hosting window closes with the chosen CharacterKey. The
             standalone Browse Characters dialog hides this column. -->
        <DataGridTemplateColumn Header="{StaticResource CharacterPickerColPick}"
                                Width="80"
                                IsVisible="{Binding $parent[Window].((vm:CharacterPickerViewModel)DataContext).IsPickMode}">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate DataType="vm:CharacterPickerRow">
              <Button Content="{StaticResource CharacterPickerPick}"
                      Command="{Binding PickCommand}"
                      Padding="6,2"
                      MinHeight="0" />
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</Window>

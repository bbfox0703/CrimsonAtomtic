<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CrimsonAtomtic.Ui.ViewModels"
        mc:Ignorable="d"
        d:DesignWidth="900"
        d:DesignHeight="900"
        x:Class="CrimsonAtomtic.Ui.Views.WorldMapWindow"
        x:DataType="vm:WorldMapViewModel"
        x:Name="Root"
        Title="{DynamicResource WorldMapWindowTitle}"
        Icon="/Assets/MainIcon.ico"
        Width="900" Height="900"
        MinWidth="480" MinHeight="480"
        FontSize="{Binding $parent[Window].FontSize, FallbackValue=14}">

  <DockPanel LastChildFill="True" Margin="8">

    <!-- ── Toolbar ─────────────────────────────────────────────────── -->
    <Grid DockPanel.Dock="Top"
          ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto"
          ColumnSpacing="8"
          Margin="0,0,0,8"
          VerticalAlignment="Center">
      <Button Grid.Column="0"
              Content="{DynamicResource WorldMapPickMap}"
              Click="OnPickMapClick"
              ToolTip.Tip="{DynamicResource WorldMapPickMapTip}" />
      <Border Grid.Column="1" Width="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Opacity="0.5"/>
      <TextBlock Grid.Column="2"
                 Text="{DynamicResource WorldMapFilterLabel}"
                 VerticalAlignment="Center"
                 Opacity="0.8" />
      <TextBox Grid.Column="3"
               MinWidth="120"
               Text="{Binding ObjectFilter, Mode=TwoWay}"
               ToolTip.Tip="{DynamicResource WorldMapFilterTip}" />
      <ComboBox Grid.Column="4"
                MinWidth="280"
                ItemsSource="{Binding FilteredObjects}"
                SelectedItem="{Binding SelectedObject, Mode=TwoWay}"
                ToolTip.Tip="{DynamicResource WorldMapObjectPickerTip}">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:EntityChoice">
            <TextBlock Text="{Binding DisplayLabel}" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <!-- Spacer -->
      <Button Grid.Column="6"
              Content="{DynamicResource WorldMapClose}"
              Click="OnCloseClick"
              MinWidth="80" />
    </Grid>

    <!-- ── Status bar ──────────────────────────────────────────────── -->
    <Grid DockPanel.Dock="Bottom"
          ColumnDefinitions="*,Auto,Auto"
          ColumnSpacing="16"
          Margin="0,8,0,0">
      <TextBlock Grid.Column="0"
                 Text="{Binding BasemapPathLabel}"
                 Opacity="0.6"
                 FontFamily="Consolas, Menlo, monospace"
                 VerticalAlignment="Center"
                 TextTrimming="CharacterEllipsis" />
      <TextBlock Grid.Column="1"
                 Text="{Binding CursorCoordsText}"
                 Opacity="0.7"
                 FontFamily="Consolas, Menlo, monospace"
                 VerticalAlignment="Center" />
      <TextBlock Grid.Column="2"
                 Text="{Binding PingedMarkerLabel}"
                 Opacity="0.85"
                 VerticalAlignment="Center"
                 IsVisible="{Binding HasPingedMarker}" />
    </Grid>

    <!-- ── Map surface ─────────────────────────────────────────────── -->
    <Border BorderThickness="1"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            Background="#101010"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
      <Grid x:Name="MapStage"
            Width="{Binding DisplayWidth}"
            Height="{Binding DisplayHeight}"
            PointerMoved="OnMapPointerMoved">
        <!-- Basemap stretched to fill the square canvas regardless of
             source aspect ratio. Source image is whatever the user
             picked; the marker projection is computed against the
             canonical 5178×5240 reference, so a non-canonical image
             gives wrong-looking but consistent placement. -->
        <Image Source="{Binding Basemap}"
               Stretch="Fill"
               RenderOptions.BitmapInterpolationMode="MediumQuality" />

        <!-- Pinged marker overlay. Single Ellipse for now — multi-
             marker support is a one-liner future change (swap to an
             ItemsControl bound to a collection). -->
        <Canvas IsVisible="{Binding HasPingedMarker}"
                IsHitTestVisible="False">
          <Ellipse Canvas.Left="{Binding PingedMarkerX}"
                   Canvas.Top="{Binding PingedMarkerY}"
                   Width="16" Height="16"
                   Fill="#FFE74C3C"
                   Stroke="#FFFFFF"
                   StrokeThickness="2">
            <Ellipse.RenderTransform>
              <TranslateTransform X="-8" Y="-8" />
            </Ellipse.RenderTransform>
          </Ellipse>
        </Canvas>
      </Grid>
    </Border>
  </DockPanel>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CrimsonAtomtic.Ui.ViewModels"
        mc:Ignorable="d"
        d:DesignWidth="1100"
        d:DesignHeight="600"
        x:Class="CrimsonAtomtic.Ui.Views.AbyssGatesWindow"
        x:DataType="vm:AbyssGatesViewModel"
        Title="{StaticResource AbyssGatesWindowTitle}"
        Icon="/Assets/MainIcon.ico"
        Width="1080" Height="600"
        MinWidth="700" MinHeight="320"
        FontSize="{Binding $parent[Window].FontSize, FallbackValue=14}">

  <DockPanel LastChildFill="True" Margin="12">
    <!-- Header explains the v1 scope so users don't expect missing-
         gate rows to mean a bug. -->
    <TextBlock DockPanel.Dock="Top"
               Text="{StaticResource AbyssGatesHeader}"
               TextWrapping="Wrap"
               Opacity="0.7"
               Margin="0,0,0,8" />

    <!-- Status footer + Close -->
    <Grid DockPanel.Dock="Bottom"
          ColumnDefinitions="*,Auto"
          ColumnSpacing="12"
          Margin="0,8,0,0">
      <TextBlock Grid.Column="0"
                 Text="{Binding StatusMessage}"
                 Opacity="0.7"
                 VerticalAlignment="Center"
                 TextTrimming="CharacterEllipsis" />
      <Button Grid.Column="1"
              Content="{StaticResource AbyssGatesClose}"
              Click="OnCloseClick"
              MinWidth="80" />
    </Grid>

    <!-- Rows grid. Default sort: OwnerLevelName then GimmickName,
         matching how the upstream's probe groups its sample. -->
    <DataGrid ItemsSource="{Binding Rows}"
              IsReadOnly="True"
              CanUserResizeColumns="True"
              CanUserSortColumns="True"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column"
              AutoGenerateColumns="False">
      <DataGrid.Columns>
        <DataGridTextColumn Header="{StaticResource AbyssGatesColOwnerLevel}"
                            Binding="{Binding OwnerLevelName}"
                            Width="240" />
        <DataGridTextColumn Header="{StaticResource AbyssGatesColGimmick}"
                            Binding="{Binding GimmickName}"
                            Width="*" />
        <DataGridTextColumn Header="{StaticResource AbyssGatesColSaveKey}"
                            Binding="{Binding FieldGimmickSaveDataKey}"
                            Width="110" />
        <DataGridTextColumn Header="{StaticResource AbyssGatesColState}"
                            Binding="{Binding StateLabel}"
                            Width="180" />
        <DataGridTextColumn Header="{StaticResource AbyssGatesColStateHash}"
                            Binding="{Binding StateHashText}"
                            Width="120"
                            FontFamily="Consolas, Menlo, monospace" />
        <!-- Lock / Unlock buttons. CanExecute on the underlying
             commands gates which one is enabled for the row's
             current state. -->
        <DataGridTemplateColumn Header="{StaticResource AbyssGatesColAction}" Width="170">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate DataType="vm:AbyssGateRow">
              <StackPanel Orientation="Horizontal" Spacing="4"
                          VerticalAlignment="Center">
                <Button Content="{StaticResource AbyssGatesUnlock}"
                        ToolTip.Tip="{StaticResource AbyssGatesUnlockTip}"
                        Command="{Binding UnlockCommand}"
                        Padding="6,2" MinHeight="0" />
                <Button Content="{StaticResource AbyssGatesLock}"
                        ToolTip.Tip="{StaticResource AbyssGatesLockTip}"
                        Command="{Binding LockCommand}"
                        Padding="6,2" MinHeight="0" />
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</Window>

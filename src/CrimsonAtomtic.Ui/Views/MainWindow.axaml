<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CrimsonAtomtic.Ui.ViewModels"
        xmlns:model="using:CrimsonAtomtic.SaveModel"
        xmlns:svc="using:CrimsonAtomtic.Ui.Services"
        mc:Ignorable="d"
        d:DesignWidth="900"
        d:DesignHeight="600"
        x:Class="CrimsonAtomtic.Ui.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle, FallbackValue={DynamicResource WindowTitle}}"
        Icon="/Assets/MainIcon.ico"
        Width="960" Height="640"
        MinWidth="600" MinHeight="400"
        FontSize="{Binding FontSize, FallbackValue=14}">

  <!-- Avalonia 12 Fluent pins DataGridCell + DataGridColumnHeader's
       FontSize via its default theme styles, so the Window-level
       FontSize cascade (above) doesn't reach individual rows /
       header cells. These two style setters reach down through the
       visual tree and explicitly bind both back to the Window — so
       picking Tools → Font Size now scales the whole grid, not just
       the surrounding chrome. -->
  <Window.Styles>
    <Style Selector="DataGridCell">
      <Setter Property="FontSize" Value="{Binding $parent[Window].FontSize}" />
    </Style>
    <Style Selector="DataGridColumnHeader">
      <Setter Property="FontSize" Value="{Binding $parent[Window].FontSize}" />
    </Style>
  </Window.Styles>

  <!-- Layered root: a faded Logo.jpg sits behind the whole window,
       slightly more prominent on the empty splash state and dropping
       to a faint watermark once a save is loaded (so the DataGrids
       stay legible). Children render in declaration order; the menu
       and content panels keep their theme backgrounds where they need
       to, and the image only shows through the transparent gaps. -->
  <Grid>
    <Image Source="/Assets/Logo.jpg"
           Stretch="UniformToFill"
           IsHitTestVisible="False"
           Opacity="{Binding BackgroundOpacity}" />

    <DockPanel LastChildFill="True"
               Background="Transparent">

    <Menu DockPanel.Dock="Top">
      <MenuItem Header="{DynamicResource MenuFile}">
        <MenuItem Header="{DynamicResource MenuOpenSave}" Click="OnOpenSaveClick" />
        <MenuItem Header="{DynamicResource MenuSave}"
                  Command="{Binding SaveCommand}" />
        <MenuItem Header="{DynamicResource MenuSaveAs}"
                  Click="OnSaveAsClick"
                  IsEnabled="{Binding HasSave}" />
        <Separator />
        <MenuItem Header="{DynamicResource MenuRestoreFromBackup}"
                  Click="OnRestoreFromBackupClick" />
        <Separator />
        <MenuItem Header="{DynamicResource MenuExit}" Click="OnExitClick" />
      </MenuItem>
      <MenuItem Header="{DynamicResource MenuTools}">
        <!-- UI Language submenu. Auto = pick from OS culture every
             launch (no settings.ui_language stored); the explicit
             entries persist a code that survives across machines.
             Dynamically populated check marks live in the code-behind
             (RefreshUiLanguageCheckmarks). -->
        <MenuItem Header="{DynamicResource MenuUiLanguage}"
                  Name="UiLanguageMenu">
          <MenuItem Header="{DynamicResource MenuUiLanguageAuto}"
                    Click="OnSetUiLanguageClick"
                    Tag="" />
          <Separator />
          <MenuItem Header="{DynamicResource MenuUiLanguageEn}"
                    Click="OnSetUiLanguageClick"
                    Tag="en" />
          <MenuItem Header="{DynamicResource MenuUiLanguageJa}"
                    Click="OnSetUiLanguageClick"
                    Tag="ja" />
          <MenuItem Header="{DynamicResource MenuUiLanguageZhTw}"
                    Click="OnSetUiLanguageClick"
                    Tag="zh-TW" />
        </MenuItem>
        <Separator />
        <MenuItem Header="{DynamicResource MenuBrowseItems}"
                  Click="OnBrowseItemsClick" />
        <MenuItem Header="{DynamicResource MenuBrowseCharacters}"
                  Click="OnBrowseCharactersClick" />
        <MenuItem Header="{DynamicResource MenuBrowseCharacterRefs}"
                  Click="OnBrowseCharacterRefsClick"
                  IsEnabled="{Binding HasSave}" />
        <MenuItem Header="{DynamicResource MenuBrowseLocalization}"
                  Click="OnBrowseLocalizationClick" />
        <MenuItem Header="{DynamicResource MenuFindItems}"
                  Click="OnFindItemsClick"
                  IsEnabled="{Binding HasSave}" />
        <Separator />
        <MenuItem Header="{DynamicResource MenuExtractIcons}"
                  Click="OnExtractIconsClick" />
        <MenuItem Header="{DynamicResource MenuSetGameInstallFolder}"
                  Click="OnSetGameInstallFolderClick" />
        <Separator />
        <!-- Bulk-edit sweeps. Both gate on HasSave via the VM's
             RelayCommand CanExecute, so the menu items disable when
             no save is loaded. Each command shows its own confirm
             dialog before mutating anything. -->
        <MenuItem Header="{DynamicResource MenuFillAllStacks}"
                  Command="{Binding FillAllStacksAcrossInventoriesCommand}" />
        <MenuItem Header="{DynamicResource MenuUnlockAllAbyssGates}"
                  Command="{Binding UnlockAllAbyssGatesCommand}" />
        <MenuItem Header="{DynamicResource MenuBulkCompleteHeldSAChallenges}"
                  Click="OnCompleteSealedArtifactChallengesClick"
                  IsEnabled="{Binding HasSave}" />
        <MenuItem Header="{DynamicResource MenuEditAbyssGates}"
                  Click="OnEditAbyssGatesClick"
                  IsEnabled="{Binding HasSave}" />
        <MenuItem Header="{DynamicResource MenuUnlockMounts}"
                  Click="OnUnlockMountsClick"
                  IsEnabled="{Binding HasSave}" />
        <MenuItem Header="{DynamicResource MenuEditKnowledge}"
                  Click="OnEditKnowledgeClick"
                  IsEnabled="{Binding HasSave}" />
        <MenuItem Header="{DynamicResource MenuEditFactionNodes}"
                  Click="OnEditFactionNodesClick"
                  IsEnabled="{Binding HasSave}" />
        <MenuItem Header="{DynamicResource MenuRenameMercenary}"
                  Click="OnRenameMercenaryClick"
                  IsEnabled="{Binding HasSave}" />
        <MenuItem Header="{DynamicResource MenuEditItemDyes}"
                  Click="OnEditItemDyesClick"
                  IsEnabled="{Binding HasSave}" />
        <MenuItem Header="{DynamicResource MenuVendorBuyback}"
                  Click="OnVendorBuybackClick"
                  IsEnabled="{Binding HasSave}" />
        <MenuItem Header="{DynamicResource MenuWorldMap}"
                  Click="OnWorldMapClick"
                  IsEnabled="{Binding HasSave}" />
        <Separator />
        <MenuItem Header="{DynamicResource MenuReviewChanges}"
                  Click="OnReviewChangesClick"
                  IsEnabled="{Binding HasSave}" />
        <MenuItem Header="{DynamicResource MenuEditItemSockets}"
                  Click="OnEditItemSocketsClick"
                  IsEnabled="{Binding HasSave}" />
        <Separator />
        <!-- Font size submenu. Each entry sets the Window's FontSize
             via the VM, which cascades to every child control. The
             tag carries the numeric value so the handler doesn't
             have to parse the header text. -->
        <MenuItem Header="{DynamicResource MenuFontSize}"
                  Name="FontSizeMenu">
          <MenuItem Header="10" Click="OnSetFontSizeClick" Tag="10" />
          <MenuItem Header="12" Click="OnSetFontSizeClick" Tag="12" />
          <MenuItem Header="13" Click="OnSetFontSizeClick" Tag="13" />
          <MenuItem Header="14 (default)" Click="OnSetFontSizeClick" Tag="14" />
          <MenuItem Header="16" Click="OnSetFontSizeClick" Tag="16" />
          <MenuItem Header="18" Click="OnSetFontSizeClick" Tag="18" />
          <MenuItem Header="20" Click="OnSetFontSizeClick" Tag="20" />
        </MenuItem>
        <MenuItem Header="{DynamicResource MenuLanguage}"
                  Name="SecondaryLanguageMenu">
          <MenuItem Header="{DynamicResource MenuLanguageOff}"
                    Click="OnSetSecondaryLanguageClick"
                    Tag="" />
        </MenuItem>
      </MenuItem>
    </Menu>

    <!-- Status footer:
         - Left: localization (PALOC entries / iteminfo items / secondary lang).
         - Middle: icon cache state (path + file count, or error).
         - Right: transient bulk-op status messages.
         The 3-column layout means changing icon folder gives the user
         immediate visual confirmation ("Icons: icons_local (6,011 files)")
         without needing to open Tools menu to verify the change. -->
    <Border DockPanel.Dock="Bottom"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            Padding="12,4">
      <Grid ColumnDefinitions="*,Auto,Auto"
            ColumnSpacing="16">
        <TextBlock Grid.Column="0"
                   Text="{Binding LocalizationStatus}"
                   Opacity="0.6"
                   FontSize="{Binding StatusBarFontSize}"
                   TextTrimming="CharacterEllipsis" />
        <TextBlock Grid.Column="1"
                   Text="{Binding IconStatus}"
                   Opacity="0.6"
                   FontSize="{Binding StatusBarFontSize}"
                   TextTrimming="CharacterEllipsis" />
        <TextBlock Grid.Column="2"
                   Text="{Binding BulkOpStatus}"
                   Opacity="0.9"
                   Foreground="Goldenrod"
                   FontSize="{Binding StatusBarFontSize}"
                   IsVisible="{Binding BulkOpStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
      </Grid>
    </Border>

    <!-- Empty state -->
    <StackPanel IsVisible="{Binding !HasSave}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
      <TextBlock Text="{DynamicResource EmptyTitle}"
                 FontSize="24"
                 HorizontalAlignment="Center" />
      <TextBlock Text="{DynamicResource EmptyHint}"
                 Opacity="0.6"
                 HorizontalAlignment="Center" />
      <TextBlock Text="{Binding AppVersion}"
                 Opacity="0.4"
                 FontSize="12"
                 HorizontalAlignment="Center" />
    </StackPanel>

    <!-- Loaded state. Summary column width binds to the VM so the
         user can collapse it to a narrow rail and reclaim ~280 px of
         horizontal space for the main DataGrids. -->
    <Grid IsVisible="{Binding HasSave}"
          Margin="12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="{Binding SummaryColumnWidth}" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- Left: summary. Header row carries the toggle button + title;
           the data Grid below hides when collapsed so the column can
           shrink to a thin rail showing just the toggle. -->
      <Border Grid.Column="0"
              Padding="6,12,12,12"
              BorderThickness="0,0,1,0"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
        <StackPanel Spacing="8">
          <Grid ColumnDefinitions="Auto,*"
                ColumnSpacing="6">
            <Button Grid.Column="0"
                    Content="{Binding SummaryToggleGlyph}"
                    Command="{Binding ToggleSummaryCollapsedCommand}"
                    ToolTip.Tip="{DynamicResource SummaryToggleTip}"
                    Padding="6,0"
                    MinHeight="24"
                    VerticalAlignment="Center" />
            <TextBlock Grid.Column="1"
                       Text="{DynamicResource SummaryHeader}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsSummaryExpanded}" />
          </Grid>

          <Grid ColumnDefinitions="Auto,*"
                RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                ColumnSpacing="12"
                RowSpacing="4"
                IsVisible="{Binding IsSummaryExpanded}">

            <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource SummarySlot}" Opacity="0.6" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Summary.SlotName}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource SummaryVersion}" Opacity="0.6" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Summary.Version}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource SummaryHmac}" Opacity="0.6" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding HmacStatusText}" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource SummaryPayload}" Opacity="0.6" />
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PayloadSizeText}" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource SummaryBody}" Opacity="0.6" />
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding UncompressedSizeText}" />

            <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource SummaryTypes}" Opacity="0.6" />
            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SchemaTypeCountText}" />

            <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource SummaryEntries}" Opacity="0.6" />
            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding TocEntryCountText}" />
          </Grid>
        </StackPanel>
      </Border>

      <!-- Right: blocks list (top) + field detail pane (bottom),
           split by a draggable GridSplitter. The blocks list itself
           has its own header row (title + count) and a filter box
           directly below it, mirroring the fields/elements panes. -->
      <Grid Grid.Column="1"
            RowDefinitions="Auto,Auto,*,Auto,320"
            Margin="12,0,0,0">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              Margin="0,0,0,4">
          <TextBlock Grid.Column="0"
                     Text="{DynamicResource BlocksHeader}"
                     FontSize="16"
                     FontWeight="SemiBold" />
          <TextBlock Grid.Column="1"
                     Text="{Binding BlocksFilterCountText}"
                     Opacity="0.6"
                     VerticalAlignment="Center" />
        </Grid>

        <!-- Blocks filter: matches case-insensitively against class
             name and the TOC index, so "Inventory" jumps to all the
             inventory-shaped blocks while "1106" jumps straight to
             row 1106. -->
        <TextBox Grid.Row="1"
                 Text="{Binding BlocksFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="{DynamicResource BlocksFilterPlaceholder}"
                 Margin="0,0,0,4" />

        <!-- Column widths are deliberately fixed (no Width="*") so the
             grid's total width exceeds the viewport and a horizontal
             scrollbar appears. Stretching one column to fill the viewport
             made every column-resize a "shuffle everything else first"
             chore; fixed widths + scroll is the standard "spreadsheet"
             affordance the user asked for. -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding VisibleBlocks}"
                  SelectedItem="{Binding SelectedBlock, Mode=TwoWay}"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AutoGenerateColumns="False"
                  Background="Transparent"
                  RowBackground="Transparent">
          <DataGrid.Columns>
            <DataGridTextColumn Header="{DynamicResource BlocksColIndex}"   Binding="{Binding Index}"          Width="60" />
            <DataGridTextColumn Header="{DynamicResource BlocksColClass}"   Binding="{Binding ClassName}"      Width="480" />
            <DataGridTextColumn Header="{DynamicResource BlocksColOffset}"  Binding="{Binding DataOffset}"     Width="120" />
            <DataGridTextColumn Header="{DynamicResource BlocksColSize}"    Binding="{Binding DataSize}"       Width="120" />
            <DataGridTextColumn Header="{DynamicResource BlocksColFields}"  Binding="{Binding FieldsDecoded}"  Width="80" />
          </DataGrid.Columns>
        </DataGrid>

        <GridSplitter Grid.Row="3"
                      Height="4"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                      ResizeDirection="Rows" />

        <Grid Grid.Row="4"
              RowDefinitions="Auto,Auto,Auto,Auto,*,Auto"
              Margin="0,8,0,0">

          <Grid Grid.Row="0"
                ColumnDefinitions="*,Auto"
                Margin="0,0,0,4">
            <TextBlock Grid.Column="0"
                       Text="{DynamicResource FieldsHeader}"
                       FontSize="14"
                       FontWeight="SemiBold" />
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Center">
              <TextBlock Text="{Binding FieldsFilterCountText}"
                         Opacity="0.6"
                         IsVisible="{Binding IsShowingFields}" />
              <TextBlock Text="{Binding ElementsCountText}"
                         Opacity="0.6"
                         IsVisible="{Binding IsShowingElements}" />
            </StackPanel>
          </Grid>

          <!-- Empty state: no block selected. -->
          <TextBlock Grid.Row="1"
                     Text="{DynamicResource FieldsHint}"
                     Opacity="0.6"
                     IsVisible="{Binding !HasSelectedBlock}"
                     Margin="0,0,0,4" />

          <!-- Breadcrumb. Each segment is a clickable button that pops
               the navigation stack back to that depth. -->
          <ItemsControl Grid.Row="1"
                        ItemsSource="{Binding Breadcrumb}"
                        IsVisible="{Binding HasSelectedBlock}"
                        Margin="0,0,0,4">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="4" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:BreadcrumbItem">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <Button Content="{Binding Label}"
                          Padding="6,2"
                          MinHeight="0"
                          Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).NavigateToDepthCommand}"
                          CommandParameter="{Binding Depth}" />
                  <TextBlock Text="›" Opacity="0.4" VerticalAlignment="Center" />
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Loaded-block state: metadata row + (conditional) block-action
               bar. Both visible only when a BlockFrame is on top (not when
               showing an element list). -->
          <StackPanel Grid.Row="2"
                      IsVisible="{Binding IsShowingFields}"
                      Orientation="Vertical"
                      Spacing="4"
                      Margin="0,0,0,4">
            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*"
                  ColumnSpacing="8">
              <TextBlock Grid.Column="0" Text="{DynamicResource FieldsMask}" Opacity="0.6" />
              <TextBlock Grid.Column="1" Text="{Binding MaskBytesText}" FontFamily="Cascadia Code,Consolas,monospace" />
              <TextBlock Grid.Column="2" Text="{DynamicResource FieldsTrailingPad}" Opacity="0.6" />
              <TextBlock Grid.Column="3" Text="{Binding TrailingPadText}" FontFamily="Cascadia Code,Consolas,monospace" />
              <TextBlock Grid.Column="4" Text="{DynamicResource FieldsUndecoded}" Opacity="0.6" />
              <TextBlock Grid.Column="5" Text="{Binding UndecodedRangesText}" FontFamily="Cascadia Code,Consolas,monospace" />
            </Grid>
            <!-- Block-action bar: "Mark Challenge Complete" stays VISIBLE
                 on every MissionStateData catalog row (IsCurrentNavOnMissionStateRow),
                 and ENABLES only when the row is fully eligible
                 (IsCurrentChallengeMarkable). The tooltip surfaces either the
                 action description (when eligible) or the skip reason from the
                 bulk-sweep diagnostic plumbing (when disabled) so the user can
                 see why the button is grayed out instead of guessing. -->
            <Button Content="{DynamicResource MarkChallengeCompleteButton}"
                    ToolTip.Tip="{Binding CurrentChallengeMarkTooltip}"
                    Command="{Binding MarkCurrentChallengeCompleteCommand}"
                    IsVisible="{Binding IsCurrentNavOnMissionStateRow}"
                    IsEnabled="{Binding IsCurrentChallengeMarkable}"
                    HorizontalAlignment="Left"
                    Padding="10,4"
                    MinHeight="0" />
          </StackPanel>

          <!-- Filter box: shown only when fields are being displayed. -->
          <TextBox Grid.Row="3"
                   Text="{Binding FieldsFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   PlaceholderText="{DynamicResource FieldsFilterPlaceholder}"
                   IsVisible="{Binding IsShowingFields}"
                   Margin="0,0,0,4" />

          <!-- Search box for the element-list view (e.g. itemList[14]):
               filter by ItemKey, resolved item name, or class. Same
               Grid.Row as the fields filter — they're mutually
               exclusive via IsVisible. -->
          <TextBox Grid.Row="3"
                   Text="{Binding ElementsFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   PlaceholderText="{DynamicResource ElementsFilterPlaceholder}"
                   IsVisible="{Binding IsShowingElements}"
                   Margin="0,0,0,4" />

          <!-- Fields DataGrid (visible when a block is on top). -->
          <DataGrid Grid.Row="4"
                    x:Name="FieldsDataGrid"
                    ItemsSource="{Binding VisibleFields}"
                    SelectedItem="{Binding SelectedField, Mode=TwoWay}"
                    IsVisible="{Binding IsShowingFields}"
                    IsReadOnly="True"
                    CanUserResizeColumns="True"
                    SelectionMode="Single"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    RowBackground="Transparent">
            <DataGrid.Columns>
              <DataGridTextColumn Header="{DynamicResource FieldsColIndex}"       Binding="{Binding FieldIndex}"   Width="50" />
              <DataGridTextColumn Header="{DynamicResource FieldsColName}"        Binding="{Binding Name}"         Width="320" />
              <DataGridTextColumn Header="{DynamicResource FieldsColType}"        Binding="{Binding TypeName}"     Width="200" />
              <DataGridTextColumn Header="{DynamicResource FieldsColKind}"        Binding="{Binding Kind}"         Width="130" />
              <DataGridTextColumn Header="{DynamicResource FieldsColPresent}"     Binding="{Binding Present}"      Width="80" />
              <DataGridTextColumn Header="{DynamicResource FieldsColValue}"       Binding="{Binding DisplayValue}" Width="400" />
              <DataGridTextColumn Header="{DynamicResource FieldsColResolvedName}" Binding="{Binding ResolvedName}" Width="280" />
              <DataGridTemplateColumn Header="{DynamicResource FieldsColDrill}" Width="80">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="vm:FieldRowViewModel">
                    <Button Content="{DynamicResource FieldsDrillButton}"
                            IsVisible="{Binding HasNested}"
                            HorizontalAlignment="Center"
                            Padding="8,2"
                            MinHeight="0"
                            Command="{Binding $parent[DataGrid].((vm:MainWindowViewModel)DataContext).DrillIntoFieldCommand}"
                            CommandParameter="{Binding Row}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>

          <!-- Inline edit panel: visible when the selected field is an
               editable top-level scalar. Clicking Apply pushes the bytes
               through SetScalarField; the DataGrid refreshes from the
               freshly re-decoded block. -->
          <Border Grid.Row="5"
                  IsVisible="{Binding IsEditPanelVisible}"
                  BorderThickness="0,1,0,0"
                  BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                  Padding="0,8,0,0"
                  Margin="0,8,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto"
                  RowDefinitions="Auto,Auto,Auto"
                  ColumnSpacing="8"
                  RowSpacing="4">
              <TextBlock Grid.Row="0" Grid.Column="0"
                         Text="{DynamicResource EditPanelHeader}"
                         FontWeight="SemiBold" />
              <TextBlock Grid.Row="0" Grid.Column="1"
                         Text="{Binding SelectedField.Name}"
                         Opacity="0.8"
                         FontFamily="Cascadia Code,Consolas,monospace"
                         Margin="8,0,0,0" />
              <!-- max-stack hint sits to the right of the type tag,
                   only when a peer ItemKey exists and the iteminfo
                   bridge knows that key. Doubles as the affordance
                   for the Set-to-max button immediately below — same
                   row's right side. -->
              <TextBlock Grid.Row="0" Grid.Column="2"
                         Text="{Binding SelectedFieldMaxStackHintText}"
                         Opacity="0.6"
                         FontFamily="Cascadia Code,Consolas,monospace"
                         Margin="8,0,0,0" />
              <TextBlock Grid.Row="0" Grid.Column="3"
                         Text="{Binding SelectedFieldTypeHint}"
                         Opacity="0.6"
                         FontFamily="Cascadia Code,Consolas,monospace" />

              <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="{Binding SelectedField.RawText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       KeyDown="OnEditValueKeyDown"
                       PlaceholderText="{Binding SelectedFieldTypeHint}" />
              <!-- Make absent: flips a present scalar to absent. Hidden
                   for already-absent rows (Apply handles the reverse).
                   Placed before Set-to-max so it sits visually adjacent
                   to the textbox — the destructive action that loses
                   the typed value. -->
              <Button Grid.Row="1" Grid.Column="2"
                      Content="{DynamicResource EditPanelMakeAbsent}"
                      ToolTip.Tip="{DynamicResource EditPanelMakeAbsentTip}"
                      Command="{Binding MakeFieldAbsentCommand}"
                      CommandParameter="{Binding SelectedField}"
                      IsVisible="{Binding SelectedField.Present, FallbackValue=False}" />
              <!-- Set-to-max: pre-fills RawText with the item's
                   max_stack_count. CanExecute keeps the button
                   disabled when there's no peer ItemKey or no
                   max-stack entry — so the user can leave it
                   visible at all times and it just lights up when
                   relevant. -->
              <Button Grid.Row="1" Grid.Column="3"
                      Content="{DynamicResource EditPanelFillMaxStack}"
                      ToolTip.Tip="{DynamicResource EditPanelFillMaxStackTip}"
                      Command="{Binding FillSelectedFieldToMaxStackCommand}" />
              <!-- Pick character… : visible only when the selected
                   scalar is a CharacterKey (TypeName check on the VM).
                   Opens the shared CharacterPickerWindow in pick mode;
                   the chosen key is written back to SelectedField.RawText
                   so the user can review + click Apply. -->
              <Button Grid.Row="1" Grid.Column="4"
                      Content="{DynamicResource EditPanelPickCharacter}"
                      ToolTip.Tip="{DynamicResource EditPanelPickCharacterTip}"
                      Click="OnPickCharacterClick"
                      IsVisible="{Binding IsSelectedFieldCharacterKey}" />
              <Button Grid.Row="1" Grid.Column="5"
                      Content="{DynamicResource EditPanelApply}"
                      Command="{Binding CommitFieldEditCommand}"
                      CommandParameter="{Binding SelectedField}"
                      IsDefault="True" />
              <Button Grid.Row="1" Grid.Column="6"
                      Content="{DynamicResource EditPanelRevert}"
                      Command="{Binding RevertFieldEditCommand}"
                      CommandParameter="{Binding SelectedField}" />

              <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="7"
                         Text="{Binding SelectedField.EditError}"
                         Foreground="IndianRed"
                         TextWrapping="Wrap"
                         IsVisible="{Binding SelectedField.EditError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </Grid>
          </Border>

          <!-- Elements DataGrid (visible when an ObjectList is on top:
               lets the user pick which element to drill into).
               Key + Name columns surface the row's identity so users
               can tell what each slot holds at a glance instead of
               seeing 14 identical "ItemSaveData" rows. SelectedElement
               is two-way so a breadcrumb back-pop can re-highlight
               (and scroll into view via x:Name) the row the user
               previously drilled from. -->
          <DataGrid Grid.Row="4"
                    x:Name="ElementsDataGrid"
                    ItemsSource="{Binding VisibleElements}"
                    SelectedItem="{Binding SelectedElement, Mode=TwoWay}"
                    IsVisible="{Binding IsShowingElements}"
                    IsReadOnly="True"
                    CanUserResizeColumns="True"
                    SelectionMode="Single"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    RowBackground="Transparent">
            <DataGrid.Columns>
              <DataGridTextColumn Header="{DynamicResource ElementsColIndex}"    Binding="{Binding ClassIndex}"   Width="60" />
              <!-- Icon column — only meaningful for ItemKey-typed rows
                   (ItemSaveData inside an itemList). The VM zeroes
                   IconItemKey on rows whose key field is a different
                   kind, so the converter returns null and the cell
                   stays empty for character / faction / container
                   pickers. -->
              <DataGridTemplateColumn Header="{DynamicResource ElementsColIcon}" Width="56">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="vm:ElementRowViewModel">
                    <Image Source="{Binding IconItemKey, Converter={x:Static svc:ItemKeyToIconConverter.Instance}}"
                           Width="40" Height="40"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="{DynamicResource ElementsColClass}"    Binding="{Binding ClassName}"    Width="280" />
              <DataGridTextColumn Header="{DynamicResource ElementsColItemKey}"  Binding="{Binding KeyText}"      Width="90" />
              <DataGridTextColumn Header="{DynamicResource ElementsColItemName}" Binding="{Binding ResolvedName}" Width="360" />
              <DataGridTextColumn Header="{DynamicResource ElementsColOffset}"   Binding="{Binding DataOffset}"   Width="120" />
              <DataGridTextColumn Header="{DynamicResource ElementsColSize}"     Binding="{Binding DataSize}"     Width="120" />
              <DataGridTemplateColumn Header="{DynamicResource ElementsColOpen}" Width="80">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="vm:ElementRowViewModel">
                    <Button Content="{DynamicResource ElementsOpenButton}"
                            HorizontalAlignment="Center"
                            Padding="8,2"
                            MinHeight="0"
                            Command="{Binding $parent[DataGrid].((vm:MainWindowViewModel)DataContext).DrillIntoElementCommand}"
                            CommandParameter="{Binding Block}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <!-- "Fill stack(s) to max" button — visible on two
                   row shapes:
                     (a) Single item: this row IS an ItemSaveData
                         (has _itemKey + _stackCount on its own
                         fields). Label: "Fill stack". Fills just
                         this row's count.
                     (b) Container: this row has a nested ItemList of
                         stackable items AND its own key is
                         InventoryKey-ish (excludes MercenarySaveData
                         et al. whose row resolves to a named entity).
                         Label: "Fill stacks". Fills every nested
                         item.
                   Both routes go through the same command which
                   prompts for confirmation before applying. -->
              <DataGridTemplateColumn Header="{DynamicResource ElementsColBulkFill}" Width="120">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="vm:ElementRowViewModel">
                    <Button Content="{Binding FillButtonLabel}"
                            ToolTip.Tip="{DynamicResource ElementsBulkFillTip}"
                            IsVisible="{Binding IsBulkFillCandidate}"
                            Padding="8,2"
                            MinHeight="0"
                            Command="{Binding $parent[DataGrid].((vm:MainWindowViewModel)DataContext).BulkFillItemListMaxStackCommand}"
                            CommandParameter="{Binding}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <!-- "Add Item…" button — discoverable entry point to the
                   unified Add-Item picker. Visible only on ItemSaveData
                   item rows (IsSingleFillCandidate). Clicking sets this
                   row as the clone template and opens the picker with a
                   top action bar ("+ Add … from <this row>"). -->
              <DataGridTemplateColumn Header="{DynamicResource ElementsColAddItem}" Width="110">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="vm:ElementRowViewModel">
                    <Button Content="{DynamicResource ElementsAddItemButton}"
                            ToolTip.Tip="{DynamicResource ElementsAddItemTip}"
                            IsVisible="{Binding IsSingleFillCandidate}"
                            Padding="8,2"
                            MinHeight="0"
                            Click="OnAddItemFromRowClick" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <!-- "Remove" button — length-changing edit (PR B). Drops
                   this element from the parent list via
                   ISaveLoader.ListRemoveElement, re-emits the body, and
                   refreshes the nav stack so the row disappears in
                   place. Confirms via the same modal hook the Fill
                   command uses; cancelled removes leave the save
                   untouched. -->
              <DataGridTemplateColumn Header="{DynamicResource ElementsColRemove}" Width="90">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="vm:ElementRowViewModel">
                    <Button Content="{DynamicResource ElementsRemoveButton}"
                            ToolTip.Tip="{DynamicResource ElementsRemoveTip}"
                            Padding="8,2"
                            MinHeight="0"
                            Command="{Binding $parent[DataGrid].((vm:MainWindowViewModel)DataContext).RemoveElementCommand}"
                            CommandParameter="{Binding}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Grid>
    </Grid>

    </DockPanel>
  </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CrimsonAtomtic.Ui.ViewModels"
        xmlns:model="using:CrimsonAtomtic.SaveModel"
        mc:Ignorable="d"
        d:DesignWidth="900"
        d:DesignHeight="600"
        x:Class="CrimsonAtomtic.Ui.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{StaticResource WindowTitle}"
        Width="960" Height="640"
        MinWidth="600" MinHeight="400">

  <DockPanel LastChildFill="True">

    <Menu DockPanel.Dock="Top">
      <MenuItem Header="{StaticResource MenuFile}">
        <MenuItem Header="{StaticResource MenuOpenSave}" Click="OnOpenSaveClick" />
        <Separator />
        <MenuItem Header="{StaticResource MenuExit}" Click="OnExitClick" />
      </MenuItem>
    </Menu>

    <!-- Empty state -->
    <StackPanel IsVisible="{Binding !HasSave}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
      <TextBlock Text="{StaticResource EmptyTitle}"
                 FontSize="24"
                 HorizontalAlignment="Center" />
      <TextBlock Text="{StaticResource EmptyHint}"
                 Opacity="0.6"
                 HorizontalAlignment="Center" />
    </StackPanel>

    <!-- Loaded state -->
    <Grid IsVisible="{Binding HasSave}"
          ColumnDefinitions="320,*"
          Margin="12">

      <!-- Left: summary -->
      <Border Grid.Column="0"
              Padding="12"
              BorderThickness="0,0,1,0"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
        <StackPanel Spacing="8">
          <TextBlock Text="{StaticResource SummaryHeader}"
                     FontSize="16"
                     FontWeight="SemiBold" />

          <Grid ColumnDefinitions="Auto,*"
                RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                ColumnSpacing="12"
                RowSpacing="4">

            <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource SummarySlot}" Opacity="0.6" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Summary.SlotName}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource SummaryVersion}" Opacity="0.6" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Summary.Version}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="{StaticResource SummaryHmac}" Opacity="0.6" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding HmacStatusText}" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="{StaticResource SummaryPayload}" Opacity="0.6" />
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PayloadSizeText}" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="{StaticResource SummaryBody}" Opacity="0.6" />
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding UncompressedSizeText}" />

            <TextBlock Grid.Row="5" Grid.Column="0" Text="{StaticResource SummaryTypes}" Opacity="0.6" />
            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SchemaTypeCountText}" />

            <TextBlock Grid.Row="6" Grid.Column="0" Text="{StaticResource SummaryEntries}" Opacity="0.6" />
            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding TocEntryCountText}" />
          </Grid>
        </StackPanel>
      </Border>

      <!-- Right: blocks list (top) + field detail pane (bottom),
           split by a draggable GridSplitter. -->
      <Grid Grid.Column="1"
            RowDefinitions="Auto,*,Auto,260"
            Margin="12,0,0,0">

        <TextBlock Grid.Row="0"
                   Text="{StaticResource BlocksHeader}"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Blocks}"
                  SelectedItem="{Binding SelectedBlock, Mode=TwoWay}"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AutoGenerateColumns="False">
          <DataGrid.Columns>
            <DataGridTextColumn Header="{StaticResource BlocksColIndex}"   Binding="{Binding Index}"      Width="60" />
            <DataGridTextColumn Header="{StaticResource BlocksColClass}"   Binding="{Binding ClassName}"  Width="*" />
            <DataGridTextColumn Header="{StaticResource BlocksColOffset}"  Binding="{Binding DataOffset}" Width="120" />
            <DataGridTextColumn Header="{StaticResource BlocksColSize}"    Binding="{Binding DataSize}"   Width="120" />
            <DataGridTextColumn Header="{StaticResource BlocksColFields}"  Binding="{Binding FieldsDecoded}" Width="80" />
          </DataGrid.Columns>
        </DataGrid>

        <GridSplitter Grid.Row="2"
                      Height="4"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                      ResizeDirection="Rows" />

        <Grid Grid.Row="3"
              RowDefinitions="Auto,Auto,Auto,Auto,*"
              Margin="0,8,0,0">

          <Grid Grid.Row="0"
                ColumnDefinitions="*,Auto"
                Margin="0,0,0,4">
            <TextBlock Grid.Column="0"
                       Text="{StaticResource FieldsHeader}"
                       FontSize="14"
                       FontWeight="SemiBold" />
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Center">
              <TextBlock Text="{Binding FieldsFilterCountText}"
                         Opacity="0.6"
                         IsVisible="{Binding IsShowingFields}" />
              <TextBlock Text="{Binding ElementsCountText}"
                         Opacity="0.6"
                         IsVisible="{Binding IsShowingElements}" />
            </StackPanel>
          </Grid>

          <!-- Empty state: no block selected. -->
          <TextBlock Grid.Row="1"
                     Text="{StaticResource FieldsHint}"
                     Opacity="0.6"
                     IsVisible="{Binding !HasSelectedBlock}"
                     Margin="0,0,0,4" />

          <!-- Breadcrumb. Each segment is a clickable button that pops
               the navigation stack back to that depth. -->
          <ItemsControl Grid.Row="1"
                        ItemsSource="{Binding Breadcrumb}"
                        IsVisible="{Binding HasSelectedBlock}"
                        Margin="0,0,0,4">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="4" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:BreadcrumbItem">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <Button Content="{Binding Label}"
                          Padding="6,2"
                          MinHeight="0"
                          Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).NavigateToDepthCommand}"
                          CommandParameter="{Binding Depth}" />
                  <TextBlock Text="›" Opacity="0.4" VerticalAlignment="Center" />
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Loaded-block state: metadata row. Visible only when a
               BlockFrame is on top (not when showing an element list). -->
          <Grid Grid.Row="2"
                IsVisible="{Binding IsShowingFields}"
                ColumnDefinitions="Auto,*,Auto,*,Auto,*"
                ColumnSpacing="8"
                Margin="0,0,0,4">
            <TextBlock Grid.Column="0" Text="{StaticResource FieldsMask}" Opacity="0.6" />
            <TextBlock Grid.Column="1" Text="{Binding MaskBytesText}" FontFamily="Cascadia Code,Consolas,monospace" />
            <TextBlock Grid.Column="2" Text="{StaticResource FieldsTrailingPad}" Opacity="0.6" />
            <TextBlock Grid.Column="3" Text="{Binding TrailingPadText}" FontFamily="Cascadia Code,Consolas,monospace" />
            <TextBlock Grid.Column="4" Text="{StaticResource FieldsUndecoded}" Opacity="0.6" />
            <TextBlock Grid.Column="5" Text="{Binding UndecodedRangesText}" FontFamily="Cascadia Code,Consolas,monospace" />
          </Grid>

          <!-- Filter box: shown only when fields are being displayed. -->
          <TextBox Grid.Row="3"
                   Text="{Binding FieldsFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   PlaceholderText="{StaticResource FieldsFilterPlaceholder}"
                   IsVisible="{Binding IsShowingFields}"
                   Margin="0,0,0,4" />

          <!-- Fields DataGrid (visible when a block is on top). -->
          <DataGrid Grid.Row="4"
                    ItemsSource="{Binding VisibleFields}"
                    IsVisible="{Binding IsShowingFields}"
                    IsReadOnly="True"
                    CanUserResizeColumns="True"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    AutoGenerateColumns="False">
            <DataGrid.Columns>
              <DataGridTextColumn Header="{StaticResource FieldsColIndex}"   Binding="{Binding FieldIndex}" Width="50" />
              <DataGridTextColumn Header="{StaticResource FieldsColName}"    Binding="{Binding Name}"       Width="280" />
              <DataGridTextColumn Header="{StaticResource FieldsColType}"    Binding="{Binding TypeName}"   Width="160" />
              <DataGridTextColumn Header="{StaticResource FieldsColKind}"    Binding="{Binding Kind}"       Width="120" />
              <DataGridTextColumn Header="{StaticResource FieldsColPresent}" Binding="{Binding Present}"    Width="70" />
              <DataGridTextColumn Header="{StaticResource FieldsColValue}"   Binding="{Binding Value}"      Width="*" />
              <DataGridTemplateColumn Header="{StaticResource FieldsColDrill}" Width="80">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="model:DecodedFieldRow">
                    <Button Content="{StaticResource FieldsDrillButton}"
                            IsVisible="{Binding HasNested}"
                            HorizontalAlignment="Center"
                            Padding="8,2"
                            MinHeight="0"
                            Command="{Binding $parent[DataGrid].((vm:MainWindowViewModel)DataContext).DrillIntoFieldCommand}"
                            CommandParameter="{Binding}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>

          <!-- Elements DataGrid (visible when an ObjectList is on top:
               lets the user pick which element to drill into). -->
          <DataGrid Grid.Row="4"
                    ItemsSource="{Binding VisibleElements}"
                    IsVisible="{Binding IsShowingElements}"
                    IsReadOnly="True"
                    CanUserResizeColumns="True"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    AutoGenerateColumns="False">
            <DataGrid.Columns>
              <DataGridTextColumn Header="{StaticResource ElementsColIndex}"  Binding="{Binding ClassIndex}" Width="60" />
              <DataGridTextColumn Header="{StaticResource ElementsColClass}"  Binding="{Binding ClassName}"  Width="*" />
              <DataGridTextColumn Header="{StaticResource ElementsColOffset}" Binding="{Binding DataOffset}" Width="120" />
              <DataGridTextColumn Header="{StaticResource ElementsColSize}"   Binding="{Binding DataSize}"   Width="120" />
              <DataGridTemplateColumn Header="{StaticResource ElementsColOpen}" Width="80">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="model:BlockDetails">
                    <Button Content="{StaticResource ElementsOpenButton}"
                            HorizontalAlignment="Center"
                            Padding="8,2"
                            MinHeight="0"
                            Command="{Binding $parent[DataGrid].((vm:MainWindowViewModel)DataContext).DrillIntoElementCommand}"
                            CommandParameter="{Binding}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Grid>
    </Grid>

  </DockPanel>
</Window>

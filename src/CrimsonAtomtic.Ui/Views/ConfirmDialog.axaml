<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="440"
        d:DesignHeight="200"
        x:Class="CrimsonAtomtic.Ui.Views.ConfirmDialog"
        Width="440"
        MinWidth="320" MinHeight="140"
        MaxHeight="640"
        SizeToContent="Height"
        CanResize="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/MainIcon.ico">

  <!-- Auto-grows to fit the message (SizeToContent="Height") up to
       MaxHeight; longer prose (e.g. the localized sealed-artifact
       confirm) scrolls inside the ScrollViewer. The button row stays
       pinned below the scrolling region, so it's always reachable. -->
  <Grid Margin="16" RowDefinitions="*,Auto">
    <ScrollViewer Grid.Row="0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <TextBlock Name="MessageText"
                 TextWrapping="Wrap"
                 Margin="0,0,8,0" />
    </ScrollViewer>

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,16,0,0">
      <Button Name="NoButton"
              Content="{DynamicResource ConfirmDialogNo}"
              Click="OnNoClick"
              MinWidth="80" />
      <Button Name="YesButton"
              Content="{DynamicResource ConfirmDialogYes}"
              Click="OnYesClick"
              MinWidth="80"
              IsDefault="True" />
    </StackPanel>
  </Grid>
</Window>

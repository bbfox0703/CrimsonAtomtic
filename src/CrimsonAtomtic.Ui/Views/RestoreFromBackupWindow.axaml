<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CrimsonAtomtic.Ui.ViewModels"
        mc:Ignorable="d"
        d:DesignWidth="780"
        d:DesignHeight="420"
        x:Class="CrimsonAtomtic.Ui.Views.RestoreFromBackupWindow"
        x:DataType="vm:RestoreFromBackupViewModel"
        Title="{StaticResource RestoreFromBackupTitle}"
        Icon="/Assets/MainIcon.ico"
        Width="780" Height="420"
        MinWidth="520" MinHeight="280">

  <Grid RowDefinitions="Auto,Auto,*"
        Margin="12">

    <TextBlock Grid.Row="0"
               Text="{Binding Subtitle}"
               TextWrapping="Wrap"
               Margin="0,0,0,4" />

    <TextBlock Grid.Row="1"
               Text="{StaticResource RestoreFromBackupColumnHint}"
               Opacity="0.6"
               FontSize="11"
               Margin="0,0,0,8" />

    <DataGrid Grid.Row="2"
              ItemsSource="{Binding Backups}"
              IsReadOnly="True"
              CanUserResizeColumns="True"
              CanUserSortColumns="True"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column"
              AutoGenerateColumns="False">
      <DataGrid.Columns>
        <DataGridTextColumn Header="{StaticResource RestoreColSlot}"
                            Binding="{Binding SlotLabel}"
                            Width="180" />
        <DataGridTextColumn Header="{StaticResource RestoreColTimestamp}"
                            Binding="{Binding TimestampLabel}"
                            SortMemberPath="TimestampSortKey"
                            Width="180" />
        <DataGridTextColumn Header="{StaticResource RestoreColFiles}"
                            Binding="{Binding FileSummary}"
                            Width="180" />
        <DataGridTextColumn Header="{StaticResource RestoreColSize}"
                            Binding="{Binding TotalBytesLabel}"
                            Width="90" />
        <!-- Per-row Restore button. Click goes through the VM event
             pipe to MainWindow which routes to RestoreFromBackupAsync.
             The dialog itself doesn't perform the file copy; the main
             VM owns the I/O so it can also re-load the save into the
             UI afterwards. -->
        <DataGridTemplateColumn Header="{StaticResource RestoreColAction}"
                                Width="120">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="vm:BackupRowViewModel">
              <Button Content="{StaticResource RestoreButton}"
                      ToolTip.Tip="{StaticResource RestoreButtonTip}"
                      Padding="8,2"
                      MinHeight="0"
                      Tag="{Binding Entry}"
                      Click="OnRestoreButtonClick" />
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</Window>

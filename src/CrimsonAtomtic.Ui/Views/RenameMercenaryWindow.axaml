<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CrimsonAtomtic.Ui.ViewModels"
        x:Class="CrimsonAtomtic.Ui.Views.RenameMercenaryWindow"
        x:DataType="vm:RenameMercenaryViewModel"
        Title="{StaticResource MenuRenameMercenary}"
        Width="1280" Height="600"
        MinWidth="960" MinHeight="360"
        FontSize="{Binding $parent[Window].FontSize, FallbackValue=14}">

  <DockPanel LastChildFill="True" Margin="12">
    <!-- Header explains the v1 limitation up front so users don't go
         hunting for a "show current name" column that doesn't exist. -->
    <TextBlock DockPanel.Dock="Top"
               Text="{StaticResource RenameMercenaryHeader}"
               TextWrapping="Wrap"
               Opacity="0.7"
               Margin="0,0,0,8" />

    <!-- Status footer + Close button. -->
    <Grid DockPanel.Dock="Bottom"
          ColumnDefinitions="*,Auto"
          ColumnSpacing="12"
          Margin="0,8,0,0">
      <TextBlock Grid.Column="0"
                 Text="{Binding StatusMessage}"
                 Opacity="0.7"
                 VerticalAlignment="Center"
                 TextTrimming="CharacterEllipsis" />
      <Button Grid.Column="1"
              Content="{StaticResource RenameMercenaryClose}"
              Click="OnCloseClick"
              MinWidth="80" />
    </Grid>

    <!-- Mercenary list. Identity columns first; then a textbox per row
         for the new name, an Apply button, and a tail "Applied" column
         that fills in once the user has renamed an entry. -->
    <DataGrid ItemsSource="{Binding Mercenaries}"
              AutoGenerateColumns="False"
              CanUserResizeColumns="True"
              CanUserSortColumns="False"
              GridLinesVisibility="Horizontal"
              IsReadOnly="False"
              HeadersVisibility="Column">
      <DataGrid.Columns>
        <DataGridTextColumn Header="{StaticResource RenameMercenaryColIdx}"
                            Binding="{Binding Index}"
                            Width="60"
                            IsReadOnly="True" />
        <DataGridTextColumn Header="{StaticResource RenameMercenaryColMercNo}"
                            Binding="{Binding MercNo}"
                            Width="80"
                            IsReadOnly="True" />
        <DataGridTextColumn Header="{StaticResource RenameMercenaryColCharKey}"
                            Binding="{Binding CharacterKey}"
                            Width="90"
                            IsReadOnly="True" />
        <!-- Portrait column. The real DDS-derived Image binds to the
             row's Portrait property which fills in asynchronously
             after construction; the TextBlock fallback shows the
             row's CategoryGlyph (🐎 / 🚐 / 🎈 / 🦌 / 👤 / 🐾 / ❔)
             whenever Portrait is null — most 1.07 mercenaries are
             mounts / wagons / animals with template names, and Pearl
             Abyss only ships per-character portraits for ~3 main
             NPCs, so the fallback is the common case. -->
        <DataGridTemplateColumn Header="{StaticResource RenameMercenaryColPortrait}"
                                Width="60">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate DataType="vm:MercenaryRow">
              <Panel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="{Binding Portrait}"
                       Width="48" Height="48"
                       Stretch="Uniform"
                       IsVisible="{Binding HasPortrait}" />
                <TextBlock Text="{Binding CategoryGlyph}"
                           FontSize="28"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Opacity="0.65"
                           IsVisible="{Binding !HasPortrait}" />
              </Panel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="{StaticResource RenameMercenaryColCharName}"
                            Binding="{Binding ResolvedCharacterName}"
                            Width="200"
                            IsReadOnly="True" />
        <DataGridTextColumn Header="{StaticResource RenameMercenaryColType}"
                            Binding="{Binding TypeTag}"
                            Width="90"
                            IsReadOnly="True" />
        <DataGridTextColumn Header="{StaticResource RenameMercenaryColEquip}"
                            Binding="{Binding EquipCount}"
                            Width="70"
                            IsReadOnly="True" />
        <!-- New-name TextBox uses Mode=TwoWay + UpdateSourceTrigger=
             PropertyChanged so the bound NewName field tracks each
             keystroke. Default LostFocus binding meant the value only
             commits when you tab away — coupled with the CanExecute
             gate that's been removed, the user's first Apply click
             could land before NewName updated, surfacing as a no-op.
             PropertyChanged commits on every character so the textbox
             is always in sync with the model. -->
        <DataGridTemplateColumn Header="{StaticResource RenameMercenaryColNewName}"
                                Width="*"
                                MinWidth="220">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate DataType="vm:MercenaryRow">
              <TextBox Text="{Binding NewName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       VerticalAlignment="Center"
                       PlaceholderText="{StaticResource RenameMercenaryNewNameWatermark}" />
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTemplateColumn Header="{StaticResource RenameMercenaryColApply}"
                                Width="90">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate DataType="vm:MercenaryRow">
              <Button Content="{StaticResource RenameMercenaryApply}"
                      Command="{Binding ApplyCommand}"
                      HorizontalAlignment="Stretch" />
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="{StaticResource RenameMercenaryColApplied}"
                            Binding="{Binding AppliedName}"
                            Width="160"
                            IsReadOnly="True" />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</Window>

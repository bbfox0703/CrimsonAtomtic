<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CrimsonAtomtic.Ui.ViewModels"
        mc:Ignorable="d"
        d:DesignWidth="900"
        d:DesignHeight="540"
        x:Class="CrimsonAtomtic.Ui.Views.DyeSlotEditorWindow"
        x:DataType="vm:DyeSlotEditorViewModel"
        Title="{DynamicResource DyeSlotEditorWindowTitle}"
        Icon="/Assets/MainIcon.ico"
        Width="940" Height="560"
        MinWidth="760" MinHeight="380"
        FontSize="{Binding $parent[Window].FontSize, FallbackValue=14}">

  <DockPanel LastChildFill="True" Margin="12">
    <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,0,0,8">
      <TextBlock Text="{Binding HeaderText}" FontWeight="Bold" />
      <TextBlock Text="{Binding SubHeaderText}" Opacity="0.7" />
    </StackPanel>

    <Grid DockPanel.Dock="Bottom"
          ColumnDefinitions="*,Auto"
          ColumnSpacing="12"
          Margin="0,8,0,0">
      <TextBlock Grid.Column="0"
                 Text="{Binding StatusMessage}"
                 Opacity="0.7"
                 VerticalAlignment="Center"
                 TextTrimming="CharacterEllipsis" />
      <Button Grid.Column="1"
              Content="{DynamicResource DyeSlotEditorClose}"
              Click="OnCloseClick"
              MinWidth="80" />
    </Grid>

    <!-- Per-slot rows. Each row carries 7 editors (R/G/B/A + grime +
         material + color group) + an Apply button + LastError text.
         DataGrid keeps things compact for items with 3-4 slots. -->
    <DataGrid ItemsSource="{Binding Slots}"
              IsReadOnly="False"
              CanUserResizeColumns="True"
              CanUserSortColumns="False"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column"
              AutoGenerateColumns="False">
      <DataGrid.Columns>
        <DataGridTextColumn Header="{DynamicResource DyeSlotColSlot}"
                            Binding="{Binding SlotLabel}"
                            Width="110"
                            IsReadOnly="True" />
        <!-- Read-only gamedata material-layer hint. Shows both dye layers
             ("leather + cloth") on 1.13's expanded dyeable gear; the save
             carries a single palette key per slot, so this is orientation
             only, not separately editable. -->
        <DataGridTextColumn Header="{DynamicResource DyeSlotColLayers}"
                            Binding="{Binding MaterialLayers}"
                            Width="140"
                            IsReadOnly="True" />
        <!-- Color column: replaces the previous R/G/B/A NumericUpDowns
             with a visual swatch + "Pick…" button. The engine snaps
             every in-game dye to one of the color group's 109 palette
             positions (see vendor/crimson-rs/docs/dye-editor-scope.md
             §"Recommended C# editor UX"), so the off-grid byte-level
             control that NumericUpDowns gave was an illusion — the
             palette grid is the correct UX. Off-grid CE-modified
             values still work (Apply writes whatever R/G/B is in the
             row; the picker just won't highlight a current cell for
             them). -->
        <DataGridTemplateColumn Header="{DynamicResource DyeSlotColColor}" Width="170">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="vm:DyeSlotRow">
              <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Border Width="28" Height="28"
                        Background="{Binding SwatchBrush}"
                        BorderBrush="Black"
                        BorderThickness="1"
                        CornerRadius="2"
                        ToolTip.Tip="{Binding SwatchHex}" />
                <Button Content="{DynamicResource DyeSlotPick}"
                        Command="{Binding RequestPickColorCommand}"
                        Padding="6,2"
                        MinHeight="0" />
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTemplateColumn Header="{DynamicResource DyeSlotColGrime}" Width="80">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="vm:DyeSlotRow">
              <NumericUpDown Value="{Binding Grime}" Minimum="-128" Maximum="127"
                             ShowButtonSpinner="False" Increment="1"
                             HorizontalContentAlignment="Right" />
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTemplateColumn Header="{DynamicResource DyeSlotColMaterial}" Width="200">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="vm:DyeSlotRow">
              <ComboBox ItemsSource="{Binding MaterialOptions}"
                        SelectedItem="{Binding SelectedMaterial}"
                        DisplayMemberBinding="{Binding Display}"
                        HorizontalAlignment="Stretch" />
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTemplateColumn Header="{DynamicResource DyeSlotColColorGroup}" Width="200">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="vm:DyeSlotRow">
              <ComboBox ItemsSource="{Binding ColorGroupOptions}"
                        SelectedItem="{Binding SelectedColorGroup}"
                        DisplayMemberBinding="{Binding Display}"
                        HorizontalAlignment="Stretch" />
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTemplateColumn Header="{DynamicResource DyeSlotColAction}" Width="90">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="vm:DyeSlotRow">
              <Button Content="{DynamicResource DyeSlotApply}"
                      Command="{Binding ApplyCommand}"
                      Padding="6,2"
                      MinHeight="0" />
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="{DynamicResource DyeSlotColStatus}"
                            Binding="{Binding LastError}"
                            Width="*"
                            IsReadOnly="True" />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</Window>

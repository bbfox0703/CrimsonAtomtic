<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CrimsonAtomtic.Ui.App"
             RequestedThemeVariant="Default">

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
  </Application.Styles>

  <Application.Resources>
    <ResourceDictionary>
      <!-- FluentTheme defaults FlyoutThemeMaxWidth (in
           Accents/BaseResources.xaml) to 456 dip — that one resource key
           caps BOTH the top-level Menu's MenuItem submenu Popup Border
           AND every MenuFlyoutPresenter / Flyout via a single
           DynamicResource lookup. At any FontSize above the default 14
           the longest Tools-menu items
           ("Complete Eligible Held Sealed Abyss Artifact Challenges…")
           clip mid-word. Override widens the cap to comfortably fit
           every shipped UI string at FontSize 22 (the supported
           maximum). Earlier attempt at `MenuFlyoutThemeMaxWidth` was a
           no-op — that key doesn't exist in v12 Fluent. -->
      <x:Double x:Key="FlyoutThemeMaxWidth">1000</x:Double>

      <!-- Every shipped UI language is pre-merged here so the
           avares:// Source is resolved at XAML-compile time (AOT-safe;
           constructing a ResourceInclude at runtime trips IL2026
           because its (Uri) ctor is RequiresUnreferencedCode).
           UiLanguageService.Apply reorders this collection at runtime
           so the active language sits last — Avalonia's MergedDictionaries
           lookup walks in reverse, so last-merged wins for duplicate keys. -->
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CrimsonAtomtic/Resources/Strings/en.axaml" />
        <ResourceInclude Source="avares://CrimsonAtomtic/Resources/Strings/ja.axaml" />
        <ResourceInclude Source="avares://CrimsonAtomtic/Resources/Strings/zh-TW.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

</Application>

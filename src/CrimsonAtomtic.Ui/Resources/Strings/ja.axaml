  <sys:String x:Key="ItemPickerCopyNameTip">英語名をクリップボードにコピー</sys:String>
  <sys:String x:Key="ItemPickerCopyNameSecondaryTip">セカンダリ言語の名前をクリップボードにコピー</sys:String>


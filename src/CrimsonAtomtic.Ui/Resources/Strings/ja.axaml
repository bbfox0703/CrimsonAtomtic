  <!-- Drill-down + navigation -->
  <sys:String x:Key="FieldsColDrill">ドリル</sys:String>
  <sys:String x:Key="FieldsDrillButton">▸</sys:String>

  <!-- Edit panel -->
  <sys:String x:Key="EditPanelHeader">フィールドを編集</sys:String>
  <sys:String x:Key="EditPanelNameLabel">フィールド</sys:String>
  <sys:String x:Key="EditPanelTypeLabel">型</sys:String>
  <sys:String x:Key="EditPanelValueLabel">新しい値</sys:String>
  <sys:String x:Key="EditPanelApply">適用</sys:String>
  <sys:String x:Key="EditPanelRevert">元に戻す</sys:String>
  <sys:String x:Key="EditPanelFillMaxStack">最大値に設定</sys:String>
  <sys:String x:Key="EditPanelFillMaxStackTip">このフィールドにアイテムの max_stack_count (iteminfo より) を入れます。テキストボックスにあらかじめ入力されます — 確認後 Apply をクリックしてください。</sys:String>
  <sys:String x:Key="EditPanelMakeAbsent">absent にする</sys:String>
  <sys:String x:Key="EditPanelMakeAbsentTip">このスカラーの存在ビットをオフに反転 — フィールドが block から削除されます (mask bit クリア、payload bytes 破棄)。値を入力して Apply をクリックすると元に戻せます。</sys:String>
  <sys:String x:Key="MarkChallengeCompleteButton">✓ チャレンジ完了をマーク (Pattern B v1)</sys:String>
  <sys:String x:Key="MarkChallengeCompleteTip">エンジン忠実な単一チャレンジ完了 (Pattern B v1)。ゲームが既にこのチャレンジを検出し、利用可能と表示している (ゲーム内で封印遺物を入手済み) 場合のみ有効化されます。関連エントリを書き込みます — 完了済みだが未受領の状態でゲーム自身が書き込む内容と完全に同じです。生活系のチャレンジには適用されない場合があります。完全テスト未済 — まず必ずセーブをバックアップしてください。</sys:String>
  <sys:String x:Key="MarkChallengeSkipReasonPrefix">無効 — 理由:</sys:String>
  <sys:String x:Key="ConfirmDialogYes">はい</sys:String>
  <sys:String x:Key="ConfirmDialogNo">いいえ</sys:String>
  <sys:String x:Key="ElementsColBulkFill">一括</sys:String>
  <sys:String x:Key="ElementsBulkFillButton">スタックを満たす</sys:String>
  <sys:String x:Key="ElementsBulkFillTip">このコンテナ内の全アイテムの _stackCount を iteminfo の max_stack_count に設定します。</sys:String>
  <sys:String x:Key="ElementsBulkFillConfirmTitle">スタックを最大まで満たしますか？</sys:String>
  <sys:String x:Key="ElementsColRemove">削除</sys:String>
  <sys:String x:Key="ElementsRemoveButton">✕ 削除</sys:String>
  <sys:String x:Key="ElementsRemoveTip">この要素を list から取り除きます。save body はそれに合わせて縮みます。書き込まずに再読み込みすれば元に戻せます。</sys:String>
  <sys:String x:Key="ItemPickerAddToBagTip">このアイテムを、メインウィンドウが現在表示しているインベントリリストに追加します。先にバッグを開いて (_inventorylist[N]._itemList へドリルダウン) ください。さもないとクリック時に必要条件がステータスバーに表示されます。</sys:String>
  <sys:String x:Key="MenuRestoreFromBackup">バックアップから復元…</sys:String>
  <sys:String x:Key="RestoreFromBackupTitle">バックアップから復元</sys:String>
  <sys:String x:Key="RestoreFromBackupColumnHint">行の「復元」をクリックすると、そのスナップショットで現セーブを上書きします。現在の内容は先にバックアップされます。</sys:String>
  <sys:String x:Key="RestoreColSlot">Slot (ユーザー / 名前)</sys:String>
  <sys:String x:Key="RestoreColTimestamp">バックアップ取得時刻</sys:String>
  <sys:String x:Key="RestoreColFiles">ファイル</sys:String>
  <sys:String x:Key="RestoreColSize">サイズ</sys:String>
  <sys:String x:Key="RestoreColAction">操作</sys:String>
  <sys:String x:Key="RestoreButton">⤺ 復元</sys:String>
  <sys:String x:Key="RestoreButtonTip">このバックアップで現セーブを上書きします。現状態が先にバックアップされるので、本復元操作自体も取り消し可能です。</sys:String>
  <sys:String x:Key="EditPanelNestedReadOnly">ネストされたフィールドの編集はまだサポートされていません。Back でトップレベル block に戻ってください。</sys:String>
  <sys:String x:Key="ElementsColIcon">アイコン</sys:String>
  <sys:String x:Key="ElementsColIndex">#</sys:String>
  <sys:String x:Key="ElementsColClass">Class</sys:String>
  <sys:String x:Key="ElementsColOffset">Offset</sys:String>
  <sys:String x:Key="ElementsColSize">Size</sys:String>
  <sys:String x:Key="ElementsColFields">フィールド数</sys:String>
  <sys:String x:Key="ElementsColOpen">開く</sys:String>
  <sys:String x:Key="ElementsOpenButton">▸</sys:String>
  <sys:String x:Key="ElementsColItemKey">Key</sys:String>
  <sys:String x:Key="ElementsColItemName">名前</sys:String>
  <sys:String x:Key="ElementsFilterPlaceholder">キー、名前、クラスで絞り込み…</sys:String>

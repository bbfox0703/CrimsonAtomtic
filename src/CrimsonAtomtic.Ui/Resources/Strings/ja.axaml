  <sys:String x:Key="JournalDyeEdited">{0} のスロット {1} の染色を編集（{2}）</sys:String>

  <!-- ソケット編集ダイアログ -->
  <sys:String x:Key="JournalCatSockets">ソケット</sys:String>
  <sys:String x:Key="SocketApplySetFailed">セット適用：{0} — {1} スロット後にコミット失敗：{2}（コード {3}）。書き込まずに再読み込みすると元に戻せます。</sys:String>
  <sys:String x:Key="SocketApplySetNoChange">セット適用：{0} — 変更なし（対象の全スロットが既に一致）。</sys:String>
  <sys:String x:Key="JournalSocketApplySet">セット「{0}」を {1} に適用 — {2} スロット変更</sys:String>
  <sys:String x:Key="SocketApplySetDone">セット「{0}」を {1} に適用：{2} スロット変更。</sys:String>
  <sys:String x:Key="SocketSameGem">現在の宝石と同じ — 書き込みは行われませんでした。</sys:String>
  <sys:String x:Key="SocketApplyFailed">適用に失敗（{0}、アイテム {1}、ソケット {2}）：{3}</sys:String>
  <sys:String x:Key="JournalSocketSet">{0} のソケット {1} に宝石を設定 → {2}</sys:String>
  <sys:String x:Key="JournalSocketFilled">{0} のソケット {1} に宝石を充填 → {2}</sys:String>
  <sys:String x:Key="SocketSetDone">{0} のソケット {1} に宝石を設定：→ {2}。</sys:String>
  <sys:String x:Key="SocketFilledDone">{0} のソケット {1} に宝石を充填：→ {2}。</sys:String>
  <sys:String x:Key="SocketClearFailed">クリアに失敗（{0}、アイテム {1}、ソケット {2}）：{3}</sys:String>
  <sys:String x:Key="JournalSocketCleared">{0} のソケット {1} の宝石をクリア（元は {2}）</sys:String>
  <sys:String x:Key="SocketClearDone">{0} のソケット {1} の宝石をクリアしました（元は {2}）。</sys:String>

  <!-- カスタム宝石セット編集ダイアログ -->
  <sys:String x:Key="GemSetsHeader">最大 3 つのカスタムセット、各最大 5 個の宝石。空のキーセルは保存時にスキップされます。</sys:String>
  <sys:String x:Key="GemSetsInvalidKey">セット {0}：「{1}」は有効な ItemKey（10進 u32）ではありません。保存を中止しました。</sys:String>
  <sys:String x:Key="GemSetsSaveFailed">保存に失敗（settings.json を書き込めません）。カスタムセットは保存されていません。</sys:String>
  <sys:String x:Key="GemSetsSaved">{0} 個のカスタムセット定義を保存しました。ソケットエディタを閉じて再度開くと「セット適用」ツールバーで使用できます。</sys:String>

  <!-- 傭兵の名前変更ダイアログ -->
  <sys:String x:Key="JournalCatRenameMercenary">傭兵の名前変更</sys:String>
  <sys:String x:Key="RenameMercLoaded">{0} 件の傭兵エントリを読み込みました。</sys:String>
  <sys:String x:Key="RenameMercFailed">インデックス {0} の名前変更に失敗：{1}</sys:String>
  <sys:String x:Key="RenameMercEmpty">（空）</sys:String>
  <sys:String x:Key="RenameMercNameBytes">「{0}」（{1} bytes UTF-8）</sys:String>
  <sys:String x:Key="RenameMercDone">idx {0}（MercNo {1}）を名前変更 → {2}</sys:String>
  <sys:String x:Key="RenameMercIdentityNo">MercNo {0}</sys:String>
  <sys:String x:Key="JournalRenameCleared">{0} のカスタム名をクリア</sys:String>
  <sys:String x:Key="JournalRenameSet">{0} を「{1}」に名前変更</sys:String>

  <!-- 店買い戻し + キャラクター参照ダイアログ -->
  <sys:String x:Key="BuybackRemoveFailed">削除に失敗：{0}</sys:String>
  <sys:String x:Key="CharRefsEnumFailed">CharacterKey 参照の列挙に失敗：{0}（コード {1}）</sys:String>

  <!-- バックアップから復元ダイアログのサブタイトル -->
  <sys:String x:Key="RestoreSubtitleNone">{0} の下にまだバックアップがありません。</sys:String>
  <sys:String x:Key="RestoreSubtitleOne">{0} の下にバックアップが 1 件。</sys:String>
  <sys:String x:Key="RestoreSubtitleMany">{1} の下にバックアップが {0} 件。</sys:String>

  <!-- カスタム宝石セット編集：ラベルのプレースホルダ -->
  <sys:String x:Key="GemSetsLabelPlaceholder">ラベル</sys:String>

  <!-- アイコン抽出の進捗ダイアログ (ツール → ゲームデータからアイコンを抽出) -->
  <sys:String x:Key="IconExtractTitle">ゲームデータからアイコンを抽出</sys:String>
  <sys:String x:Key="IconExtractHeader">ゲームデータからアイテムアイコンを抽出中…</sys:String>
  <sys:String x:Key="IconExtractInitializing">初期化中…</sys:String>
  <sys:String x:Key="IconExtractCancel">キャンセル</sys:String>
  <sys:String x:Key="IconExtractClose">閉じる</sys:String>
  <sys:String x:Key="IconExtractCancelling">キャンセル中…</sys:String>
  <sys:String x:Key="IconExtractNoArgs">抽出引数なしでダイアログが開かれました。</sys:String>
  <sys:String x:Key="IconExtractProgress">処理済み {0:N0} / {1:N0} • 書き込み：{2:N0} • 失敗：{3:N0}</sys:String>
  <sys:String x:Key="IconExtractFailedHeader">抽出に失敗</sys:String>
  <sys:String x:Key="IconExtractCancelledHeader">抽出をキャンセルしました</sys:String>
  <sys:String x:Key="IconExtractCancelledBody">キャッシュは完全には作成されませんでした。もう一度実行すると再開できます;書き込み済みのアイコンは保持されます。</sys:String>
  <sys:String x:Key="IconExtractCompleteHeader">抽出完了</sys:String>
  <sys:String x:Key="IconExtractCompleteBody" xml:space="preserve">{1:N0} 個中 {0:N0} 個のアイコンを書き込みました。&#10;スキップ — キャッシュ済み：{2:N0}、アイコン項目なし：{3:N0}、名前未解決：{4:N0}、DDS なし：{5:N0}。&#10;失敗：{6:N0}。</sys:String>

  <!-- ダイアログ見出し/件数ステータス（読み込み時に設定;元は複数行の三項式） -->
  <sys:String x:Key="FactionNoNodes">勢力拠点が見つかりません — このセーブに FactionSaveData._factionNodeElementSaveDataList がありません（または名前解決用のゲームインストールが未設定）。</sys:String>
  <sys:String x:Key="FactionNodeHeaderStatus">勢力拠点 {0:N0} 件。絞り込み/行をチェックし、対象の状態を選んで「選択を設定」を押します。「すべて発見」は未発見/発見済みの全拠点をアクティブにします。</sys:String>
  <sys:String x:Key="KnowledgeNotLoaded">knowledgeinfo.pabgb が未ロード（ゲームインストール未設定）。</sys:String>
  <sys:String x:Key="KnowledgeHeaderStatus">知識エントリ {0:N0} 件 · 習得済み {1:N0} 件。カテゴリ選択または検索し、行をチェックして「選択を習得」を押します。</sys:String>
  <sys:String x:Key="BuybackHeaderStatus">{1} 店舗で売却アイテム {0} 件。</sys:String>
  <sys:String x:Key="BuybackCountAll">売却アイテム {0} 件。</sys:String>
  <sys:String x:Key="BuybackCountFiltered">{1} 件中 {0} 件の売却アイテムが一致。</sys:String>
  <sys:String x:Key="JournalCatVendorBuyback">店買い戻し</sys:String>
  <sys:String x:Key="JournalBuybackRemoved">{2} の買い戻しから {0} ×{1} を削除</sys:String>
  <sys:String x:Key="BuybackRemoveDone">{2} の買い戻しから {0} ×{1} を削除しました。</sys:String>
  <sys:String x:Key="SocketHeaderStatus">{1} 個のアイテムで {0} スロット（{2} 個充填済み）。</sys:String>
  <sys:String x:Key="SocketGemSetsRefreshed">カスタム宝石セットを更新 — 「セット適用」ドロップダウンで {0} セット利用可能。</sys:String>

</ResourceDictionary>

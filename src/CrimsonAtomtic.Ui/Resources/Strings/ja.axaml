  <!-- ワールドマップダイアログ（ツールメニュー） -->
  <sys:String x:Key="MenuWorldMap">ワールドマップ(_W)…</sys:String>
  <sys:String x:Key="WorldMapWindowTitle">ワールドマップ</sys:String>
  <sys:String x:Key="WorldMapPickMap">マップを選択…</sys:String>
  <sys:String x:Key="WorldMapPickMapTip">ワールドマップの背景に使う画像ファイルを選びます。画像は正方形キャンバスに強制ストレッチされ、マーカー位置は Crimson Desert の標準ワールドマップ基準で計算されるため、画像の解像度・縦横比は影響しません。</sys:String>
  <sys:String x:Key="WorldMapPickMapTitle">ワールドマップ画像を選択</sys:String>
  <sys:String x:Key="WorldMapFilterLabel">絞り込み：</sys:String>
  <sys:String x:Key="WorldMapFilterTip">オブジェクト名の部分一致で絞り込みます。空欄＝座標を持つ全オブジェクトを表示。</sys:String>
  <sys:String x:Key="WorldMapObjectPickerTip">マップ上に位置をピン表示するオブジェクト（アクティブキャラ / 傭兵 / ギミック）を選びます。</sys:String>
  <sys:String x:Key="WorldMapClose">閉じる</sys:String>
  <sys:String x:Key="WorldMapNoSaveTitle">セーブが読み込まれていません</sys:String>
  <sys:String x:Key="WorldMapNoSaveBody">先に File → Open Save でセーブを開いてからワールドマップを開いてください。</sys:String>

  <!-- ========================================================================
       VM で UiText.Get/Format により生成するステータス/確認/journal 文字列
       (Tools メニューのダイアログフロー)。複数行の確認文は &#10; + xml:space="preserve"。
       ======================================================================== -->

  <!-- Journal (変更サマリー) カテゴリラベル (区塊カラム) -->
  <sys:String x:Key="JournalCatMarkChallenge">チャレンジ完了</sys:String>
  <sys:String x:Key="JournalCatFieldEdit">フィールド編集</sys:String>
  <sys:String x:Key="JournalCatBulkFill">一括フィル</sys:String>
  <sys:String x:Key="JournalCatRemoveElement">要素削除</sys:String>
  <sys:String x:Key="JournalCatAbyssGates">アビスゲート</sys:String>
  <sys:String x:Key="JournalCatKnowledge">知識</sys:String>
  <sys:String x:Key="JournalCatFactionNodes">勢力拠点</sys:String>
  <sys:String x:Key="JournalCatAddItem">アイテム追加</sys:String>
  <sys:String x:Key="JournalCatMountUnlock">マウント解放</sys:String>

  <!-- 単一/一括チャレンジ完了 (Pattern B v1) -->
  <sys:String x:Key="MarkApplying">Pattern B v1 を適用中（FAR トラッカー + X_2 サブミッション）…</sys:String>
  <sys:String x:Key="MarkFailedReadFar">マーク失敗（FAR トラッカーを再読み込みできません）：{0}</sys:String>
  <sys:String x:Key="MarkFailedNoKey">マーク失敗：FAR トラッカーに _key フィールドがありません — レシピを続行できません。</sys:String>
  <sys:String x:Key="JournalMarkOne">チャレンジ {0}（{1}）を完了としてマーク（Pattern B v1）</sys:String>
  <sys:String x:Key="MarkDoneExisting">{0}（{1}）を Pattern B v1 で完了としてマーク — FAR トラッカー idx {2} を反転（X_2 サブミッションは既存）。</sys:String>
  <sys:String x:Key="MarkDoneNew">{0}（{1}）を Pattern B v1 で完了としてマーク — FAR トラッカー idx {2} を反転、X_2 サブミッション項目を idx {3} に作成。</sys:String>
  <sys:String x:Key="MarkFailedGeneric">マーク失敗：{0}。セーブ状態は部分的かもしれません — 書き込まずに再読み込みすると元に戻せます。</sys:String>
  <sys:String x:Key="BulkMarkProgress">Pattern B v1 を適用中：{0} / {1}…</sys:String>
  <sys:String x:Key="BulkMarkProgressKey">Pattern B v1 を適用中：{0} / {1} — チャレンジ 0x{2}</sys:String>
  <sys:String x:Key="JournalBulkMark">封印アビス遺物チャレンジ {0} 件を一括完了（Pattern B v1）</sys:String>
  <sys:String x:Key="BulkMarkDone">完了：対象の封印アビス遺物チャレンジ {1} 件中 {0} 件を Pattern B v1 で一括完了しました。</sys:String>
  <sys:String x:Key="BulkMarkFailed">一括マークがチャレンジ {0} で失敗（{1}/{2} 適用後）：{3}。セーブ状態は部分適用です — 書き込まずに再読み込みすると元に戻せます。</sys:String>
  <sys:String x:Key="JournalBulkMarkPartial">封印アビス遺物チャレンジ {0} 件を一括完了（Pattern B v1、部分 — {1} で失敗）</sys:String>

  <!-- フィールド編集 journal -->
  <sys:String x:Key="JournalFieldEditAbsentWord">なし</sys:String>
  <sys:String x:Key="JournalFieldEdit">{0}.{1}：{2} → {3} &lt;{4}&gt;</sys:String>
  <sys:String x:Key="JournalFieldMadeAbsent">{0}.{1}：なしに設定</sys:String>

  <!-- スタックフィル (単一コンテナ + 全所持品) -->
  <sys:String x:Key="FillNothing">フィルするものがありません — 既に目標値、または max_stack データなし。</sys:String>
  <sys:String x:Key="FillConfirmTitle">スタックをフィルしますか？</sys:String>
  <sys:String x:Key="FillConfirmBody" xml:space="preserve">このコンテナ内の {0} 個のアイテムの _stackCount をフィルしますか？&#10;&#10;max_stack_count &gt; 100 のアイテムは最大までフィル（上限 9,999,999 — 通貨など大上限のアイテムはそこで止まり、既にそれより多いスタックはそのまま）。&#10;max_stack_count ≤ 100 のアイテムは次の満杯スタックに切り上げ（例：数量 120、上限 50 → 150）。既にスタック境界のアイテムはスキップ。&#10;&#10;ヒント：単一アイテムの「スタックをフィル」ボタンは上限なしで真の最大までフィルします。&#10;&#10;書き込まずに再読み込みすると元に戻せます。</sys:String>
  <sys:String x:Key="FillCancelled">フィルをキャンセルしました。</sys:String>
  <sys:String x:Key="FillProgress">{0} 個のスタックをフィル中…</sys:String>
  <sys:String x:Key="JournalFillOne">{0} のスタックをフィルしました</sys:String>
  <sys:String x:Key="JournalFillMany">{1} の {0} 個のスタックをフィルしました</sys:String>
  <sys:String x:Key="FillDone">{0} 個のスタックをフィルしました。</sys:String>
  <sys:String x:Key="FillFailed">{0}/{1} 後に失敗：{2}</sys:String>
  <sys:String x:Key="ScanningInventories">所持品をスキャン中…</sys:String>
  <sys:String x:Key="FillAllNothing">フィルするものがありません — {0} 個のコンテナの全スタックが既に目標値です。</sys:String>
  <sys:String x:Key="FillAllConfirmTitle">すべての所持品の全スタックをフィルしますか？</sys:String>
  <sys:String x:Key="FillAllConfirmBody" xml:space="preserve">{1} 個のコンテナ（すべての InventorySaveData ブロック）の {0} 個のアイテムの _stackCount を最大までフィルしますか？&#10;&#10;max_stack_count &gt; 100 のアイテムは最大までフィル（上限 9,999,999 — 通貨など大上限のアイテムはそこで止まり、既にそれより多いスタックはそのまま）。&#10;max_stack_count ≤ 100 のアイテムは次の満杯スタックに切り上げ（例：数量 120、上限 50 → 150）。既にスタック境界のアイテムはスキップ。&#10;&#10;ヒント：単一アイテムの「スタックをフィル」ボタンは上限なしで真の最大までフィルします。&#10;&#10;書き込まずに再読み込みすると元に戻せます。</sys:String>
  <sys:String x:Key="FillAllProgress">{1} 個のコンテナの {0} 個のスタックをフィル中…</sys:String>
  <sys:String x:Key="JournalFillAll">{1} 個のコンテナ（全所持品）で {0} 個のスタックをフィルしました</sys:String>
  <sys:String x:Key="FillAllDone">{1} 個のコンテナで {0} 個のスタックをフィルしました。</sys:String>

  <!-- 要素削除 -->
  <sys:String x:Key="RemoveConfirmTitle">要素を削除しますか？</sys:String>
  <sys:String x:Key="RemoveConfirmBody" xml:space="preserve">この要素をリストから削除しますか？&#10;&#10;要素：[{0}] {1}&#10;リストサイズ：{2} → {3}&#10;&#10;書き込まずに再読み込みすると元に戻せます。</sys:String>
  <sys:String x:Key="RemoveCancelled">削除をキャンセルしました。</sys:String>
  <sys:String x:Key="RemoveProgress">要素を削除中…</sys:String>
  <sys:String x:Key="JournalRemove">{1} から {0} を削除（インデックス [{2}]）</sys:String>
  <sys:String x:Key="RemoveDone">要素 [{0}] を削除しました。</sys:String>
  <sys:String x:Key="RemoveFailed">削除に失敗：{0}</sys:String>

  <!-- すべてのアビスゲートを解放 (マップ発見) + 知識注入 -->
  <sys:String x:Key="AbyssNoKnowledgeInfo">処理対象なし — knowledgeinfo.pabgb が未ロード（ゲームインストール未設定）。</sys:String>
  <sys:String x:Key="AbyssNoEntries">処理対象なし — knowledgeinfo.pabgb にアビスゲート知識エントリが見つかりません。</sys:String>
  <sys:String x:Key="AbyssAllDiscovered">処理対象なし — {0} 件のアビスゲート知識エントリはすべて発見済みです。</sys:String>
  <sys:String x:Key="AbyssConfirmTitle">すべてのアビスゲートを解放しますか（マップ発見）？</sys:String>
  <sys:String x:Key="AbyssConfirmBody" xml:space="preserve">{0} 件のアビスゲート知識キーを {1}._list に注入しますか？&#10;&#10;knowledgeinfo.pabgb から {2} 件の一致キーを収集（{3} 個の名前プレフィックス）。&#10;{4} 件は既にセーブに存在 — そのまま。&#10;{0} 件を追加します。&#10;&#10;これは **発見フラグ** のレイヤーのみ — これでアビスゲートがマップに表示されます。実際にゲートを通行可能にするには、ツール → アビスゲートを編集… でゲートごとの状態を変更してください。&#10;&#10;書き込まずに再読み込みすると元に戻せます。</sys:String>
  <sys:String x:Key="KnowledgeInjecting">{0} 件の知識キーを注入中…</sys:String>
  <sys:String x:Key="JournalAbyssAdded">{0} 件のアビスゲート知識キーを {1}._list に一括追加（マップ発見）</sys:String>
  <sys:String x:Key="AbyssDone">完了：{0} 件のアビスゲート知識キーを追加（{2}._list 内で計 {1} 件）。</sys:String>
  <sys:String x:Key="JournalAbyssAddedPartial">{0}/{1} 件のアビスゲート知識キーを一括追加、キー 0x{2} の前で失敗</sys:String>
  <sys:String x:Key="KnowledgeInjectFailed">{0}/{1} 後に失敗：{2}（コード {3}）。{4}</sys:String>
  <sys:String x:Key="KnowledgeInjectFailedPartial">部分的な進行を元に戻すには、書き込まずに再読み込みしてください。</sys:String>
  <sys:String x:Key="KnowledgeInjectFailedNone">変更は書き込まれていません。</sys:String>


  <sys:String x:Key="ItemFlagLabelIsEditableGrime">汚れ編集可</sys:String>
  <sys:String x:Key="ItemFlagTipIsEditableGrime">編集可能な汚れ / 摩耗オーバーレイあり</sys:String>

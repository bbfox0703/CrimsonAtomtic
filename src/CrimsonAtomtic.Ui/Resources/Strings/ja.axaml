  <!-- Field detail pane -->
  <sys:String x:Key="FieldsHeader">Block フィールド</sys:String>
  <sys:String x:Key="FieldsHint">上で block を選択して、そのフィールドを確認してください。</sys:String>
  <sys:String x:Key="FieldsColIndex">#</sys:String>
  <sys:String x:Key="FieldsColName">フィールド</sys:String>
  <sys:String x:Key="FieldsColType">型</sys:String>
  <sys:String x:Key="FieldsColKind">Kind</sys:String>
  <sys:String x:Key="FieldsColPresent">Present</sys:String>
  <sys:String x:Key="FieldsColValue">値</sys:String>
  <sys:String x:Key="FieldsColResolvedName">名前</sys:String>
  <sys:String x:Key="FieldsColRange">Bytes</sys:String>
  <sys:String x:Key="FieldsMask">Mask</sys:String>
  <sys:String x:Key="FieldsTrailingPad">Trailing pad</sys:String>
  <sys:String x:Key="FieldsUndecoded">Undecoded</sys:String>
  <sys:String x:Key="FieldsLoading">読み込み中…</sys:String>
  <sys:String x:Key="FieldsError">block の詳細を読み込めませんでした。</sys:String>

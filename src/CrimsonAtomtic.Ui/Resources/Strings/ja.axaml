  <sys:String x:Key="FindItemsFlagNewMarkTip">_isNewMark = true (ゲーム内の「NEW」バッジが付いています)</sys:String>
  <sys:String x:Key="FindItemsRefresh">更新</sys:String>

  <!-- 詳細ペインのラベル — vendor 2b1307a の crimson_iteminfo_lookup_summary
       経由で iteminfo.pabgb の静的メタデータを表示する。 -->
  <sys:String x:Key="FindItemsDetailPaneTitle">アイテム詳細</sys:String>
  <sys:String x:Key="FindItemsDetailPaneEmpty">左側の行を選択すると、iteminfo のフラグと静的メタデータが表示されます。</sys:String>
  <sys:String x:Key="FindItemsDetailNoSummary">このアイテムキーは iteminfo.pabgb に存在しません — おそらく開発用 / 内容が外されたエントリです。セーブ側のフィールド (Locked / NewMark) は左の表に残っています。</sys:String>
  <sys:String x:Key="FindItemsDetailSectionFlags">静的フラグ</sys:String>
  <sys:String x:Key="FindItemsDetailFlagsEmpty">静的フラグは設定されていません。</sys:String>
  <sys:String x:Key="FindItemsDetailSectionScalars">静的メタデータ</sys:String>
  <sys:String x:Key="FindItemsDetailItemType">アイテム種別</sys:String>
  <sys:String x:Key="FindItemsDetailItemTier">ティア</sys:String>
  <sys:String x:Key="FindItemsDetailEquipableLevel">装備可能レベル</sys:String>
  <sys:String x:Key="FindItemsDetailMaxEndurance">最大耐久値</sys:String>
  <sys:String x:Key="FindItemsDetailMaxStack">最大スタック</sys:String>
  <sys:String x:Key="FindItemsDetailCooltime">クールダウン</sys:String>
  <sys:String x:Key="FindItemsDetailRespawnTime">リスポーン (秒)</sys:String>
  <sys:String x:Key="FindItemsDetailCategoryInfo">カテゴリ</sys:String>

  <!-- iteminfo 静的フラグのラベル + ツールチップ。ビット位置は

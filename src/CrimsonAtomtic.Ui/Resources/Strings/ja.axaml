       CRIMSON_ITEMINFO_FLAG_* を参照。 -->
  <sys:String x:Key="ItemFlagLabelIsBlocked">ブロック</sys:String>
  <sys:String x:Key="ItemFlagTipIsBlocked">開発用 / 未使用エントリ</sys:String>
  <sys:String x:Key="ItemFlagLabelIsDyeable">染色可能</sys:String>
  <sys:String x:Key="ItemFlagTipIsDyeable">少なくとも 1 つの染色スロットがある</sys:String>
  <sys:String x:Key="ItemFlagLabelIsDestroyWhenBroken">破損時に消去</sys:String>

<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

  <!--
    Japanese (ja) translations.
    en.axaml is the source of truth — sync new keys here when en.axaml
    gains entries. Technical identifiers (save-file field names with
    leading underscores, schema class names, file paths, hex constants,
    build-identifier terms like Pattern B v1 / FAR tracker / PALOC /
    HMAC / iteminfo) are intentionally preserved verbatim — these are
    debug/forensic surfaces that need to be greppable across English
    docs and source code.
  -->

  <!-- Language marker — see en.axaml for rationale. Don't remove. -->
  <sys:String x:Key="__UiLangCode__">ja</sys:String>

  <!-- Window / chrome -->
  <sys:String x:Key="WindowTitle">CrimsonAtomtic</sys:String>

  <!-- Menu -->
  <sys:String x:Key="MenuFile">ファイル(_F)</sys:String>
  <sys:String x:Key="MenuOpenSave">セーブを開く(_O)…</sys:String>
  <sys:String x:Key="MenuSave">保存(_S)</sys:String>
  <sys:String x:Key="MenuSaveAs">名前を付けて保存(_A)…</sys:String>
  <sys:String x:Key="MenuExit">終了(_X)</sys:String>
  <sys:String x:Key="MenuTools">ツール(_T)</sys:String>
  <sys:String x:Key="MenuBrowseLocalization">ローカライズ文字列を参照(_B)…</sys:String>
  <sys:String x:Key="MenuBrowseItems">アイテム一覧(_I)…</sys:String>
  <sys:String x:Key="MenuExtractIcons">ゲームデータからアイコンを抽出(_E)…</sys:String>
  <sys:String x:Key="MenuSetGameInstallFolder">ゲームインストールフォルダを設定(_G)…</sys:String>
  <sys:String x:Key="SetGameInstallFolderInvalidTitle">このフォルダは紅の砂漠 / Crimson Desert のインストール先には見えません</sys:String>
  <sys:String x:Key="SetGameInstallFolderInvalidBody">選択したフォルダに必要なアセットファイル (0020\0.pamt) が見つかりません。ゲームの 0000\、0020\、… の各 pack group を含むディレクトリを選んでください — 通常は &lt;Steam library&gt;\steamapps\common\Crimson Desert、または Epic / Game Pass 用にコピーしたアセットフォルダです。</sys:String>
  <sys:String x:Key="MenuRenameMercenary">傭兵の名前を変更(_M)…</sys:String>
  <sys:String x:Key="MenuEditItemSockets">アイテムのソケットを編集(_S)…</sys:String>
  <sys:String x:Key="SocketEditorHeader">スロット単位で Fill / Change / Clear します。Fill と Change の際は耐久値 (Endurance) を 65535 (最大) にリセットするので、新しい上位ジェムが古いスロットの消耗値を引き継ぎません。アイテムの現在の上限を超える index にジェムを入れると _validSocketCount が自動的に引き上げられます (ゲーム内でスロットが見えるようになります)。基底の list が事前確保しているスロット (通常 5 まで) は、ゲームデータ上の上限に関わらず埋められます。変更内容は次回の File → Save で書き込まれます。</sys:String>
  <sys:String x:Key="SocketEditorColBag">バッグ</sys:String>
  <sys:String x:Key="SocketEditorColItem">アイテム</sys:String>
  <sys:String x:Key="SocketEditorColItemKey">ItemKey</sys:String>
  <sys:String x:Key="SocketEditorColSocket">スロット</sys:String>
  <sys:String x:Key="SocketEditorColCurrentGem">現在のジェム</sys:String>
  <sys:String x:Key="SocketEditorColCurrentGemKey">GemKey</sys:String>
  <sys:String x:Key="SocketEditorColAction">操作</sys:String>
  <sys:String x:Key="SocketEditorColApplied">ステータス</sys:String>
  <sys:String x:Key="SocketEditorChangeGem">変更…</sys:String>
  <sys:String x:Key="SocketEditorFillGem">セット…</sys:String>
  <sys:String x:Key="SocketEditorClearGem">クリア</sys:String>
  <sys:String x:Key="SocketEditorChangeGemTip">ジェム選択ダイアログを開き、このスロットを上書きします。_currentEndurance を 65535 (最大) にリセットするので、上位ジェムは満タンから始まります。</sys:String>
  <sys:String x:Key="SocketEditorFillGemTip">ジェム選択ダイアログを開き、この空きスロットを埋めます。必要に応じて親アイテムの _validSocketCount を自動的に引き上げ、ゲーム内でスロットを可視化します。</sys:String>
  <sys:String x:Key="SocketEditorClearGemTip">このソケットを空に戻します。_currentEndurance と _itemKey の両方が absent になり、mask は [0x00] に反転します。</sys:String>
  <sys:String x:Key="SocketEditorColState">状態</sys:String>
  <sys:String x:Key="SocketEditorApplySetItemLabel">適用先：</sys:String>
  <sys:String x:Key="SocketEditorApplySetSetLabel">セット：</sys:String>
  <sys:String x:Key="SocketEditorApplySetApply">適用</sys:String>
  <sys:String x:Key="SocketEditorApplySetEditCustom">カスタムセットを編集…</sys:String>
  <sys:String x:Key="SocketEditorApplySetEditCustomTip">3 つのユーザーカスタムジェムセットを定義 / リネームします。settings.json に保存されます。</sys:String>
  <sys:String x:Key="SocketEditorFilterLabel">フィルター：</sys:String>
  <sys:String x:Key="SocketEditorFilterWatermark">入力で絞り込み — アイテム名 / バッグ / item key は 5 スロット全てを表示。ジェム名 / gem key は一致するスロットだけに絞り込み…</sys:String>

  <!-- Custom gem sets editor (launched from Sockets editor toolbar) -->
  <sys:String x:Key="CustomGemSetsWindowTitle">カスタムジェムセットを編集</sys:String>
  <sys:String x:Key="CustomGemSetsHeader">ソケットエディタの Apply-Set ツールバーに、組み込みの 3 つと並んで表示される 3 つのユーザー定義ジェムセットです。各セットはラベル + 最大 5 個の ItemKey エントリ (空欄はスキップ) を持ちます。N 個のエントリを持つセットを適用すると、対象アイテムのスロット 0..N-1 が上書きされ、[N..max] は変更されません。クリックで settings.json に保存されます。</sys:String>
  <sys:String x:Key="CustomGemSetsSave">保存</sys:String>
  <sys:String x:Key="CustomGemSetsClose">閉じる</sys:String>
  <sys:String x:Key="SocketEditorClose">閉じる</sys:String>
  <sys:String x:Key="SocketEditorNotAvailableTitle">このセーブには埋まったソケットがありません</sys:String>
  <sys:String x:Key="SocketEditorNotAvailableBody">読み込まれたセーブに、ジェムが入ったソケットを持つアイテムがありません (または _socketSaveDataList を持つアイテムが一つもありません)。ゲーム内でジェムを装着すると、ここに表示されます。</sys:String>
  <sys:String x:Key="SocketEditorPickerTitle">ジェムを選択</sys:String>
  <sys:String x:Key="RenameMercenaryHeader">傭兵 / ペットの名前を変更します。「名前」列には CharacterKey から解決されたキャラクター / テンプレート名が表示されます (メインウィンドウの mercenaryDataList の Name 列と同じソース) — 各行を識別するために使用してください。あなたのカスタム名 (_mercenaryName に保存済み) は表示されません — read-side FFI は未実装です。新しい名前を入力し、行ごとに Apply をクリックしてください。変更内容は次回の File → Save で書き込まれます。</sys:String>
  <sys:String x:Key="RenameMercenaryColIdx">インデックス</sys:String>
  <sys:String x:Key="RenameMercenaryColMercNo">MercNo</sys:String>
  <sys:String x:Key="RenameMercenaryColCharKey">CharKey</sys:String>
  <sys:String x:Key="RenameMercenaryColPortrait">ポートレート</sys:String>
  <sys:String x:Key="RenameMercenaryColCharName">名前</sys:String>
  <sys:String x:Key="RenameMercenaryColType">種類</sys:String>
  <sys:String x:Key="RenameMercenaryColEquip">装備</sys:String>
  <sys:String x:Key="RenameMercenaryColNewName">新しい名前 (UTF-8)</sys:String>
  <sys:String x:Key="RenameMercenaryColApply">操作</sys:String>
  <sys:String x:Key="RenameMercenaryColApplied">適用済み</sys:String>
  <sys:String x:Key="RenameMercenaryApply">適用</sys:String>
  <sys:String x:Key="RenameMercenaryClose">閉じる</sys:String>
  <sys:String x:Key="RenameMercenaryNewNameWatermark">新しい名前を入力…</sys:String>
  <sys:String x:Key="RenameMercenaryNotAvailableTitle">名前を変更できる傭兵がいません</sys:String>
  <sys:String x:Key="RenameMercenaryNotAvailableBody">読み込まれたセーブに MercenaryClanSaveData block がないか、その _mercenaryDataList が空 / 読み込み不能です。ゲーム内で 1 体以上の傭兵を雇用すると、ここに傭兵リストが表示されます。</sys:String>
  <sys:String x:Key="MenuFillAllStacks">全インベントリのスタックを最大まで満たす(_A)…</sys:String>
  <sys:String x:Key="MenuUnlockAllAbyssGates">全てのアビスゲートをアンロック (マップ発見)(_U)…</sys:String>
  <sys:String x:Key="MenuBulkCompleteHeldSAChallenges">所持中で現在処理可能な封印アビス遺物チャレンジを全てクリア(_C)…</sys:String>
  <sys:String x:Key="MenuEditAbyssGates">アビスゲートを編集 (個別にロック/アンロック)(_E)…</sys:String>
  <sys:String x:Key="MenuUnlockMounts">騎乗をアンロック (シジル + ドラゴン)(_U)…</sys:String>
  <sys:String x:Key="MenuEditKnowledge">ナレッジを編集 (カテゴリ別に習得)(_K)…</sys:String>
  <sys:String x:Key="MenuEditItemDyes">アイテムの染色を編集(_D)…</sys:String>
  <sys:String x:Key="MenuVendorBuyback">商人の買い戻しリスト(_V)…</sys:String>
  <sys:String x:Key="MenuReviewChanges">未保存の変更を確認(_R)…</sys:String>

  <!-- Vendor Buyback dialog (Tools menu) -->
  <sys:String x:Key="VendorBuybackWindowTitle">商人の買い戻し</sys:String>
  <sys:String x:Key="VendorBuybackHeader">プレイヤーが商人に売却したアイテムを表示 + 削除します。各行は StoreDataSaveData._storeSoldItemDataList の要素 1 つに対応します。Remove ボタンはその商人の買い戻しキューからエントリを削除し (スロットを解放)、同じ商人の後続要素は自動的に 1 つ下にシフトします。「インベントリに戻す」機能は今後の予定です。変更内容は次回の File → Save で書き込まれます。</sys:String>
  <sys:String x:Key="VendorBuybackFilterLabel">フィルター：</sys:String>
  <sys:String x:Key="VendorBuybackFilterWatermark">入力で絞り込み — 商人名 / store key はその商人の全売却アイテムを表示。アイテム名 / item key は行単位で絞り込み…</sys:String>
  <sys:String x:Key="VendorBuybackColStore">商人</sys:String>
  <sys:String x:Key="VendorBuybackColStoreKey">StoreKey</sys:String>
  <sys:String x:Key="VendorBuybackColItem">アイテム</sys:String>
  <sys:String x:Key="VendorBuybackColItemKey">ItemKey</sys:String>
  <sys:String x:Key="VendorBuybackColStack">スタック</sys:String>
  <sys:String x:Key="VendorBuybackColEndurance">耐久</sys:String>
  <sys:String x:Key="VendorBuybackColSoldAt">売却時刻 (ticks)</sys:String>
  <sys:String x:Key="VendorBuybackColAction">操作</sys:String>
  <sys:String x:Key="VendorBuybackColStatus">ステータス</sys:String>
  <sys:String x:Key="VendorBuybackRemove">削除</sys:String>
  <sys:String x:Key="VendorBuybackRemoveTip">この商人の買い戻しキューから本エントリを削除します。スロットが空くと他のアイテムが流れ込めるようになります。セッション中は取り消し不可。元に戻すにはセーブを書き込まずに再読み込みしてください。</sys:String>
  <sys:String x:Key="VendorBuybackJump">ジャンプ…</sys:String>
  <sys:String x:Key="VendorBuybackJumpTip">このダイアログを閉じ、メインエディタの block ツリーで対象アイテムを開きます。そこからは通常の per-field エディタでスタック数、耐久、ソケット、染色などをインベントリアイテムと同じ感覚で編集できます。</sys:String>
  <sys:String x:Key="VendorBuybackClose">閉じる</sys:String>
  <sys:String x:Key="VendorBuybackNotAvailableTitle">商人の買い戻しエントリがありません</sys:String>
  <sys:String x:Key="VendorBuybackNotAvailableBody">読み込まれたセーブに、非空の _storeSoldItemDataList を持つ StoreDataSaveData がありません。ゲーム内で商人にアイテムを売却し、買い戻しキューを作成してください。</sys:String>

  <!-- Change summary dialog (review pending edits + close-on-dirty confirm) -->
  <sys:String x:Key="ChangeSummaryWindowTitle">未保存の変更</sys:String>
  <sys:String x:Key="ChangeSummaryHeaderClose">未保存の変更があります — 終了前に保存しますか？</sys:String>
  <sys:String x:Key="ChangeSummarySubHeaderClose">下記の編集はまだディスクに書き込まれていません。「保存」で書き込んで終了、「破棄して終了」で保存せず終了 (ディスク上の旧状態は維持)、「キャンセル」で編集を続行します。</sys:String>
  <sys:String x:Key="ChangeSummaryHeaderReview">前回保存からの変更</sys:String>
  <sys:String x:Key="ChangeSummarySubHeaderReview">セーブを読み込んで以降 (または前回の File → Save 以降) に UI から適用された編集の読み取り専用リストです。再読み込みで全変更を破棄、File → Save で書き込みます。</sys:String>
  <sys:String x:Key="ChangeSummaryColTime">時刻</sys:String>
  <sys:String x:Key="ChangeSummaryColCategory">領域</sys:String>
  <sys:String x:Key="ChangeSummaryColSummary">変更</sys:String>
  <sys:String x:Key="ChangeSummarySave">保存</sys:String>
  <sys:String x:Key="ChangeSummaryDiscard">破棄</sys:String>
  <sys:String x:Key="ChangeSummaryDiscardExit">破棄して終了</sys:String>
  <sys:String x:Key="ChangeSummaryCancel">キャンセル</sys:String>
  <sys:String x:Key="ChangeSummaryNoChangesTitle">未保存の変更はありません</sys:String>
  <sys:String x:Key="ChangeSummaryNoChangesBody">セーブを読み込んで以降 (または前回の File → Save 以降)、編集は行われていません。</sys:String>

  <!-- Dye editor master dialog -->
  <sys:String x:Key="DyeEditorWindowTitle">アイテムの染色を編集</sys:String>
  <sys:String x:Key="DyeEditorHeader">アイテム単位で染色を編集します。_itemDyeDataList を持つアイテム (Edit)、および染色をサポートする装備中アイテムで未染色のもの (+ Add) を一覧表示します。Edit で各スロットの R/G/B/A + グライム + マテリアル + カラーグループを変更、+ Add で有効なスロットを選んでデフォルト空の染色要素を生成して後で Edit から色付けできます。</sys:String>
  <sys:String x:Key="DyeEditorSearchPlaceholder">アイテム名、バッグ、ItemKey で絞り込み…</sys:String>
  <sys:String x:Key="DyeEditorColIcon">アイコン</sys:String>
  <sys:String x:Key="DyeEditorColBag">バッグ</sys:String>
  <sys:String x:Key="DyeEditorColItem">アイテム</sys:String>
  <sys:String x:Key="DyeEditorColItemKey">ItemKey</sys:String>
  <sys:String x:Key="DyeEditorColSlotCount">スロット数</sys:String>
  <sys:String x:Key="DyeEditorColAction">操作</sys:String>
  <sys:String x:Key="DyeEditorEdit">編集…</sys:String>
  <sys:String x:Key="DyeEditorEditTip">このアイテムの染色リストに対するスロット単位のエディタを開きます。Apply 後もダイアログは開いたままなので、複数スロットを連続で編集できます。</sys:String>
  <sys:String x:Key="DyeEditorAdd">+ 追加</sys:String>
  <sys:String x:Key="DyeEditorAddTip">このアイテムに対する有効な染色スロットを選び、デフォルト空の染色要素を生成します。生成後は Edit をクリックして色を設定してください。</sys:String>
  <sys:String x:Key="DyeEditorAddPickSlotTitle">染色スロットを選択</sys:String>
  <sys:String x:Key="DyeEditorAddPickSlotHeader">このアイテムに生成する染色スロットを選んでください。下の一覧は partprefabdyeslotinfo から解決されたこのアイテムのスロット一覧で、各ラベルはそのスロットのデフォルトマテリアル名です。</sys:String>
  <sys:String x:Key="DyeEditorAddNoTemplateTitle">このセーブに染色テンプレートがありません</sys:String>
  <sys:String x:Key="DyeEditorAddNoTemplateBody">トグル ABI は、要素 schema をコピーするために少なくとも 1 つの染色済みアイテムをセーブ内に必要とします。ゲーム内でまずアイテムを 1 つ染色 (任意の衣装 / 防具) してセーブし、ここで再読込してから再度お試しください。</sys:String>
  <sys:String x:Key="DyeEditorAddFailedTitle">染色を追加できませんでした</sys:String>
  <sys:String x:Key="DyeEditorClose">閉じる</sys:String>
  <sys:String x:Key="DyeEditorNotAvailableTitle">このセーブには染色済みアイテムがありません</sys:String>
  <sys:String x:Key="DyeEditorNotAvailableBody">_itemDyeDataList を少なくとも 1 スロット保持するアイテムがありません。プレイヤーがまだ何も染色していないか、または本セーブの schema が _itemDyeDataList を別のフィールド名で保持しています (vendor/crimson-rs/_probe_item_dye_data を再実行して確認してください)。</sys:String>

  <!-- Dye slot editor child dialog -->
  <sys:String x:Key="DyeSlotEditorWindowTitle">染色スロットを編集</sys:String>
  <sys:String x:Key="DyeSlotColSlot">スロット</sys:String>
  <sys:String x:Key="DyeSlotColColor">色</sys:String>
  <sys:String x:Key="DyeSlotColGrime">グライム</sys:String>
  <sys:String x:Key="DyeSlotColMaterial">マテリアル</sys:String>
  <sys:String x:Key="DyeSlotColColorGroup">カラーグループ</sys:String>
  <sys:String x:Key="DyeSlotColAction">操作</sys:String>
  <sys:String x:Key="DyeSlotColStatus">ステータス</sys:String>
  <sys:String x:Key="DyeSlotPick">色を選択…</sys:String>
  <sys:String x:Key="DyeSlotApply">適用</sys:String>
  <sys:String x:Key="DyeSlotEditorClose">閉じる</sys:String>

  <!-- Dye palette picker modal -->
  <sys:String x:Key="DyePalettePickerWindowTitle">染色を選択</sys:String>
  <sys:String x:Key="DyePalettePickerCancel">キャンセル</sys:String>
  <sys:String x:Key="DyePalettePickerOffGridBanner">現在の色はこのテーマのパレット上にありません (外部ツールで設定された可能性)。いずれかのセルをクリックするとパレット上の色で置き換えられます。</sys:String>
  <sys:String x:Key="AbyssGatesWindowTitle">アビスゲートを編集</sys:String>
  <sys:String x:Key="AbyssGatesHeader">ゲート単位でロック/アンロックを切り替えます。FieldSaveData._fieldGimmickSaveDataList 内の各 FieldGimmickSaveData 要素に対し _initStateNameHash を書き込みます (Default 0x866c7489 ↔ Activated 0xe300acfe)。Idle (情景) と Unknown の行は読み取り専用です — 非ゲート系 gimmick の安定性を損なわないためです。変更内容は次回の File → Save で書き込まれます。</sys:String>
  <sys:String x:Key="AbyssGatesColOwnerLevel">所属レベル</sys:String>
  <sys:String x:Key="AbyssGatesColGimmick">Gimmick</sys:String>
  <sys:String x:Key="AbyssGatesColSaveKey">SaveKey</sys:String>
  <sys:String x:Key="AbyssGatesColState">状態</sys:String>
  <sys:String x:Key="AbyssGatesColStateHash">Hash</sys:String>
  <sys:String x:Key="AbyssGatesColAction">操作</sys:String>
  <sys:String x:Key="AbyssGatesUnlock">アンロック</sys:String>
  <sys:String x:Key="AbyssGatesLock">ロック</sys:String>
  <sys:String x:Key="AbyssGatesUnlockTip">Default (未通過) → Activated (通過済み)。_initStateNameHash を 0xe300acfe に設定します。</sys:String>
  <sys:String x:Key="AbyssGatesLockTip">Activated (通過済み) → Default (未通過)。_initStateNameHash を 0x866c7489 に戻します。</sys:String>
  <sys:String x:Key="AbyssGatesClose">閉じる</sys:String>
  <sys:String x:Key="AbyssGatesNotAvailableTitle">このセーブにアビスゲートがありません</sys:String>
  <sys:String x:Key="AbyssGatesNotAvailableBody">FieldSaveData._fieldGimmickSaveDataList 内に、gimmickinfo.pabgb の abyss / hyperspace 許可リストに一致する FieldGimmickSaveData 要素がありません。セーブに FieldSaveData の root がまだないか (ゲーム序盤)、ゲームインストールパスが未設定で gimmickinfo を読めない可能性があります。</sys:String>

  <!-- 騎乗アンロックダイアログ -->
  <sys:String x:Key="MountUnlockWindowTitle">騎乗をアンロック</sys:String>
  <sys:String x:Key="MountUnlockHeader">シジル騎乗 (クマ、シカ、アイベックス、イボイノシシ、シルバーファング、フェニックス) は「結束のシジル」としてクエストアーティファクトに付与されます。ゲームを起動してシジルを「使用」するとアンロックが完了します (エンジンが召喚と騎乗能力を付与)。ドラゴン (ブラックスター) は直接アンロックされます: 同梱のドナーセーブから実際の騎乗要素を移植し、召喚ナレッジを注入します。次回の「ファイル → 保存」でファイルに書き込まれます。</sys:String>
  <sys:String x:Key="MountUnlockColMount">騎乗</sys:String>
  <sys:String x:Key="MountUnlockColType">種類</sys:String>
  <sys:String x:Key="MountUnlockColMethod">方法</sys:String>
  <sys:String x:Key="MountUnlockColAction">操作</sys:String>
  <sys:String x:Key="MountUnlockAction">アンロック</sys:String>
  <sys:String x:Key="MountUnlockClose">閉じる</sys:String>

  <!-- ナレッジ編集ダイアログ -->
  <sys:String x:Key="KnowledgeWindowTitle">ナレッジを編集</sys:String>
  <sys:String x:Key="KnowledgeHeader">ナレッジ／コーデックスを項目別・カテゴリ別に習得します。カテゴリ選択や検索で絞り込み、習得したい行にチェックを入れて「選択を習得」を押します。「カテゴリを一括習得」は現在の表示にある未習得項目をすべて注入します（地図解放の Node、コーデックスの Collection は警告あり）。次回の「ファイル → 保存」でファイルに書き込まれます。</sys:String>
  <sys:String x:Key="KnowledgeCategory">カテゴリ:</sys:String>
  <sys:String x:Key="KnowledgeSearchHint">名前・キー・カテゴリで絞り込み…</sys:String>
  <sys:String x:Key="KnowledgeUnlearnedOnly">未習得のみ</sys:String>

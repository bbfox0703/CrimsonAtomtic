  <sys:String x:Key="KnowledgeAllLearned">選択した知識はすべて習得済みです。</sys:String>
  <sys:String x:Key="JournalKnowledgePartial">{0}/{1} 件の知識キーを習得、0x{2} の前で失敗</sys:String>

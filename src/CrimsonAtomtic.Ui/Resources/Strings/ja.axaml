  <sys:String x:Key="ItemFlagLabelIsHousingOnly">ハウジング専用</sys:String>
  <sys:String x:Key="ItemFlagTipIsHousingOnly">プレイヤーハウジング内でのみ意味を持つ</sys:String>
  <sys:String x:Key="ItemFlagLabelIsEquipQuickSlotVisible">クイックスロット表示</sys:String>
  <sys:String x:Key="ItemFlagTipIsEquipQuickSlotVisible">装備クイックスロットバーに登録可能 (1.08+)</sys:String>
  <sys:String x:Key="ItemFlagLabelIsImportantItem">重要</sys:String>
  <sys:String x:Key="ItemFlagTipIsImportantItem">ストーリー / クエスト関連の重要アイテム</sys:String>
  <sys:String x:Key="ItemFlagLabelIsShieldItem">シールド</sys:String>

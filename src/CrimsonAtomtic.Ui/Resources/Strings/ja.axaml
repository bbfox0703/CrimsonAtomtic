  <sys:String x:Key="ItemFlagLabelIsTowerShieldItem">タワーシールド</sys:String>
  <sys:String x:Key="ItemFlagTipIsTowerShieldItem">タワーシールドのバリエーション</sys:String>
  <sys:String x:Key="ItemFlagLabelIsWild">野生</sys:String>
  <sys:String x:Key="ItemFlagTipIsWild">作成ではなく世界から採取するアイテム</sys:String>
  <sys:String x:Key="ItemFlagLabelHideFromInventoryOnPopItem">使用後に非表示</sys:String>

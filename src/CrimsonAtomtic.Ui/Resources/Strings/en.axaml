  <!-- Edit panel -->
  <sys:String x:Key="EditPanelHeader">Edit field</sys:String>
  <sys:String x:Key="EditPanelNameLabel">Field</sys:String>
  <sys:String x:Key="EditPanelTypeLabel">Type</sys:String>
  <sys:String x:Key="EditPanelValueLabel">New value</sys:String>
  <sys:String x:Key="EditPanelApply">Apply</sys:String>
  <sys:String x:Key="EditPanelRevert">Revert</sys:String>
  <sys:String x:Key="EditPanelFillMaxStack">Set to max</sys:String>
  <sys:String x:Key="EditPanelFillMaxStackTip">Fill this field with the item's max_stack_count (from iteminfo). Pre-fills the textbox — review then click Apply.</sys:String>
  <sys:String x:Key="EditPanelMakeAbsent">Make absent</sys:String>
  <sys:String x:Key="EditPanelMakeAbsentTip">Flip this scalar's presence bit off — the field is removed from the block (mask bit cleared, payload bytes dropped). Reverse it by typing a value and clicking Apply.</sys:String>
  <sys:String x:Key="MarkChallengeCompleteButton">✓ Mark Challenge Complete (Pattern B v1)</sys:String>
  <sys:String x:Key="MarkChallengeCompleteTip">Engine-faithful single-challenge completion (Pattern B v1). Only enables when the game has already detected this challenge as available (you've picked up the sealed artifact in-game). Writes the relevant entries — exactly what the game itself writes for a completed-but-unclaimed state. Living-type challenges may not apply. NOT FULLY TESTED — back up your save first.</sys:String>
  <sys:String x:Key="MarkChallengeSkipReasonPrefix">Disabled — reason:</sys:String>
  <sys:String x:Key="ConfirmDialogYes">Yes</sys:String>
  <sys:String x:Key="ConfirmDialogNo">No</sys:String>
  <sys:String x:Key="ElementsColBulkFill">Bulk</sys:String>
  <sys:String x:Key="ElementsBulkFillButton">Fill stacks</sys:String>
  <sys:String x:Key="ElementsBulkFillTip">Set every item in this container's _stackCount to its iteminfo max_stack_count.</sys:String>
  <sys:String x:Key="ElementsBulkFillConfirmTitle">Fill stacks to max?</sys:String>
  <sys:String x:Key="ElementsColAddItem">Add</sys:String>
  <sys:String x:Key="ElementsAddItemButton">+ Add Item…</sys:String>
  <sys:String x:Key="ElementsAddItemTip">Open the item browser to add a new item to this list, cloning this row as the template. The browser's top bar names the item and where it lands.</sys:String>
  <sys:String x:Key="ElementsColRemove">Remove</sys:String>
  <sys:String x:Key="ElementsRemoveButton">✕ Remove</sys:String>
  <sys:String x:Key="ElementsRemoveTip">Drop this element from the list. The save body shrinks to match; reversible by reloading without writing.</sys:String>
  <sys:String x:Key="ItemPickerAddToBagTip">Add this item to the inventory list the main window is currently showing. Open a bag (drill into _inventorylist[N]._itemList) first; otherwise the click reports the requirement in the status bar.</sys:String>
  <sys:String x:Key="MenuRestoreFromBackup">Restore from Backup…</sys:String>
  <sys:String x:Key="RestoreFromBackupTitle">Restore from Backup</sys:String>
  <sys:String x:Key="RestoreFromBackupColumnHint">Click "Restore" on a row to overwrite the live save with that snapshot. The current contents are backed up first.</sys:String>
  <sys:String x:Key="RestoreColSlot">Slot (user / name)</sys:String>
  <sys:String x:Key="RestoreColTimestamp">Backup taken</sys:String>
  <sys:String x:Key="RestoreColFiles">Files</sys:String>
  <sys:String x:Key="RestoreColSize">Size</sys:String>
  <sys:String x:Key="RestoreColAction">Action</sys:String>
  <sys:String x:Key="RestoreButton">⤺ Restore</sys:String>
  <sys:String x:Key="RestoreButtonTip">Overwrite the live save with this backup. The current state is backed up first, so this restore is itself undoable.</sys:String>
  <sys:String x:Key="EditPanelNestedReadOnly">Editing nested fields is not yet supported. Use Back to return to the top-level block.</sys:String>

  <!-- Picker shared with CharacterPickerWindow (Pick mode + warning banner)
       + edit panel button strings for the CharacterKey scalar field picker. -->
  <sys:String x:Key="CharacterPickerWarning">⚠ Linkage is best-effort. A characterinfo.pabgb key may not refer to the same entity across different fields. Cross-verify in-game or against the main editor before relying on the resolved name.</sys:String>

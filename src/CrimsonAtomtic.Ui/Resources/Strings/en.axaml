  <sys:String x:Key="ItemFlagLabelEnableEquipInCloneActor">Clone-actor</sys:String>
  <sys:String x:Key="ItemFlagTipEnableEquipInCloneActor">Equippable on a player's clone-actor (mirror combat)</sys:String>
  <sys:String x:Key="ItemFlagLabelCanDisassemble">Disassemble</sys:String>
  <sys:String x:Key="ItemFlagTipCanDisassemble">Eligible for the disassemble / salvage workflow</sys:String>
  <sys:String x:Key="ItemFlagLabelIsAllGimmickSealable">Gimmick-sealable</sys:String>
  <sys:String x:Key="ItemFlagTipIsAllGimmickSealable">Sealable against all gimmick effects</sys:String>
  <sys:String x:Key="ItemFlagLabelDeleteByGimmickUnlock">Auto-delete</sys:String>
  <sys:String x:Key="ItemFlagTipDeleteByGimmickUnlock">Auto-deleted when its bound gimmick gets unlocked</sys:String>
  <sys:String x:Key="ItemFlagLabelUseDropSetTarget">Drop-set</sys:String>
  <sys:String x:Key="ItemFlagTipUseDropSetTarget">Used as a drop-set targeting key (loot-table marker)</sys:String>


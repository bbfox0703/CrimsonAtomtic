<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

  <!-- Window / chrome -->
  <sys:String x:Key="WindowTitle">CrimsonAtomtic</sys:String>

  <!-- Menu -->
  <sys:String x:Key="MenuFile">_File</sys:String>
  <sys:String x:Key="MenuOpenSave">_Open Save…</sys:String>
  <sys:String x:Key="MenuSave">_Save</sys:String>
  <sys:String x:Key="MenuSaveAs">Save _As…</sys:String>
  <sys:String x:Key="MenuExit">E_xit</sys:String>
  <sys:String x:Key="MenuTools">_Tools</sys:String>
  <sys:String x:Key="MenuBrowseLocalization">_Browse Localization…</sys:String>
  <sys:String x:Key="MenuBrowseItems">Browse _Items…</sys:String>
  <sys:String x:Key="MenuExtractIcons">_Extract Icons from Game Data…</sys:String>
  <sys:String x:Key="MenuFontSize">_Font Size</sys:String>
  <sys:String x:Key="SummaryToggleTip">Show / hide the Save Summary panel — claim more room for the main grids.</sys:String>
  <sys:String x:Key="MenuLanguage">_Secondary Language</sys:String>
  <sys:String x:Key="MenuLanguageOff">English only (no secondary)</sys:String>

  <!-- Item-picker dialog -->
  <sys:String x:Key="ItemPickerWindowTitle">Browse items</sys:String>
  <sys:String x:Key="ItemPickerSearchPlaceholder">Filter by ItemKey, string id, or localized name…</sys:String>
  <sys:String x:Key="ItemPickerColIcon">Icon</sys:String>
  <sys:String x:Key="ItemPickerColKey">ItemKey</sys:String>
  <sys:String x:Key="ItemPickerColStringKey">String ID</sys:String>
  <sys:String x:Key="ItemPickerColNameEnglish">Name (eng)</sys:String>
  <sys:String x:Key="ItemPickerColCopy">Copy</sys:String>
  <sys:String x:Key="ItemPickerCopyKeyTip">Copy the numeric ItemKey to the clipboard</sys:String>
  <sys:String x:Key="ItemPickerCopyStringKeyTip">Copy iteminfo's internal string id to the clipboard</sys:String>
  <sys:String x:Key="ItemPickerCopyNameTip">Copy the English name to the clipboard</sys:String>
  <sys:String x:Key="ItemPickerCopyNameSecondaryTip">Copy the secondary-language name to the clipboard</sys:String>

  <!-- Browse-localization dialog -->
  <sys:String x:Key="LocalizationWindowTitle">Browse localization</sys:String>
  <sys:String x:Key="LocalizationSearchPlaceholder">Filter by key or value…</sys:String>
  <sys:String x:Key="LocalizationColKey">Key</sys:String>
  <sys:String x:Key="LocalizationColValue">Value</sys:String>
  <sys:String x:Key="LocalizationColCopy">Copy</sys:String>
  <sys:String x:Key="LocalizationCopyKeyTip">Copy the raw key to the clipboard</sys:String>
  <sys:String x:Key="LocalizationCopyValueTip">Copy the English value to the clipboard</sys:String>
  <sys:String x:Key="LocalizationCopyValue2Tip">Copy the secondary-language value to the clipboard</sys:String>

  <!-- Empty workspace -->
  <sys:String x:Key="EmptyTitle">No save loaded</sys:String>
  <sys:String x:Key="EmptyHint">Use File → Open Save to read a .save file.</sys:String>

  <!-- Summary pane -->
  <sys:String x:Key="SummaryHeader">Save summary</sys:String>
  <sys:String x:Key="SummarySlot">Slot</sys:String>
  <sys:String x:Key="SummaryVersion">Version</sys:String>
  <sys:String x:Key="SummaryHmac">HMAC</sys:String>
  <sys:String x:Key="SummaryHmacOk">verified</sys:String>
  <sys:String x:Key="SummaryHmacFail">FAILED</sys:String>
  <sys:String x:Key="SummaryPayload">Payload</sys:String>
  <sys:String x:Key="SummaryBody">Body</sys:String>
  <sys:String x:Key="SummaryTypes">Schema types</sys:String>
  <sys:String x:Key="SummaryEntries">TOC entries</sys:String>

  <!-- Blocks pane -->
  <sys:String x:Key="BlocksHeader">Top-level blocks</sys:String>
  <sys:String x:Key="BlocksFilterPlaceholder">Filter blocks by class or index…</sys:String>
  <sys:String x:Key="BlocksColIndex">#</sys:String>
  <sys:String x:Key="BlocksColClass">Class</sys:String>
  <sys:String x:Key="BlocksColOffset">Offset</sys:String>
  <sys:String x:Key="BlocksColSize">Size</sys:String>
  <sys:String x:Key="BlocksColFields">Fields</sys:String>

  <!-- Field detail pane -->
  <sys:String x:Key="FieldsHeader">Block fields</sys:String>
  <sys:String x:Key="FieldsHint">Select a block above to inspect its fields.</sys:String>
  <sys:String x:Key="FieldsColIndex">#</sys:String>
  <sys:String x:Key="FieldsColName">Field</sys:String>
  <sys:String x:Key="FieldsColType">Type</sys:String>
  <sys:String x:Key="FieldsColKind">Kind</sys:String>
  <sys:String x:Key="FieldsColPresent">Present</sys:String>
  <sys:String x:Key="FieldsColValue">Value</sys:String>
  <sys:String x:Key="FieldsColResolvedName">Name</sys:String>
  <sys:String x:Key="FieldsColRange">Bytes</sys:String>
  <sys:String x:Key="FieldsMask">Mask</sys:String>
  <sys:String x:Key="FieldsTrailingPad">Trailing pad</sys:String>
  <sys:String x:Key="FieldsUndecoded">Undecoded</sys:String>
  <sys:String x:Key="FieldsLoading">Loading…</sys:String>
  <sys:String x:Key="FieldsError">Could not load block details.</sys:String>
  <sys:String x:Key="FieldsFilterPlaceholder">Filter fields by name, type, or value…</sys:String>
  <sys:String x:Key="FieldsFilterCount">{0:N0} of {1:N0}</sys:String>

  <!-- Drill-down + navigation -->
  <sys:String x:Key="FieldsColDrill">Drill</sys:String>
  <sys:String x:Key="FieldsDrillButton">▸</sys:String>

  <!-- Edit panel -->
  <sys:String x:Key="EditPanelHeader">Edit field</sys:String>
  <sys:String x:Key="EditPanelNameLabel">Field</sys:String>
  <sys:String x:Key="EditPanelTypeLabel">Type</sys:String>
  <sys:String x:Key="EditPanelValueLabel">New value</sys:String>
  <sys:String x:Key="EditPanelApply">Apply</sys:String>
  <sys:String x:Key="EditPanelRevert">Revert</sys:String>
  <sys:String x:Key="EditPanelFillMaxStack">Set to max</sys:String>
  <sys:String x:Key="EditPanelFillMaxStackTip">Fill this field with the item's max_stack_count (from iteminfo). Pre-fills the textbox — review then click Apply.</sys:String>
  <sys:String x:Key="EditPanelMakeAbsent">Make absent</sys:String>
  <sys:String x:Key="EditPanelMakeAbsentTip">Flip this scalar's presence bit off — the field is removed from the block (mask bit cleared, payload bytes dropped). Reverse it by typing a value and clicking Apply.</sys:String>
  <sys:String x:Key="ConfirmDialogYes">Yes</sys:String>
  <sys:String x:Key="ConfirmDialogNo">No</sys:String>
  <sys:String x:Key="ElementsColBulkFill">Bulk</sys:String>
  <sys:String x:Key="ElementsBulkFillButton">Fill stacks</sys:String>
  <sys:String x:Key="ElementsBulkFillTip">Set every item in this container's _stackCount to its iteminfo max_stack_count.</sys:String>
  <sys:String x:Key="ElementsBulkFillConfirmTitle">Fill stacks to max?</sys:String>
  <sys:String x:Key="ElementsColRemove">Remove</sys:String>
  <sys:String x:Key="ElementsRemoveButton">✕ Remove</sys:String>
  <sys:String x:Key="ElementsRemoveTip">Drop this element from the list. The save body shrinks to match; reversible by reloading without writing.</sys:String>
  <sys:String x:Key="ItemPickerAddToBagTip">Add this item to the inventory list the main window is currently showing. Open a bag (drill into _inventorylist[N]._itemList) first; otherwise the click reports the requirement in the status bar.</sys:String>
  <sys:String x:Key="MenuRestoreFromBackup">Restore from Backup…</sys:String>
  <sys:String x:Key="RestoreFromBackupTitle">Restore from Backup</sys:String>
  <sys:String x:Key="RestoreFromBackupColumnHint">Click "Restore" on a row to overwrite the live save with that snapshot. The current contents are backed up first.</sys:String>
  <sys:String x:Key="RestoreColSlot">Slot (user / name)</sys:String>
  <sys:String x:Key="RestoreColTimestamp">Backup taken</sys:String>
  <sys:String x:Key="RestoreColFiles">Files</sys:String>
  <sys:String x:Key="RestoreColSize">Size</sys:String>
  <sys:String x:Key="RestoreColAction">Action</sys:String>
  <sys:String x:Key="RestoreButton">⤺ Restore</sys:String>
  <sys:String x:Key="RestoreButtonTip">Overwrite the live save with this backup. The current state is backed up first, so this restore is itself undoable.</sys:String>
  <sys:String x:Key="EditPanelNestedReadOnly">Editing nested fields is not yet supported. Use Back to return to the top-level block.</sys:String>
  <sys:String x:Key="ElementsColIcon">Icon</sys:String>
  <sys:String x:Key="ElementsColIndex">#</sys:String>
  <sys:String x:Key="ElementsColClass">Class</sys:String>
  <sys:String x:Key="ElementsColOffset">Offset</sys:String>
  <sys:String x:Key="ElementsColSize">Size</sys:String>
  <sys:String x:Key="ElementsColFields">Fields</sys:String>
  <sys:String x:Key="ElementsColOpen">Open</sys:String>
  <sys:String x:Key="ElementsOpenButton">▸</sys:String>
  <sys:String x:Key="ElementsColItemKey">Key</sys:String>
  <sys:String x:Key="ElementsColItemName">Name</sys:String>
  <sys:String x:Key="ElementsFilterPlaceholder">Filter by key, name, or class…</sys:String>
  <sys:String x:Key="NavigationBack">← Back</sys:String>

</ResourceDictionary>

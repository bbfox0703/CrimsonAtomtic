  <sys:String x:Key="ElementsColItemKey">Key</sys:String>
  <sys:String x:Key="ElementsColItemName">Name</sys:String>
  <sys:String x:Key="ElementsFilterPlaceholder">Filter by key, name, or class…</sys:String>

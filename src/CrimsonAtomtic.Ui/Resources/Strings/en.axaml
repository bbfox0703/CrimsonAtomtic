  <sys:String x:Key="ItemFlagLabelIsWild">Wild</sys:String>
  <sys:String x:Key="ItemFlagTipIsWild">Gathered from the world rather than crafted</sys:String>
  <sys:String x:Key="ItemFlagLabelHideFromInventoryOnPopItem">Hide on pop</sys:String>
  <sys:String x:Key="ItemFlagTipHideFromInventoryOnPopItem">Hidden from inventory after the PopItem use action runs</sys:String>
  <sys:String x:Key="ItemFlagLabelDiscardable">Discardable</sys:String>
  <sys:String x:Key="ItemFlagTipDiscardable">Player is allowed to discard</sys:String>
  <sys:String x:Key="ItemFlagLabelIsRegisterTradeMarket">Tradeable</sys:String>
  <sys:String x:Key="ItemFlagTipIsRegisterTradeMarket">Eligible for the trade-market posting flow</sys:String>
  <sys:String x:Key="ItemFlagLabelIsEditorUsable">Editor</sys:String>
  <sys:String x:Key="ItemFlagTipIsEditorUsable">Reserved for in-engine editor tooling</sys:String>
  <sys:String x:Key="ItemFlagLabelIsEditableGrime">Editable grime</sys:String>
  <sys:String x:Key="ItemFlagTipIsEditableGrime">Has an editable dirt / wear overlay</sys:String>
  <sys:String x:Key="ItemFlagLabelUseImmediately">Use immediately</sys:String>
  <sys:String x:Key="ItemFlagTipUseImmediately">Triggers its use effect on pickup rather than from inventory</sys:String>
  <sys:String x:Key="ItemFlagLabelApplyMaxStackCap">Apply stack cap</sys:String>
  <sys:String x:Key="ItemFlagTipApplyMaxStackCap">Caps runtime stack count to max_stack_count</sys:String>
  <sys:String x:Key="ItemFlagLabelIsBlockedStoreSell">No store sell</sys:String>
  <sys:String x:Key="ItemFlagTipIsBlockedStoreSell">Blocked from store sell-back regardless of category</sys:String>
  <sys:String x:Key="ItemFlagLabelIsPreorderItem">Preorder</sys:String>
  <sys:String x:Key="ItemFlagTipIsPreorderItem">Granted via a pre-order entitlement bundle</sys:String>
  <sys:String x:Key="ItemFlagLabelIsHasItemUseDataInventoryBuff">Inventory buff</sys:String>
  <sys:String x:Key="ItemFlagTipIsHasItemUseDataInventoryBuff">Carries an inventory-time buff payload</sys:String>
  <sys:String x:Key="ItemFlagLabelIsPreservedOnExtract">Carry-out</sys:String>
  <sys:String x:Key="ItemFlagTipIsPreservedOnExtract">Preserved during extraction-style runs</sys:String>
  <sys:String x:Key="ItemFlagLabelEnableAlertSystemToUi">UI alert</sys:String>
  <sys:String x:Key="ItemFlagTipEnableAlertSystemToUi">Item pickup raises a UI alert</sys:String>
  <sys:String x:Key="ItemFlagLabelIsSaveGameDataAtUseItem">Save on use</sys:String>
  <sys:String x:Key="ItemFlagTipIsSaveGameDataAtUseItem">Use action triggers a save-game write</sys:String>
  <sys:String x:Key="ItemFlagLabelIsLogoutAtUseItem">Logout on use</sys:String>

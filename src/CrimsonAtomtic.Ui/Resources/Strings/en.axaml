  <sys:String x:Key="ItemFlagLabelIsDestroyWhenBroken">Destroy when broken</sys:String>
  <sys:String x:Key="ItemFlagTipIsDestroyWhenBroken">Removed from inventory when endurance hits 0</sys:String>
  <sys:String x:Key="ItemFlagLabelIsHousingOnly">Housing only</sys:String>
  <sys:String x:Key="ItemFlagTipIsHousingOnly">Only meaningful inside player housing</sys:String>
  <sys:String x:Key="ItemFlagLabelIsEquipQuickSlotVisible">Quick-slot visible</sys:String>

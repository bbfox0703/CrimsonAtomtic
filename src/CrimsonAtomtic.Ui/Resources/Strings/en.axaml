  <!-- Game-data version mismatch warning. Surfaced on startup when
       meta/0.paver's minor doesn't match the parser's target. -->
  <sys:String x:Key="GameVersionMismatchTitle">Game version mismatch</sys:String>
  <sys:String x:Key="GameVersionMismatchHeadline">CrimsonAtomtic's parser targets a different game version than what's installed.</sys:String>
  <sys:String x:Key="GameVersionMismatchDetectedLabel">Detected install:</sys:String>
  <sys:String x:Key="GameVersionMismatchTargetLabel">Parser targets:</sys:String>
  <sys:String x:Key="GameVersionMismatchExplanation">Item / save data layouts can change between Pearl Abyss patches. Running this build of CrimsonAtomtic against a different patch's data may crash on item-info loading, silently mis-decode values, or corrupt a saved file on write. Continue at your own risk — you can also quit, downgrade or upgrade your install, and relaunch.</sys:String>
  <sys:String x:Key="GameVersionMismatchContinue">Continue anyway</sys:String>
  <sys:String x:Key="GameVersionMismatchQuit">Quit</sys:String>

  <!-- First-launch legal disclaimer -->
  <sys:String x:Key="DisclaimerTitle">CrimsonAtomtic — Disclaimer</sys:String>
  <sys:String x:Key="DisclaimerAccept">I Accept</sys:String>
  <sys:String x:Key="DisclaimerDecline">Quit</sys:String>
  <sys:String x:Key="DisclaimerBody">This editor is provided as-is with no warranty of correct operation and no exhaustive validation of save structures. The author accepts no responsibility for any data corruption, save damage, account-related issues, or features that don't work as expected — and is under no obligation to fix them. There is no guarantee that this tool will be updated to track future game versions.&#x0a;&#x0a;Clicking "I Accept" confirms you have read and agreed to the above and accept all risks of using this tool.</sys:String>

  <!-- Empty workspace -->
  <sys:String x:Key="EmptyTitle">No save loaded</sys:String>
  <sys:String x:Key="EmptyHint">Use File → Open Save to read a .save file.</sys:String>


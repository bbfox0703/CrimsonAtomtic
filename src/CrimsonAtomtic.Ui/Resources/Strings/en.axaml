<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

  <!-- Window / chrome -->
  <sys:String x:Key="WindowTitle">CrimsonAtomtic</sys:String>

  <!-- Menu -->
  <sys:String x:Key="MenuFile">_File</sys:String>
  <sys:String x:Key="MenuOpenSave">_Open Save…</sys:String>
  <sys:String x:Key="MenuSave">_Save</sys:String>
  <sys:String x:Key="MenuSaveAs">Save _As…</sys:String>
  <sys:String x:Key="MenuExit">E_xit</sys:String>
  <sys:String x:Key="MenuTools">_Tools</sys:String>
  <sys:String x:Key="MenuBrowseLocalization">_Browse Localization…</sys:String>
  <sys:String x:Key="MenuLanguage">_Secondary Language</sys:String>
  <sys:String x:Key="MenuLanguageOff">English only (no secondary)</sys:String>

  <!-- Browse-localization dialog -->
  <sys:String x:Key="LocalizationWindowTitle">Browse localization</sys:String>
  <sys:String x:Key="LocalizationSearchPlaceholder">Filter by key or value…</sys:String>
  <sys:String x:Key="LocalizationColKey">Key</sys:String>
  <sys:String x:Key="LocalizationColValue">Value</sys:String>

  <!-- Empty workspace -->
  <sys:String x:Key="EmptyTitle">No save loaded</sys:String>
  <sys:String x:Key="EmptyHint">Use File → Open Save to read a .save file.</sys:String>

  <!-- Summary pane -->
  <sys:String x:Key="SummaryHeader">Save summary</sys:String>
  <sys:String x:Key="SummarySlot">Slot</sys:String>
  <sys:String x:Key="SummaryVersion">Version</sys:String>
  <sys:String x:Key="SummaryHmac">HMAC</sys:String>
  <sys:String x:Key="SummaryHmacOk">verified</sys:String>
  <sys:String x:Key="SummaryHmacFail">FAILED</sys:String>
  <sys:String x:Key="SummaryPayload">Payload</sys:String>
  <sys:String x:Key="SummaryBody">Body</sys:String>
  <sys:String x:Key="SummaryTypes">Schema types</sys:String>
  <sys:String x:Key="SummaryEntries">TOC entries</sys:String>

  <!-- Blocks pane -->
  <sys:String x:Key="BlocksHeader">Top-level blocks</sys:String>
  <sys:String x:Key="BlocksColIndex">#</sys:String>
  <sys:String x:Key="BlocksColClass">Class</sys:String>
  <sys:String x:Key="BlocksColOffset">Offset</sys:String>
  <sys:String x:Key="BlocksColSize">Size</sys:String>
  <sys:String x:Key="BlocksColFields">Fields</sys:String>

  <!-- Field detail pane -->
  <sys:String x:Key="FieldsHeader">Block fields</sys:String>
  <sys:String x:Key="FieldsHint">Select a block above to inspect its fields.</sys:String>
  <sys:String x:Key="FieldsColIndex">#</sys:String>
  <sys:String x:Key="FieldsColName">Field</sys:String>
  <sys:String x:Key="FieldsColType">Type</sys:String>
  <sys:String x:Key="FieldsColKind">Kind</sys:String>
  <sys:String x:Key="FieldsColPresent">Present</sys:String>
  <sys:String x:Key="FieldsColValue">Value</sys:String>
  <sys:String x:Key="FieldsColResolvedName">Item name</sys:String>
  <sys:String x:Key="FieldsColRange">Bytes</sys:String>
  <sys:String x:Key="FieldsMask">Mask</sys:String>
  <sys:String x:Key="FieldsTrailingPad">Trailing pad</sys:String>
  <sys:String x:Key="FieldsUndecoded">Undecoded</sys:String>
  <sys:String x:Key="FieldsLoading">Loading…</sys:String>
  <sys:String x:Key="FieldsError">Could not load block details.</sys:String>
  <sys:String x:Key="FieldsFilterPlaceholder">Filter fields by name, type, or value…</sys:String>
  <sys:String x:Key="FieldsFilterCount">{0:N0} of {1:N0}</sys:String>

  <!-- Drill-down + navigation -->
  <sys:String x:Key="FieldsColDrill">Drill</sys:String>
  <sys:String x:Key="FieldsDrillButton">▸</sys:String>

  <!-- Edit panel -->
  <sys:String x:Key="EditPanelHeader">Edit field</sys:String>
  <sys:String x:Key="EditPanelNameLabel">Field</sys:String>
  <sys:String x:Key="EditPanelTypeLabel">Type</sys:String>
  <sys:String x:Key="EditPanelValueLabel">New value</sys:String>
  <sys:String x:Key="EditPanelApply">Apply</sys:String>
  <sys:String x:Key="EditPanelRevert">Revert</sys:String>
  <sys:String x:Key="EditPanelNestedReadOnly">Editing nested fields is not yet supported. Use Back to return to the top-level block.</sys:String>
  <sys:String x:Key="ElementsColIndex">#</sys:String>
  <sys:String x:Key="ElementsColClass">Class</sys:String>
  <sys:String x:Key="ElementsColOffset">Offset</sys:String>
  <sys:String x:Key="ElementsColSize">Size</sys:String>
  <sys:String x:Key="ElementsColFields">Fields</sys:String>
  <sys:String x:Key="ElementsColOpen">Open</sys:String>
  <sys:String x:Key="ElementsOpenButton">▸</sys:String>
  <sys:String x:Key="NavigationBack">← Back</sys:String>

</ResourceDictionary>

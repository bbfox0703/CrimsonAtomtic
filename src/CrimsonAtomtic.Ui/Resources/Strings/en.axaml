  <!-- World Map dialog (Tools menu) -->
  <sys:String x:Key="MenuWorldMap">_World Map…</sys:String>
  <sys:String x:Key="WorldMapWindowTitle">World Map</sys:String>
  <sys:String x:Key="WorldMapPickMap">Pick Map…</sys:String>
  <sys:String x:Key="WorldMapPickMapTip">Choose an image file to use as the world-map backdrop. The image is force-stretched to a square canvas; marker positions are computed against the canonical Crimson Desert world map regardless of the file's pixel dimensions.</sys:String>
  <sys:String x:Key="WorldMapPickMapTitle">Pick world map image</sys:String>
  <sys:String x:Key="WorldMapFilterLabel">Filter:</sys:String>
  <sys:String x:Key="WorldMapFilterTip">Substring match against the object label. Empty = show every object with a position.</sys:String>
  <sys:String x:Key="WorldMapObjectPickerTip">Pick an object (active char, mercenary, or gimmick) to ping on the map.</sys:String>
  <sys:String x:Key="WorldMapClose">Close</sys:String>
  <sys:String x:Key="WorldMapNoSaveTitle">No save loaded</sys:String>
  <sys:String x:Key="WorldMapNoSaveBody">Open a save file (File → Open Save) before opening the World Map.</sys:String>

</ResourceDictionary>

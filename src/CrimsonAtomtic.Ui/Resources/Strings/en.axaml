<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

  <!-- Language marker — UiLanguageService snapshots Application.Resources.MergedDictionaries
       at startup and uses this key to identify which dictionary is which.
       Required because the XAML compiler inlines <ResourceInclude> targets
       as Avalonia.Controls.ResourceDictionary, which doesn't expose the
       original Source URI. Don't remove. -->
  <sys:String x:Key="__UiLangCode__">en</sys:String>

  <!-- Window / chrome -->
  <sys:String x:Key="WindowTitle">CrimsonAtomtic</sys:String>

  <!-- Menu -->
  <sys:String x:Key="MenuFile">_File</sys:String>
  <sys:String x:Key="MenuOpenSave">_Open Save…</sys:String>
  <sys:String x:Key="MenuSave">_Save</sys:String>
  <sys:String x:Key="MenuSaveAs">Save _As…</sys:String>
  <sys:String x:Key="MenuExit">E_xit</sys:String>
  <sys:String x:Key="MenuTools">_Tools</sys:String>
  <sys:String x:Key="MenuBrowseLocalization">_Browse Localization…</sys:String>
  <sys:String x:Key="MenuBrowseItems">Browse _Items…</sys:String>
  <sys:String x:Key="MenuExtractIcons">_Extract Icons from Game Data…</sys:String>
  <sys:String x:Key="MenuSetGameInstallFolder">Set _Game Install Folder…</sys:String>
  <sys:String x:Key="SetGameInstallFolderInvalidTitle">Folder doesn't look like a Crimson Desert install</sys:String>
  <sys:String x:Key="SetGameInstallFolderInvalidBody">The selected folder doesn't contain the required asset file (0020\0.pamt). Pick the directory that contains the game's 0000\, 0020\, … pack groups — typically &lt;Steam library&gt;\steamapps\common\Crimson Desert or the Epic / asset folder you copied out for Game Pass.</sys:String>
  <sys:String x:Key="MenuRenameMercenary">Rename _Mercenary…</sys:String>
  <sys:String x:Key="MenuEditItemSockets">Edit Item _Sockets…</sys:String>
  <sys:String x:Key="SocketEditorHeader">Per-slot Fill / Change / Clear. Endurance is reset to 65535 (max) on Fill + Change so a fresh greater gem doesn't inherit the old slot's worn value. _validSocketCount auto-bumps when you fill a slot whose index is past the item's current cap (so the slot becomes visible in-game). You can fill any slot the underlying list pre-allocates (typically up to 5), regardless of the gamedata-defined limit. Saves to file on next File → Save.</sys:String>
  <sys:String x:Key="SocketEditorColBag">Bag</sys:String>
  <sys:String x:Key="SocketEditorColItem">Item</sys:String>
  <sys:String x:Key="SocketEditorColItemKey">ItemKey</sys:String>
  <sys:String x:Key="SocketEditorColSocket">Slot</sys:String>
  <sys:String x:Key="SocketEditorColCurrentGem">Current gem</sys:String>
  <sys:String x:Key="SocketEditorColCurrentGemKey">GemKey</sys:String>
  <sys:String x:Key="SocketEditorColAction">Action</sys:String>
  <sys:String x:Key="SocketEditorColApplied">Status</sys:String>
  <sys:String x:Key="SocketEditorChangeGem">Change…</sys:String>
  <sys:String x:Key="SocketEditorFillGem">Fill…</sys:String>
  <sys:String x:Key="SocketEditorClearGem">Clear</sys:String>
  <sys:String x:Key="SocketEditorChangeGemTip">Open the gem picker and overwrite this filled slot. Resets _currentEndurance to 65535 (max) so greater gems start fresh.</sys:String>
  <sys:String x:Key="SocketEditorFillGemTip">Open the gem picker and fill this empty slot. Auto-bumps _validSocketCount on the parent item if needed so the slot becomes visible in-game.</sys:String>
  <sys:String x:Key="SocketEditorClearGemTip">Demote this socket back to empty. Both _currentEndurance and _itemKey become absent; mask flips to [0x00].</sys:String>
  <sys:String x:Key="SocketEditorColState">State</sys:String>
  <sys:String x:Key="SocketEditorApplySetItemLabel">Apply set to:</sys:String>
  <sys:String x:Key="SocketEditorApplySetSetLabel">Set:</sys:String>
  <sys:String x:Key="SocketEditorApplySetApply">Apply</sys:String>
  <sys:String x:Key="SocketEditorApplySetEditCustom">Edit custom sets…</sys:String>
  <sys:String x:Key="SocketEditorApplySetEditCustomTip">Define / rename the three user-custom gem sets. Saved to settings.json.</sys:String>
  <sys:String x:Key="SocketEditorFilterLabel">Filter:</sys:String>
  <sys:String x:Key="SocketEditorFilterWatermark">Type to filter — item name / bag / item key shows all 5 slots; gem name / gem key narrows to matching slots only…</sys:String>

  <!-- Custom gem sets editor (launched from Sockets editor toolbar) -->
  <sys:String x:Key="CustomGemSetsWindowTitle">Edit custom gem sets</sys:String>
  <sys:String x:Key="CustomGemSetsHeader">Three user-definable gem sets surfaced alongside the built-in three in the Sockets editor's Apply-Set toolbar. Each set has a label + up to 5 ItemKey entries (blank cells are skipped). Applying a set with N entries overwrites slots 0..N-1 of the target item and leaves slots [N..max] alone. Saves to settings.json on click.</sys:String>
  <sys:String x:Key="CustomGemSetsSave">Save</sys:String>
  <sys:String x:Key="CustomGemSetsClose">Close</sys:String>
  <sys:String x:Key="SocketEditorClose">Close</sys:String>
  <sys:String x:Key="SocketEditorNotAvailableTitle">No filled sockets in this save</sys:String>
  <sys:String x:Key="SocketEditorNotAvailableBody">The loaded save has no items with filled sockets (or no items with a _socketSaveDataList at all). Filled sockets appear here once you've embedded a gem in-game.</sys:String>
  <sys:String x:Key="SocketEditorPickerTitle">Pick a gem</sys:String>
  <sys:String x:Key="RenameMercenaryHeader">Rename mercenaries / pets. The Name column shows the character/template name resolved from CharacterKey (same source as the main window's mercenaryDataList Name column) — use it to recognise each row. The New name box is pre-filled with the current custom name (_mercenaryName); edit it and click Apply per row. An empty box clears the custom name. Saves to the file on next File → Save.</sys:String>
  <sys:String x:Key="RenameMercenaryColIdx">Index</sys:String>
  <sys:String x:Key="RenameMercenaryColMercNo">MercNo</sys:String>
  <sys:String x:Key="RenameMercenaryColCharKey">CharKey</sys:String>
  <sys:String x:Key="RenameMercenaryColPortrait">Portrait</sys:String>
  <sys:String x:Key="RenameMercenaryColCharName">Name</sys:String>
  <sys:String x:Key="RenameMercenaryColType">Type</sys:String>
  <sys:String x:Key="RenameMercenaryColEquip">Equip</sys:String>
  <sys:String x:Key="RenameMercenaryColNewName">New name (UTF-8)</sys:String>
  <sys:String x:Key="RenameMercenaryColApply">Action</sys:String>
  <sys:String x:Key="RenameMercenaryColApplied">Applied</sys:String>
  <sys:String x:Key="RenameMercenaryApply">Apply</sys:String>
  <sys:String x:Key="RenameMercenaryClose">Close</sys:String>
  <sys:String x:Key="RenameMercenaryNewNameWatermark">enter new name…</sys:String>
  <sys:String x:Key="RenameMercenaryNotAvailableTitle">No mercenaries to rename</sys:String>
  <sys:String x:Key="RenameMercenaryNotAvailableBody">The loaded save doesn't have a MercenaryClanSaveData block, or its _mercenaryDataList is empty / unreadable. Mercenaries appear here once you've recruited at least one in-game.</sys:String>
  <sys:String x:Key="MenuFillAllStacks">Fill _All Stacks Across Every Inventory…</sys:String>
  <sys:String x:Key="MenuUnlockAllAbyssGates">_Unlock All Abyss Gates (Map Discovery)…</sys:String>
  <sys:String x:Key="MenuBulkCompleteHeldSAChallenges">_Complete Eligible Held Sealed Abyss Artifact Challenges…</sys:String>
  <sys:String x:Key="MenuEditAbyssGates">_Edit Abyss Gates (Lock/Unlock per gate)…</sys:String>
  <sys:String x:Key="MenuUnlockMounts">Unlock Mo_unts (Sigils + Dragon)…</sys:String>
  <sys:String x:Key="MenuEditKnowledge">Edit _Knowledge (learn by category)…</sys:String>
  <sys:String x:Key="MenuEditFactionNodes">Edit _Faction Nodes (discover / set state)…</sys:String>
  <sys:String x:Key="MenuEditItemDyes">Edit Item _Dyes…</sys:String>
  <sys:String x:Key="MenuVendorBuyback">_Vendor Buyback…</sys:String>
  <sys:String x:Key="MenuReviewChanges">_Review Pending Changes…</sys:String>

  <!-- Vendor Buyback dialog (Tools menu) -->
  <sys:String x:Key="VendorBuybackWindowTitle">Vendor Buyback</sys:String>
  <sys:String x:Key="VendorBuybackHeader">View + Remove items the player has sold to vendors. Each row maps to one StoreDataSaveData._storeSoldItemDataList element. The Remove button deletes the entry from that store's buyback queue (frees the slot); subsequent siblings in the same store shift down by 1 automatically. "Move back to inventory" is a planned follow-up. Saves to file on next File → Save.</sys:String>
  <sys:String x:Key="VendorBuybackFilterLabel">Filter:</sys:String>
  <sys:String x:Key="VendorBuybackFilterWatermark">Type to filter — store name / store key shows every sold item in that store; item name / item key narrows per-row…</sys:String>
  <sys:String x:Key="VendorBuybackColStore">Store</sys:String>
  <sys:String x:Key="VendorBuybackColStoreKey">StoreKey</sys:String>
  <sys:String x:Key="VendorBuybackColItem">Item</sys:String>
  <sys:String x:Key="VendorBuybackColItemKey">ItemKey</sys:String>
  <sys:String x:Key="VendorBuybackColStack">Stack</sys:String>
  <sys:String x:Key="VendorBuybackColEndurance">Endurance</sys:String>
  <sys:String x:Key="VendorBuybackColSoldAt">SoldAt (ticks)</sys:String>
  <sys:String x:Key="VendorBuybackColAction">Action</sys:String>
  <sys:String x:Key="VendorBuybackColStatus">Status</sys:String>
  <sys:String x:Key="VendorBuybackRemove">Remove</sys:String>
  <sys:String x:Key="VendorBuybackRemoveTip">Delete this entry from the store's buyback queue. The slot frees up so other items can age in. Cannot be undone within the session; reload the save without writing to revert.</sys:String>
  <sys:String x:Key="VendorBuybackJump">Jump…</sys:String>
  <sys:String x:Key="VendorBuybackJumpTip">Close this dialog and open the buyback item in the main editor's block tree. Use the generic per-field editor there to modify stack count, endurance, sockets, dye, etc. — same surface as inventory items.</sys:String>
  <sys:String x:Key="VendorBuybackClose">Close</sys:String>
  <sys:String x:Key="VendorBuybackNotAvailableTitle">No vendor buyback entries</sys:String>
  <sys:String x:Key="VendorBuybackNotAvailableBody">The loaded save has no StoreDataSaveData entry with a non-empty _storeSoldItemDataList. Sell items to a vendor in-game to populate the buyback queue.</sys:String>

  <!-- Change summary dialog (review pending edits + close-on-dirty confirm) -->
  <sys:String x:Key="ChangeSummaryWindowTitle">Pending changes</sys:String>
  <sys:String x:Key="ChangeSummaryHeaderClose">Unsaved changes — save before exiting?</sys:String>
  <sys:String x:Key="ChangeSummarySubHeaderClose">The edits listed below haven't been written to disk yet. Save to commit them, Discard to exit without saving (the previous on-disk state is preserved), or Cancel to keep editing.</sys:String>
  <sys:String x:Key="ChangeSummaryHeaderReview">Pending changes since last save</sys:String>
  <sys:String x:Key="ChangeSummarySubHeaderReview">Read-only list of edits applied via the UI since the save was loaded (or since the last File → Save). Reload the save to drop all of them; File → Save to commit.</sys:String>
  <sys:String x:Key="ChangeSummaryColTime">Time</sys:String>
  <sys:String x:Key="ChangeSummaryColCategory">Area</sys:String>
  <sys:String x:Key="ChangeSummaryColSummary">Change</sys:String>
  <sys:String x:Key="ChangeSummarySave">Save</sys:String>
  <sys:String x:Key="ChangeSummaryDiscard">Discard</sys:String>
  <sys:String x:Key="ChangeSummaryDiscardExit">Discard &amp; exit</sys:String>
  <sys:String x:Key="ChangeSummaryCancel">Cancel</sys:String>
  <sys:String x:Key="ChangeSummaryNoChangesTitle">No pending changes</sys:String>
  <sys:String x:Key="ChangeSummaryNoChangesBody">Nothing has been edited since the save was loaded (or since the last File → Save).</sys:String>

  <!-- Dye editor master dialog -->
  <sys:String x:Key="DyeEditorWindowTitle">Edit item dyes</sys:String>
  <sys:String x:Key="DyeEditorHeader">Per-item dye editing. Lists items whose _itemDyeDataList is present (Edit) and equipped items that don't have dye data yet but support it (+ Add). Click Edit to mutate R/G/B/A + grime + material + color group on individual slots; click + Add to pick a valid slot and materialize a default empty dye element you can then color.</sys:String>
  <sys:String x:Key="DyeEditorSearchPlaceholder">Filter by item name, bag, or ItemKey…</sys:String>
  <sys:String x:Key="DyeEditorColIcon">Icon</sys:String>
  <sys:String x:Key="DyeEditorColBag">Bag</sys:String>
  <sys:String x:Key="DyeEditorColItem">Item</sys:String>
  <sys:String x:Key="DyeEditorColItemKey">ItemKey</sys:String>
  <sys:String x:Key="DyeEditorColSlotCount">Slots</sys:String>
  <sys:String x:Key="DyeEditorColAction">Action</sys:String>
  <sys:String x:Key="DyeEditorEdit">Edit…</sys:String>
  <sys:String x:Key="DyeEditorEditTip">Open the per-slot editor for this item's dye list. The dialog stays open after applying so you can edit several slots in sequence.</sys:String>
  <sys:String x:Key="DyeEditorAdd">+ Add</sys:String>
  <sys:String x:Key="DyeEditorAddTip">Pick a valid dye slot for this item and materialize a default-empty dye element. After it lands, click Edit to color it.</sys:String>
  <sys:String x:Key="DyeEditorAddPickSlotTitle">Pick dye slot</sys:String>
  <sys:String x:Key="DyeEditorAddPickSlotHeader">Pick the dye slot to materialize on this item. The list below shows the slots resolved from partprefabdyeslotinfo for this item — each label is the slot's default material name.</sys:String>
  <sys:String x:Key="DyeEditorAddNoTemplateTitle">No dye template in this save</sys:String>
  <sys:String x:Key="DyeEditorAddNoTemplateBody">The toggle ABI needs at least one already-dyed item in the save to copy the element schema from. Dye one item in-game first (any clothing/armor), save, reload here, and retry.</sys:String>
  <sys:String x:Key="DyeEditorAddFailedTitle">Could not add dye</sys:String>
  <sys:String x:Key="DyeEditorClose">Close</sys:String>
  <sys:String x:Key="DyeEditorNotAvailableTitle">No dyed items in this save</sys:String>
  <sys:String x:Key="DyeEditorNotAvailableBody">No item carried _itemDyeDataList with at least one slot. Either the player hasn't dyed anything yet, or this save schema has _itemDyeDataList under a different field name (re-run vendor/crimson-rs/_probe_item_dye_data to verify).</sys:String>

  <!-- Dye slot editor child dialog -->
  <sys:String x:Key="DyeSlotEditorWindowTitle">Edit dye slots</sys:String>
  <sys:String x:Key="DyeSlotColSlot">Slot</sys:String>
  <sys:String x:Key="DyeSlotColColor">Color</sys:String>
  <sys:String x:Key="DyeSlotColGrime">Grime</sys:String>
  <sys:String x:Key="DyeSlotColMaterial">Material</sys:String>
  <sys:String x:Key="DyeSlotColColorGroup">Color group</sys:String>
  <sys:String x:Key="DyeSlotColAction">Action</sys:String>
  <sys:String x:Key="DyeSlotColStatus">Status</sys:String>
  <sys:String x:Key="DyeSlotPick">Pick…</sys:String>
  <sys:String x:Key="DyeSlotApply">Apply</sys:String>
  <sys:String x:Key="DyeSlotEditorClose">Close</sys:String>

  <!-- Dye palette picker modal -->
  <sys:String x:Key="DyePalettePickerWindowTitle">Pick a dye color</sys:String>
  <sys:String x:Key="DyePalettePickerCancel">Cancel</sys:String>
  <sys:String x:Key="DyePalettePickerOffGridBanner">The currently-applied color is not on this theme's palette (probably set by an external tool). Picking any cell will replace it with an on-grid color.</sys:String>
  <sys:String x:Key="AbyssGatesWindowTitle">Edit Abyss Gates</sys:String>
  <sys:String x:Key="AbyssGatesHeader">Per-gate Lock/Unlock toggle. Writes _initStateNameHash on every nested FieldGimmickSaveData element inside FieldSaveData._fieldGimmickSaveDataList (Default 0x866c7489 ↔ Activated 0xe300acfe). Idle (scenery) and Unknown rows are read-only to avoid destabilising non-gate gimmicks. Saves to the file on next File → Save.</sys:String>
  <sys:String x:Key="AbyssGatesColOwnerLevel">Owner level</sys:String>
  <sys:String x:Key="AbyssGatesColGimmick">Gimmick</sys:String>
  <sys:String x:Key="AbyssGatesColSaveKey">SaveKey</sys:String>
  <sys:String x:Key="AbyssGatesColState">State</sys:String>
  <sys:String x:Key="AbyssGatesColStateHash">Hash</sys:String>
  <sys:String x:Key="AbyssGatesColAction">Action</sys:String>
  <sys:String x:Key="AbyssGatesUnlock">Unlock</sys:String>
  <sys:String x:Key="AbyssGatesLock">Lock</sys:String>
  <sys:String x:Key="AbyssGatesUnlockTip">Default (untouched) → Activated (crossed). Sets _initStateNameHash to 0xe300acfe.</sys:String>
  <sys:String x:Key="AbyssGatesLockTip">Activated (crossed) → Default (untouched). Sets _initStateNameHash back to 0x866c7489.</sys:String>
  <sys:String x:Key="AbyssGatesClose">Close</sys:String>
  <sys:String x:Key="AbyssGatesNotAvailableTitle">No abyss gates in this save</sys:String>
  <sys:String x:Key="AbyssGatesNotAvailableBody">No nested FieldGimmickSaveData elements inside FieldSaveData._fieldGimmickSaveDataList matched the abyss / hyperspace allowlist from gimmickinfo.pabgb. Either the save has no FieldSaveData root yet (very early-game), or the game install is unconfigured so gimmickinfo isn't available.</sys:String>

  <!-- Mount Unlock dialog -->
  <sys:String x:Key="MountUnlockWindowTitle">Unlock Mounts</sys:String>
  <sys:String x:Key="MountUnlockHeader">Sigil mounts (bears, deer, ibex, warthog, Silver Fang, Phoenix) are granted as a Sigil of Solidarity into Quest Artifacts — load the game and USE the sigil to finish the unlock (the engine then summons + grants riding). The Dragon (Blackstar) is unlocked directly: its real mount element is transplanted from a bundled donor save + its summon knowledge injected. Saves to the file on next File → Save.</sys:String>
  <sys:String x:Key="MountUnlockColMount">Mount</sys:String>
  <sys:String x:Key="MountUnlockColType">Type</sys:String>
  <sys:String x:Key="MountUnlockColMethod">Method</sys:String>
  <sys:String x:Key="MountUnlockColAction">Action</sys:String>
  <sys:String x:Key="MountUnlockAction">Unlock</sys:String>
  <sys:String x:Key="MountUnlockClose">Close</sys:String>

  <!-- Knowledge editor dialog -->
  <sys:String x:Key="KnowledgeWindowTitle">Edit Knowledge</sys:String>
  <sys:String x:Key="KnowledgeHeader">Learn knowledge / codex entries per item or per category — pick a category or search, tick the rows you want, then Learn selected. "Learn all in category" injects every unlearned entry in the current view (warned for map-reveal Node and codex Collection sets). Saves to the file on next File → Save.</sys:String>
  <sys:String x:Key="KnowledgeCategory">Category:</sys:String>
  <sys:String x:Key="KnowledgeSearchHint">Filter by name, key, or category…</sys:String>
  <sys:String x:Key="KnowledgeUnlearnedOnly">Unlearned only</sys:String>
  <sys:String x:Key="KnowledgeLearnedOnly">Learned only</sys:String>
  <sys:String x:Key="KnowledgeColKey">Key</sys:String>
  <sys:String x:Key="KnowledgeColName">Name</sys:String>
  <sys:String x:Key="KnowledgeColInternal">Internal name</sys:String>
  <sys:String x:Key="KnowledgeColCategory">Category</sys:String>
  <sys:String x:Key="KnowledgeColStatus">Status</sys:String>
  <sys:String x:Key="KnowledgeSelectAll">Select all</sys:String>
  <sys:String x:Key="KnowledgeUnselectAll">Unselect all</sys:String>
  <sys:String x:Key="KnowledgeInvert">Invert selection</sys:String>
  <sys:String x:Key="KnowledgeLearnSelected">Learn selected</sys:String>
  <sys:String x:Key="KnowledgeLearnCategory">Learn all in category</sys:String>
  <sys:String x:Key="KnowledgeClose">Close</sys:String>
  <sys:String x:Key="SealedArtifactWindowTitle">Complete Sealed Abyss Artifact Challenges</sys:String>
  <sys:String x:Key="SealedArtifactHeader">Preview of every challenge eligible for Pattern B v1 completion. Tick the ones to complete, then Complete selected. The catalog row + twin are left untouched (the engine fills them at reward pickup); achievements still require in-game completion. Saves to the file on next File → Save.</sys:String>
  <sys:String x:Key="SealedArtifactSearchHint">Filter by name, internal name, or key…</sys:String>
  <sys:String x:Key="SealedArtifactSelectAll">Select all</sys:String>
  <sys:String x:Key="SealedArtifactUnselectAll">Unselect all</sys:String>
  <sys:String x:Key="SealedArtifactInvert">Invert selection</sys:String>
  <sys:String x:Key="SealedArtifactCompleteSelected">Complete selected</sys:String>
  <sys:String x:Key="SealedArtifactClose">Close</sys:String>
  <sys:String x:Key="SealedArtifactColKey">Key</sys:String>
  <sys:String x:Key="SealedArtifactColName">Name</sys:String>
  <sys:String x:Key="SealedArtifactColInternal">Internal name</sys:String>
  <sys:String x:Key="SealedArtifactColFollowUp">Follow-up (X_2)</sys:String>
  <sys:String x:Key="FactionNodeWindowTitle">Edit Faction Nodes</sys:String>
  <sys:String x:Key="FactionNodeHeader">Discover or set the state of faction strongholds. Tick rows, pick a target state, then Set selected — or use Discover all to set every undiscovered node to Active. State only; the catalog/world reconciles other fields. Saves to the file on next File → Save.</sys:String>
  <sys:String x:Key="FactionNodeSearchHint">Filter by name, key, or state…</sys:String>
  <sys:String x:Key="FactionNodeSelectAll">Select all</sys:String>
  <sys:String x:Key="FactionNodeUnselectAll">Unselect all</sys:String>
  <sys:String x:Key="FactionNodeInvert">Invert selection</sys:String>
  <sys:String x:Key="FactionNodeColOwner">Node (owner)</sys:String>
  <sys:String x:Key="FactionNodeColKey">Key</sys:String>
  <sys:String x:Key="FactionNodeColState">State</sys:String>
  <sys:String x:Key="FactionNodeColConqueror">Conqueror</sys:String>
  <sys:String x:Key="FactionNodeColCapital">Capital</sys:String>
  <sys:String x:Key="FactionNodeTargetStateLabel">Target state:</sys:String>
  <sys:String x:Key="FactionNodeSetSelected">Set selected</sys:String>
  <sys:String x:Key="FactionNodeDiscoverAll">Discover all</sys:String>
  <sys:String x:Key="FactionNodeClose">Close</sys:String>
  <sys:String x:Key="MenuFontSize">_Font Size</sys:String>
  <sys:String x:Key="SummaryToggleTip">Show / hide the Save Summary panel — claim more room for the main grids.</sys:String>
  <sys:String x:Key="MenuLanguage">_Secondary Language</sys:String>
  <sys:String x:Key="MenuLanguageOff">English only (no secondary)</sys:String>

  <!-- UI language submenu (Tools → UI Language). Distinct from
       MenuLanguage above, which picks the in-game-data SECONDARY
       language; this picks the editor's own UI language. -->
  <sys:String x:Key="MenuUiLanguage">_UI Language</sys:String>
  <sys:String x:Key="MenuUiLanguageAuto">Auto (detect from OS)</sys:String>
  <sys:String x:Key="MenuUiLanguageEn">English</sys:String>
  <sys:String x:Key="MenuUiLanguageJa">日本語</sys:String>
  <sys:String x:Key="MenuUiLanguageZhTw">繁體中文</sys:String>

  <!-- Item-picker dialog -->
  <sys:String x:Key="ItemPickerWindowTitle">Browse items</sys:String>
  <sys:String x:Key="ItemPickerSearchPlaceholder">Filter by ItemKey, string id, or localized name…</sys:String>
  <!-- Add-Item top bar (format strings: {0}=item, {1}=source row). -->
  <sys:String x:Key="ItemPickerSelectPrompt">Select an item below, then Add</sys:String>
  <sys:String x:Key="ItemPickerAddWithSource">+ Add "{0}" from "{1}"</sys:String>
  <sys:String x:Key="ItemPickerAddNoSource">+ Add "{0}"</sys:String>
  <sys:String x:Key="ItemPickerOpenBagHint">Open a bag (drill into an item list) and pick a row to clone from.</sys:String>
  <!-- Add-Item status messages. -->
  <sys:String x:Key="AddItemStatusOpenBag">Open a bag first (drill into _inventorylist[N]._itemList).</sys:String>
  <sys:String x:Key="AddItemStatusWrongList">This list holds {0}, not ItemSaveData. Add unsupported here.</sys:String>
  <sys:String x:Key="AddItemStatusMissingFields">Source element missing one of _itemKey / _stackCount / _slotNo / _itemNo — bag layout incompatible with the clone-and-patch strategy.</sys:String>
  <sys:String x:Key="AddItemStatusProgress">Adding item {0} (template: {1})…</sys:String>
  <sys:String x:Key="AddItemStatusSuccess">Added item {0} from {1} (qty {2}, slot {3}, itemNo {4}).</sys:String>
  <sys:String x:Key="AddItemStatusFailed">Add failed: {0}</sys:String>
  <sys:String x:Key="AddItemSourceSelected">selected [{0}]: {1}</sys:String>
  <sys:String x:Key="AddItemSourceFirst">[0]: first element</sys:String>
  <sys:String x:Key="ItemPickerColIcon">Icon</sys:String>
  <sys:String x:Key="ItemPickerColKey">ItemKey</sys:String>
  <sys:String x:Key="ItemPickerColStringKey">String ID</sys:String>
  <sys:String x:Key="ItemPickerColNameEnglish">Name (eng)</sys:String>
  <sys:String x:Key="ItemPickerColCopy">Copy</sys:String>
  <sys:String x:Key="ItemPickerCopyKeyTip">Copy the numeric ItemKey to the clipboard</sys:String>
  <sys:String x:Key="ItemPickerCopyStringKeyTip">Copy iteminfo's internal string id to the clipboard</sys:String>
  <sys:String x:Key="ItemPickerCopyNameTip">Copy the English name to the clipboard</sys:String>

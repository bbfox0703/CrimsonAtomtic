  <!-- Character refs browser (Tools menu) + per-field CharacterKey picker share
       the warning banner + Pick button strings below. -->
  <sys:String x:Key="MenuBrowseCharacterRefs">Browse Character _References…</sys:String>
  <sys:String x:Key="CharacterRefsBrowserWarning">⚠ Reference linkage is best-effort. The same CharacterKey can mean different things across different blocks/fields. This list enumerates every save field whose schema TypeName is "CharacterKey" — cross-verify in the raw editor.</sys:String>
  <sys:String x:Key="CharacterRefsBrowserJump">Jump…</sys:String>
  <sys:String x:Key="CharacterRefsBrowserJumpTip">Close this dialog and navigate the main editor's block tree to the top-level block containing this CharacterKey reference. From there drill manually to the specific field.</sys:String>
  <sys:String x:Key="CharacterRefsBrowserFilterLabel">Filter:</sys:String>
  <sys:String x:Key="CharacterRefsBrowserClose">Close</sys:String>

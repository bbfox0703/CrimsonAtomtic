  <!-- Edit panel -->
  <sys:String x:Key="EditPanelHeader">編輯欄位</sys:String>
  <sys:String x:Key="EditPanelNameLabel">欄位</sys:String>
  <sys:String x:Key="EditPanelTypeLabel">類型</sys:String>
  <sys:String x:Key="EditPanelValueLabel">新值</sys:String>
  <sys:String x:Key="EditPanelApply">套用</sys:String>
  <sys:String x:Key="EditPanelRevert">復原</sys:String>
  <sys:String x:Key="EditPanelFillMaxStack">填到最大值</sys:String>
  <sys:String x:Key="EditPanelFillMaxStackTip">把這個欄位填上該物品的 max_stack_count (來自 iteminfo)。會預填到文字框 — 確認後再按 Apply。</sys:String>
  <sys:String x:Key="EditPanelMakeAbsent">標為不存在 (absent)</sys:String>
  <sys:String x:Key="EditPanelMakeAbsentTip">將此 scalar 的存在位元關掉 — 該欄位從 block 移除 (mask bit 清掉，payload bytes 丟棄)。要復原就輸入一個值再按 Apply。</sys:String>
  <sys:String x:Key="MarkChallengeCompleteButton">✓ 標記挑戰完成 (Pattern B v1)</sys:String>
  <sys:String x:Key="MarkChallengeCompleteTip">引擎自然單一挑戰完成 (Pattern B v1)。只有當遊戲已對此挑戰做過偵測、顯示為可用 (你已在遊戲中撿起封印神器) 時才會啟用。會寫入相關項目 — 與遊戲本身在已完成、但尚未領取的狀態的情況完全相同。生活部份的挑戰可能不適用。尚未完整測試 — 請先備份你的存檔。</sys:String>
  <sys:String x:Key="MarkChallengeSkipReasonPrefix">已停用 — 原因：</sys:String>

  <!-- 結構性（會改變長度）的儲存警告 -->
  <sys:String x:Key="StructuralEditWarningTitle">結構性變更 — 可能無法載入</sys:String>
  <sys:String x:Key="StructuralEditWarningBody" xml:space="preserve">此存檔包含會改變長度的（結構性）變更，例如完成封印阿比斯神器挑戰或新增／移除清單項目。&#10;&#10;資料本身寫入正確，但《赤色沙漠》自家的存檔讀取器有一個臭蟲，可能讓某些高進度存檔在這類變更後載入時崩潰。就地變更（道具數量、狀態、開關旗標）則不受影響。&#10;&#10;原始檔案已保留備份。仍要儲存嗎？</sys:String>

  <!-- 封印神器「將挑戰標記為完成」確認對話框。Detail 為格式字串：
       {0}=挑戰鍵值、{1}=內部名稱、{2}=孿生鍵值、{3}=FAR 索引、{4}=FAR 鍵值、
       {5}=更新/建立、{6}=後續鍵值、{7}=後續內部名稱、{8}=標籤數(前)、{9}=標籤數(後)、
       {10}=後續項目那一行（本身已含換行）。 -->
  <sys:String x:Key="MarkChallengeConfirmTitle">將挑戰標記為完成（Pattern B v1）？</sys:String>
  <sys:String x:Key="MarkChallengeWordUpdate">更新</sys:String>
  <sys:String x:Key="MarkChallengeWordCreate">建立</sys:String>
  <sys:String x:Key="MarkChallengeFollowUpExists" xml:space="preserve">  • X_2 子任務項目已存在；略過插入。&#10;</sys:String>
  <sys:String x:Key="MarkChallengeFollowUpNew" xml:space="preserve">  • 已附加新的 MissionStateData 項目（從 FAR 追蹤器複製，並把 _key 與 _branchedTime 修補為 X_2 子任務的形狀）。&#10;</sys:String>
  <sys:String x:Key="MarkChallengeConfirmDetail" xml:space="preserve">以 Pattern B v1 流程將此挑戰標記為完成？&#10;&#10;  挑戰鍵值：{0}&#10;  內部名稱：{1}&#10;  相鄰可見性孿生鍵值：{2}&#10;  FAR 追蹤器：索引 {3}，鍵值 {4}&#10;  要{5}的 X_2 子任務：鍵值 {6}（{7}）&#10;&#10;本操作會寫入：&#10;  • FAR 追蹤器 _state ← 5，並標記 _completedTime。&#10;  • FAR 追蹤器 _usedTagList：{8} → {9} 筆（加入可見性 magic tag）。&#10;{10}  • 目錄列與相鄰孿生資料：維持不動。引擎會在領取獎勵時處理。&#10;&#10;</sys:String>
  <sys:String x:Key="MarkChallengeConfirmWarnings" xml:space="preserve">[!! 請持有對應的神器] 請確認「這個」特定挑戰所對應的封印阿比斯神器目前就在你的背包中。此按鈕只在你至少持有一個封印的阿比斯神器（任何種類）時才會啟用，但下次重新載入時的遊戲內領獎流程，只有在對應此挑戰的神器確實在背包中時才會完成。光靠 Pattern B v1 並不足夠 — 撿取神器才是引擎的關卡判定訊號。&#10;&#10;[!! 已在 Shield II / Spear I / Hooves II / Slash III 驗證過] Pattern B v1 是從引擎自然完成的 Hooves II 挑戰逆向工程而來。此流程寫入領獎前的狀態，並讓引擎在下次載入時補完後續程序。先前直接寫入領獎後狀態的做法都會破壞遊戲內 UI。動作前請先確認你的存檔已備份（自動備份位於 %LOCALAPPDATA%\CrimsonAtomtic\Backups\ — 檔案 → 從備份還原… 可以回復）。&#10;&#10;[!! 會影響遊戲進度] 將 FAR 追蹤器強制設為 state=5 等於告訴引擎此挑戰已完成；依賴此挑戰完成的後續內容／NPC 對話都會被觸發。&#10;&#10;[!! 不會解鎖成就] Steam／平台成就只會在真正的遊戲內完成時觸發。透過修改檔案標記不會觸發成就，而且一旦挑戰進入此狀態，引擎也不會在你之後用正常流程完成時再次觸發。請勿對你打算之後用正常管道完成的挑戰使用此功能。&#10;&#10;要繼續嗎？</sys:String>
  <sys:String x:Key="MarkChallengeCancelled">已取消標記。</sys:String>

  <sys:String x:Key="ConfirmDialogYes">是</sys:String>
  <sys:String x:Key="ConfirmDialogNo">否</sys:String>
  <sys:String x:Key="ElementsColBulkFill">批次</sys:String>
  <sys:String x:Key="ElementsBulkFillButton">填滿堆疊</sys:String>
  <sys:String x:Key="ElementsBulkFillTip">把這個容器內每個物品的數量設為其遊戲中的最大堆疊數。</sys:String>
  <sys:String x:Key="ElementsBulkFillConfirmTitle">填滿堆疊至最大值？</sys:String>
  <sys:String x:Key="ElementsColAddItem">新增</sys:String>
  <sys:String x:Key="ElementsAddItemButton">+ 新增道具…</sys:String>
  <sys:String x:Key="ElementsAddItemTip">開啟道具瀏覽器，以此列為範本複製並新增道具到這個清單。瀏覽器上方的列會顯示道具與要放入的位置。</sys:String>
  <sys:String x:Key="ElementsColRemove">移除</sys:String>
  <sys:String x:Key="ElementsRemoveButton">✕ 移除</sys:String>
  <sys:String x:Key="ElementsRemoveTip">把此元素從 list 移除。save body 會跟著縮短；不寫入存檔時重新載入即可復原。</sys:String>
  <sys:String x:Key="ItemPickerAddToBagTip">把這個物品加入主視窗目前顯示的背包清單。請先打開一個背包 (鑽進 _inventorylist[N]._itemList)；否則點擊會在狀態列回報前置需求。</sys:String>
  <sys:String x:Key="MenuRestoreFromBackup">從備份還原…</sys:String>
  <sys:String x:Key="RestoreFromBackupTitle">從備份還原</sys:String>
  <sys:String x:Key="RestoreFromBackupColumnHint">在某一列按下「還原」可以將該快照覆寫到目前的存檔。目前存檔狀態「不會」被備份 — 只有在編輯器中執行儲存時才會建立備份。</sys:String>
  <sys:String x:Key="RestoreColSlot">Slot (使用者 / 名稱)</sys:String>
  <sys:String x:Key="RestoreColTimestamp">備份時間</sys:String>
  <sys:String x:Key="RestoreColFiles">檔案</sys:String>
  <sys:String x:Key="RestoreColSize">大小</sys:String>
  <sys:String x:Key="RestoreColAction">動作</sys:String>
  <sys:String x:Key="RestoreButton">⤺ 還原</sys:String>
  <sys:String x:Key="RestoreButtonTip">用此備份覆寫目前的存檔。目前的存檔狀態「不會」備份 — 若想保留，請先在編輯器中儲存。</sys:String>
  <sys:String x:Key="EditPanelNestedReadOnly">尚不支援編輯巢狀欄位。請按 Back 回到頂層 block。</sys:String>
  <sys:String x:Key="ElementsColIcon">圖示</sys:String>
  <sys:String x:Key="ElementsColIndex">#</sys:String>
  <sys:String x:Key="ElementsColClass">Class</sys:String>

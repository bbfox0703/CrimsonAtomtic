  <!-- World Map 對話框（Tools 選單） -->
  <sys:String x:Key="MenuWorldMap">世界地圖(_W)…</sys:String>
  <sys:String x:Key="WorldMapWindowTitle">世界地圖</sys:String>
  <sys:String x:Key="WorldMapPickMap">選擇地圖…</sys:String>
  <sys:String x:Key="WorldMapPickMapTip">挑一張圖片當世界地圖底圖。圖片會被強制拉伸成正方形畫布；ping 的位置以 Crimson Desert 標準世界地圖為基準計算，與圖片本身的解析度、比例無關。</sys:String>
  <sys:String x:Key="WorldMapPickMapTitle">選擇世界地圖圖片</sys:String>
  <sys:String x:Key="WorldMapFilterLabel">篩選：</sys:String>
  <sys:String x:Key="WorldMapFilterTip">用標籤子字串篩選物件清單。空白＝顯示所有有座標的物件。</sys:String>
  <sys:String x:Key="WorldMapObjectPickerTip">挑一個物件（主控角色 / 傭兵 / 場景物件）在地圖上 ping 其位置。</sys:String>

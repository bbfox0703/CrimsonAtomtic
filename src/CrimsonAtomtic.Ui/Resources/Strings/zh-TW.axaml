  <sys:String x:Key="LocalizationColValue">值</sys:String>
  <sys:String x:Key="LocalizationColCopy">複製</sys:String>
  <sys:String x:Key="LocalizationCopyKeyTip">將原始 key 複製到剪貼簿</sys:String>
  <sys:String x:Key="LocalizationCopyValueTip">將英文 value 複製到剪貼簿</sys:String>

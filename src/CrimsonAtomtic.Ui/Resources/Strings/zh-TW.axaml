  <sys:String x:Key="ItemPickerSearchPlaceholder">依 ItemKey、string id 或本地化名稱篩選…</sys:String>
  <!-- 新增道具列 (格式字串: {0}=道具, {1}=來源列)。 -->
  <sys:String x:Key="ItemPickerSelectPrompt">請在下方選擇一個道具，再按新增</sys:String>

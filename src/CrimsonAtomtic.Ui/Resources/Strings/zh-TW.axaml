  <!-- Browse-characters dialog -->
  <sys:String x:Key="MenuBrowseCharacters">瀏覽角色 / NPC(_C)…</sys:String>
  <sys:String x:Key="CharacterPickerWindowTitle">瀏覽角色 / NPC</sys:String>
  <sys:String x:Key="CharacterPickerSearchPlaceholder">依 CharacterKey、內部 id 或本地化名稱篩選…</sys:String>
  <sys:String x:Key="CharacterPickerColPortrait">頭像</sys:String>
  <sys:String x:Key="CharacterPickerColKey">CharKey</sys:String>
  <sys:String x:Key="CharacterPickerColInternal">內部 id</sys:String>
  <sys:String x:Key="CharacterPickerColNameEnglish">名稱 (eng)</sys:String>
  <sys:String x:Key="CharacterPickerColCopy">複製</sys:String>
  <sys:String x:Key="CharacterPickerCopyKeyTip">將數值 CharacterKey 複製到剪貼簿</sys:String>
  <sys:String x:Key="CharacterPickerCopyInternalTip">將 characterinfo 的內部 id (如 "Yann_Friendly") 複製到剪貼簿</sys:String>
  <sys:String x:Key="CharacterPickerCopyNameTip">將英文顯示名稱複製到剪貼簿</sys:String>
  <sys:String x:Key="CharacterPickerCopyNameSecondaryTip">將次要語言顯示名稱複製到剪貼簿</sys:String>

  <!-- Character refs browser (Tools menu) + per-field CharacterKey picker share
       the warning banner + Pick button strings below. -->
  <sys:String x:Key="MenuBrowseCharacterRefs">瀏覽角色參照(_R)…</sys:String>
  <sys:String x:Key="CharacterRefsBrowserWarning">⚠ 參照串接僅為盡力而為。同一個 CharacterKey 在不同 block / 不同欄位脈絡下可能代表不同實體。本列表僅列舉所有 schema TypeName 為 "CharacterKey" 的欄位 — 請以原始編輯器交叉驗證。</sys:String>
  <sys:String x:Key="CharacterRefsBrowserJump">跳轉…</sys:String>
  <sys:String x:Key="CharacterRefsBrowserJumpTip">關閉此對話框，並在主編輯器的 block 樹中跳轉到含有該 CharacterKey 參照的頂層 block。再從那裡手動鑽到特定欄位。</sys:String>
  <sys:String x:Key="CharacterRefsBrowserFilterLabel">篩選：</sys:String>
  <sys:String x:Key="CharacterRefsBrowserClose">關閉</sys:String>
  <sys:String x:Key="CharacterRefsBrowserCol_Portrait">頭像</sys:String>
  <sys:String x:Key="CharacterRefsBrowserCol_Block">Block</sys:String>
  <sys:String x:Key="CharacterRefsBrowserCol_BlockNum">Block #</sys:String>
  <sys:String x:Key="CharacterRefsBrowserCol_Name">角色</sys:String>
  <sys:String x:Key="CharacterRefsBrowserCol_Key">CharacterKey</sys:String>
  <sys:String x:Key="CharacterRefsBrowserCol_Action">動作</sys:String>

  <!-- Picker shared with CharacterPickerWindow (Pick mode + warning banner)
       + edit panel button strings for the CharacterKey scalar field picker. -->
  <sys:String x:Key="CharacterPickerWarning">⚠ 串接僅為盡力而為。characterinfo.pabgb 中的 key 在不同欄位脈絡下不一定對應同一實體。請以遊戲畫面或主編輯器交叉驗證後再依賴解析後的名稱。</sys:String>
  <sys:String x:Key="CharacterPickerPick">選擇</sys:String>
  <sys:String x:Key="CharacterPickerColPick">選擇</sys:String>
  <sys:String x:Key="EditPanelPickCharacter">選擇角色…</sys:String>
  <sys:String x:Key="EditPanelPickCharacterTip">開啟角色選擇對話框。選一列以填入該 CharacterKey 值到文字框；按 Apply 寫入。</sys:String>

  <!-- Browse-localization dialog -->
  <sys:String x:Key="LocalizationWindowTitle">瀏覽本地化字串</sys:String>
  <sys:String x:Key="LocalizationSearchPlaceholder">依 key 或 value 篩選…</sys:String>

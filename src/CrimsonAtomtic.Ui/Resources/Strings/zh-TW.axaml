  <!-- 單列／批次標記挑戰 (Pattern B v1) -->
  <sys:String x:Key="MarkApplying">正在套用 Pattern B v1（FAR 追蹤器 + X_2 子任務）…</sys:String>
  <sys:String x:Key="MarkFailedReadFar">標記失敗（無法重新讀取 FAR 追蹤器）：{0}</sys:String>

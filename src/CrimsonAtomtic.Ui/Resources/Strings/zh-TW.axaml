<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

  <!--
    Traditional Chinese (zh-TW) translations.
    en.axaml is the source of truth — sync new keys here when en.axaml
    gains entries. Technical identifiers (save-file field names with
    leading underscores, schema class names, file paths, hex constants,
    build-identifier terms like Pattern B v1 / FAR tracker / PALOC /
    HMAC / iteminfo) are intentionally preserved verbatim — these are
    debug/forensic surfaces that need to be greppable across English
    docs and source code.
  -->

  <!-- Window / chrome -->
  <sys:String x:Key="WindowTitle">CrimsonAtomtic</sys:String>

  <!-- Menu -->
  <sys:String x:Key="MenuFile">檔案(_F)</sys:String>
  <sys:String x:Key="MenuOpenSave">開啟存檔(_O)…</sys:String>
  <sys:String x:Key="MenuSave">儲存(_S)</sys:String>
  <sys:String x:Key="MenuSaveAs">另存新檔(_A)…</sys:String>
  <sys:String x:Key="MenuExit">離開(_X)</sys:String>
  <sys:String x:Key="MenuTools">工具(_T)</sys:String>
  <sys:String x:Key="MenuBrowseLocalization">瀏覽本地化字串(_B)…</sys:String>
  <sys:String x:Key="MenuBrowseItems">瀏覽物品(_I)…</sys:String>
  <sys:String x:Key="MenuExtractIcons">從遊戲資料抽出圖示(_E)…</sys:String>
  <sys:String x:Key="MenuSetGameInstallFolder">設定遊戲安裝資料夾(_G)…</sys:String>
  <sys:String x:Key="SetGameInstallFolderInvalidTitle">這個資料夾看起來不像赤血沙漠 Crimson Desert 安裝目錄</sys:String>
  <sys:String x:Key="SetGameInstallFolderInvalidBody">所選資料夾不包含必要的素材檔 (0020\0.pamt)。請選擇包含遊戲 0000\、0020\、… 各個 pack group 的目錄 — 通常是 &lt;Steam library&gt;\steamapps\common\Crimson Desert，或是 Epic / 為 Game Pass 拷貝出來的素材資料夾。</sys:String>
  <sys:String x:Key="MenuRenameMercenary">傭兵改名(_M)…</sys:String>
  <sys:String x:Key="MenuEditItemSockets">編輯物品插槽(_S)…</sys:String>
  <sys:String x:Key="SocketEditorHeader">逐孔填入 / 變更 / 清除。Fill 與 Change 操作會將耐久 (Endurance) 重設為 65535 (最大值)，避免新鑲入的高階寶石繼承舊孔的耗損值。當你填入一個索引超過物品目前上限的孔時，_validSocketCount 會自動上修 (讓該孔在遊戲中可見)。底層 list 預先配置的任何孔都可以填 (一般是 5 個)，不受遊戲資料定義的上限限制。改動會在下一次存檔時寫回。</sys:String>
  <sys:String x:Key="SocketEditorColBag">背包</sys:String>
  <sys:String x:Key="SocketEditorColItem">物品</sys:String>
  <sys:String x:Key="SocketEditorColItemKey">ItemKey</sys:String>
  <sys:String x:Key="SocketEditorColSocket">孔</sys:String>
  <sys:String x:Key="SocketEditorColCurrentGem">目前寶石</sys:String>
  <sys:String x:Key="SocketEditorColCurrentGemKey">GemKey</sys:String>
  <sys:String x:Key="SocketEditorColAction">動作</sys:String>
  <sys:String x:Key="SocketEditorColApplied">狀態</sys:String>
  <sys:String x:Key="SocketEditorChangeGem">變更…</sys:String>
  <sys:String x:Key="SocketEditorFillGem">填入…</sys:String>
  <sys:String x:Key="SocketEditorClearGem">清除</sys:String>
  <sys:String x:Key="SocketEditorChangeGemTip">開啟寶石選擇器，覆寫這個已填入的孔。會將 _currentEndurance 重設為 65535 (最大值)，讓高階寶石從滿耐久開始。</sys:String>
  <sys:String x:Key="SocketEditorFillGemTip">開啟寶石選擇器，填入這個空孔。必要時會自動上修 _validSocketCount，讓該孔在遊戲中可見。</sys:String>
  <sys:String x:Key="SocketEditorClearGemTip">把這個插槽退回成空。_currentEndurance 和 _itemKey 都會變成 absent；mask 翻成 [0x00]。</sys:String>
  <sys:String x:Key="SocketEditorColState">狀態</sys:String>
  <sys:String x:Key="SocketEditorApplySetItemLabel">套用組合至：</sys:String>
  <sys:String x:Key="SocketEditorApplySetSetLabel">組合：</sys:String>
  <sys:String x:Key="SocketEditorApplySetApply">套用</sys:String>
  <sys:String x:Key="SocketEditorApplySetEditCustom">編輯自訂組合…</sys:String>
  <sys:String x:Key="SocketEditorApplySetEditCustomTip">定義 / 重新命名三組使用者自訂的寶石組合。儲存至 settings.json。</sys:String>
  <sys:String x:Key="SocketEditorFilterLabel">篩選：</sys:String>
  <sys:String x:Key="SocketEditorFilterWatermark">輸入文字以篩選 — 物品名稱 / 背包 / item key 會顯示全部 5 個孔；寶石名稱 / gem key 則只顯示符合的孔…</sys:String>

  <!-- Custom gem sets editor (launched from Sockets editor toolbar) -->
  <sys:String x:Key="CustomGemSetsWindowTitle">編輯自訂寶石組合</sys:String>
  <sys:String x:Key="CustomGemSetsHeader">三組使用者可自訂的寶石組合，會與內建的三組一起出現在插槽編輯器的 Apply-Set 工具列中。每組有一個標籤 + 最多 5 個 ItemKey 項目 (空白格會被略過)。套用含 N 個項目的組合會覆寫目標物品的 0..N-1 孔，[N..max] 範圍的孔保持不動。按下儲存後寫入 settings.json。</sys:String>
  <sys:String x:Key="CustomGemSetsSave">儲存</sys:String>
  <sys:String x:Key="CustomGemSetsClose">關閉</sys:String>
  <sys:String x:Key="SocketEditorClose">關閉</sys:String>
  <sys:String x:Key="SocketEditorNotAvailableTitle">此存檔沒有已鑲嵌寶石的孔</sys:String>
  <sys:String x:Key="SocketEditorNotAvailableBody">載入的存檔沒有任何物品有已填入的插槽 (或根本沒有任何物品帶有 _socketSaveDataList)。在遊戲中鑲入一顆寶石後，已填入的槽位就會出現在這裡。</sys:String>
  <sys:String x:Key="SocketEditorPickerTitle">選擇寶石</sys:String>
  <sys:String x:Key="RenameMercenaryHeader">為傭兵 / 寵物改名。「名稱」欄顯示由 CharacterKey 解析出來的角色 / 樣板名稱 (與主視窗 mercenaryDataList 名稱欄同源) — 用來辨識每一列。你自訂的改名 (已存於 _mercenaryName) 不會顯示 — read-side FFI 尚未實作。輸入新名稱並逐列按下 Apply。改動會在下一次存檔時儲存回檔案。</sys:String>
  <sys:String x:Key="RenameMercenaryColIdx">索引</sys:String>
  <sys:String x:Key="RenameMercenaryColMercNo">MercNo</sys:String>
  <sys:String x:Key="RenameMercenaryColCharKey">CharKey</sys:String>
  <sys:String x:Key="RenameMercenaryColPortrait">頭像</sys:String>
  <sys:String x:Key="RenameMercenaryColCharName">名稱</sys:String>
  <sys:String x:Key="RenameMercenaryColType">類型</sys:String>
  <sys:String x:Key="RenameMercenaryColEquip">裝備</sys:String>
  <sys:String x:Key="RenameMercenaryColNewName">新名稱 (UTF-8)</sys:String>
  <sys:String x:Key="RenameMercenaryColApply">動作</sys:String>
  <sys:String x:Key="RenameMercenaryColApplied">已套用</sys:String>
  <sys:String x:Key="RenameMercenaryApply">套用</sys:String>
  <sys:String x:Key="RenameMercenaryClose">關閉</sys:String>
  <sys:String x:Key="RenameMercenaryNewNameWatermark">輸入新名稱…</sys:String>
  <sys:String x:Key="RenameMercenaryNotAvailableTitle">沒有可改名的傭兵</sys:String>
  <sys:String x:Key="RenameMercenaryNotAvailableBody">載入的存檔沒有 MercenaryClanSaveData block，或其 _mercenaryDataList 為空 / 無法讀取。在遊戲中招募至少一名傭兵後，傭兵列表就會出現在這裡。</sys:String>
  <sys:String x:Key="MenuFillAllStacks">把所有背包的堆疊都填到最大(_A)…</sys:String>
  <sys:String x:Key="MenuUnlockAllAbyssGates">解鎖所有阿比斯之門 (地圖探索)(_U)…</sys:String>
  <sys:String x:Key="MenuBulkCompleteHeldSAChallenges">完成目前可處理的、所有持有的封印阿比斯神器挑戰(_C)…</sys:String>
  <sys:String x:Key="MenuEditAbyssGates">編輯阿比斯之門 (每個門個別鎖/解鎖)(_E)…</sys:String>
  <sys:String x:Key="MenuEditItemDyes">編輯物品染色(_D)…</sys:String>
  <sys:String x:Key="MenuVendorBuyback">商人回購清單(_V)…</sys:String>
  <sys:String x:Key="MenuReviewChanges">檢視待寫入的變更(_R)…</sys:String>

  <!-- Vendor Buyback dialog (Tools menu) -->
  <sys:String x:Key="VendorBuybackWindowTitle">商人回購</sys:String>
  <sys:String x:Key="VendorBuybackHeader">檢視 + 移除玩家賣給商人的物品。每一列對應到一筆 StoreDataSaveData._storeSoldItemDataList 元素。Remove 按鈕會把該筆從該商人的回購佇列刪掉 (釋出該格)；同一商人後續的同階兄弟會自動下移 1 格。「移回背包」功能規劃中。改動會在下一次 File → Save 寫回存檔。</sys:String>
  <sys:String x:Key="VendorBuybackFilterLabel">篩選：</sys:String>
  <sys:String x:Key="VendorBuybackFilterWatermark">輸入文字以篩選 — 商人名稱 / store key 會顯示該商人所有售出物品；物品名稱 / item key 會逐列縮小範圍…</sys:String>
  <sys:String x:Key="VendorBuybackColStore">商人</sys:String>
  <sys:String x:Key="VendorBuybackColStoreKey">StoreKey</sys:String>
  <sys:String x:Key="VendorBuybackColItem">物品</sys:String>
  <sys:String x:Key="VendorBuybackColItemKey">ItemKey</sys:String>
  <sys:String x:Key="VendorBuybackColStack">堆疊</sys:String>
  <sys:String x:Key="VendorBuybackColEndurance">耐久</sys:String>
  <sys:String x:Key="VendorBuybackColSoldAt">售出時間 (ticks)</sys:String>
  <sys:String x:Key="VendorBuybackColAction">動作</sys:String>
  <sys:String x:Key="VendorBuybackColStatus">狀態</sys:String>
  <sys:String x:Key="VendorBuybackRemove">移除</sys:String>
  <sys:String x:Key="VendorBuybackRemoveTip">從該商人的回購佇列刪除此筆。該格空出後其他物品才能流轉進來。此操作在 session 內無法復原；要回復就重新載入存檔但不要寫入即可。</sys:String>
  <sys:String x:Key="VendorBuybackJump">跳轉…</sys:String>
  <sys:String x:Key="VendorBuybackJumpTip">關閉此對話框，並在主編輯器的 block 樹中開啟該回購物品。從那裡可以用通用欄位編輯器修改堆疊數量、耐久、插槽、染色等 — 介面與背包物品相同。</sys:String>
  <sys:String x:Key="VendorBuybackClose">關閉</sys:String>
  <sys:String x:Key="VendorBuybackNotAvailableTitle">沒有商人回購紀錄</sys:String>
  <sys:String x:Key="VendorBuybackNotAvailableBody">載入的存檔沒有任何 StoreDataSaveData 帶有非空的 _storeSoldItemDataList。請先在遊戲中賣物給商人以建立回購佇列。</sys:String>

  <!-- Change summary dialog (review pending edits + close-on-dirty confirm) -->
  <sys:String x:Key="ChangeSummaryWindowTitle">待寫入的變更</sys:String>
  <sys:String x:Key="ChangeSummaryHeaderClose">有未儲存的變更 — 退出前先儲存？</sys:String>
  <sys:String x:Key="ChangeSummarySubHeaderClose">下列編輯尚未寫入磁碟。按「儲存」會寫入並關閉；按「捨棄並退出」會直接關閉 (磁碟上的舊狀態維持不變)；按「取消」會回到編輯器繼續編輯。</sys:String>
  <sys:String x:Key="ChangeSummaryHeaderReview">自上次儲存以來的變更</sys:String>
  <sys:String x:Key="ChangeSummarySubHeaderReview">從載入存檔 (或上次存檔後) 開始，透過 UI 套用過的編輯之唯讀清單。重新載入存檔可丟棄所有變更；File → Save 可寫入磁碟。</sys:String>
  <sys:String x:Key="ChangeSummaryColTime">時間</sys:String>
  <sys:String x:Key="ChangeSummaryColCategory">區塊</sys:String>
  <sys:String x:Key="ChangeSummaryColSummary">變更</sys:String>
  <sys:String x:Key="ChangeSummarySave">儲存</sys:String>
  <sys:String x:Key="ChangeSummaryDiscard">捨棄</sys:String>
  <sys:String x:Key="ChangeSummaryDiscardExit">捨棄存檔並退出</sys:String>
  <sys:String x:Key="ChangeSummaryCancel">取消</sys:String>
  <sys:String x:Key="ChangeSummaryNoChangesTitle">沒有待寫入的變更</sys:String>
  <sys:String x:Key="ChangeSummaryNoChangesBody">自載入存檔 (或上次寫回檔案後) 起，沒有任何編輯紀錄。</sys:String>

  <!-- Dye editor master dialog -->
  <sys:String x:Key="DyeEditorWindowTitle">編輯物品染色</sys:String>
  <sys:String x:Key="DyeEditorHeader">逐物品編輯染色。列出所有 _itemDyeDataList 存在且非空的物品。點 Edit 可修改各孔位的 R/G/B/A + 髒污 + 材質 + 色彩群組。</sys:String>
  <sys:String x:Key="DyeEditorSearchPlaceholder">依物品名稱、背包或 ItemKey 篩選…</sys:String>
  <sys:String x:Key="DyeEditorColIcon">圖示</sys:String>
  <sys:String x:Key="DyeEditorColBag">背包</sys:String>
  <sys:String x:Key="DyeEditorColItem">物品</sys:String>
  <sys:String x:Key="DyeEditorColItemKey">ItemKey</sys:String>
  <sys:String x:Key="DyeEditorColSlotCount">孔數</sys:String>
  <sys:String x:Key="DyeEditorColAction">動作</sys:String>
  <sys:String x:Key="DyeEditorEdit">編輯…</sys:String>
  <sys:String x:Key="DyeEditorEditTip">為此物品的染色清單開啟逐孔編輯器。對話框在套用後不會關閉，方便連續編輯多個槽位。</sys:String>
  <sys:String x:Key="DyeEditorClose">關閉</sys:String>
  <sys:String x:Key="DyeEditorNotAvailableTitle">此存檔沒有已染色物品</sys:String>
  <sys:String x:Key="DyeEditorNotAvailableBody">沒有任何物品攜帶至少一格的 _itemDyeDataList。可能是玩家還沒染色過任何東西，或是此存檔 schema 把 _itemDyeDataList 放在不同的欄位名底下 (請重跑 vendor/crimson-rs/_probe_item_dye_data 確認)。</sys:String>

  <!-- Dye slot editor child dialog -->
  <sys:String x:Key="DyeSlotEditorWindowTitle">編輯染色槽</sys:String>
  <sys:String x:Key="DyeSlotColSlot">孔</sys:String>
  <sys:String x:Key="DyeSlotColColor">顏色</sys:String>
  <sys:String x:Key="DyeSlotColGrime">髒污</sys:String>
  <sys:String x:Key="DyeSlotColMaterial">材質</sys:String>
  <sys:String x:Key="DyeSlotColColorGroup">色彩群組</sys:String>
  <sys:String x:Key="DyeSlotColAction">動作</sys:String>
  <sys:String x:Key="DyeSlotColStatus">狀態</sys:String>
  <sys:String x:Key="DyeSlotPick">選色…</sys:String>
  <sys:String x:Key="DyeSlotApply">套用</sys:String>
  <sys:String x:Key="DyeSlotEditorClose">關閉</sys:String>

  <!-- Dye palette picker modal -->
  <sys:String x:Key="DyePalettePickerWindowTitle">選擇染色</sys:String>
  <sys:String x:Key="DyePalettePickerCancel">取消</sys:String>
  <sys:String x:Key="DyePalettePickerOffGridBanner">目前的顏色不在此主題的色盤內 (可能是外部工具設定的)。點任何色格都會用色盤上的顏色取代它。</sys:String>
  <sys:String x:Key="AbyssGatesWindowTitle">編輯阿比斯之門</sys:String>
  <sys:String x:Key="AbyssGatesHeader">逐門切換鎖定/解鎖。針對 FieldSaveData._fieldGimmickSaveDataList 內每個 FieldGimmickSaveData 元素寫入 _initStateNameHash (Default 0x866c7489 ↔ Activated 0xe300acfe)。Idle (場景) 與 Unknown 列為唯讀，避免破壞非門類 gimmick 的穩定性。改動會在下一次 File → Save 寫回存檔。</sys:String>
  <sys:String x:Key="AbyssGatesColOwnerLevel">擁有者關卡</sys:String>
  <sys:String x:Key="AbyssGatesColGimmick">Gimmick</sys:String>
  <sys:String x:Key="AbyssGatesColSaveKey">SaveKey</sys:String>
  <sys:String x:Key="AbyssGatesColState">狀態</sys:String>
  <sys:String x:Key="AbyssGatesColStateHash">Hash</sys:String>
  <sys:String x:Key="AbyssGatesColAction">動作</sys:String>
  <sys:String x:Key="AbyssGatesUnlock">解鎖</sys:String>
  <sys:String x:Key="AbyssGatesLock">鎖定</sys:String>
  <sys:String x:Key="AbyssGatesUnlockTip">Default (未觸發) → Activated (已穿越)。將 _initStateNameHash 設為 0xe300acfe。</sys:String>
  <sys:String x:Key="AbyssGatesLockTip">Activated (已穿越) → Default (未觸發)。將 _initStateNameHash 復原為 0x866c7489。</sys:String>
  <sys:String x:Key="AbyssGatesClose">關閉</sys:String>
  <sys:String x:Key="AbyssGatesNotAvailableTitle">此存檔沒有阿比斯之門</sys:String>
  <sys:String x:Key="AbyssGatesNotAvailableBody">FieldSaveData._fieldGimmickSaveDataList 內沒有任何 FieldGimmickSaveData 元素符合 gimmickinfo.pabgb 中的 abyss / hyperspace 白名單。可能是存檔還沒有 FieldSaveData root (遊戲非常早期)，或遊戲安裝路徑未設定使得 gimmickinfo 無法讀取。</sys:String>
  <sys:String x:Key="MenuFontSize">字型大小(_F)</sys:String>
  <sys:String x:Key="SummaryToggleTip">顯示 / 隱藏存檔摘要面板 — 把空間讓給主資料表格。</sys:String>
  <sys:String x:Key="MenuLanguage">次要語言(_S)</sys:String>
  <sys:String x:Key="MenuLanguageOff">僅英文 (不顯示次要語言)</sys:String>

  <!-- UI language submenu (Tools → UI Language). Distinct from
       MenuLanguage above, which picks the in-game-data SECONDARY
       language; this picks the editor's own UI language. -->
  <sys:String x:Key="MenuUiLanguage">介面語言(_U)</sys:String>
  <sys:String x:Key="MenuUiLanguageAuto">自動 (依作業系統偵測)</sys:String>
  <sys:String x:Key="MenuUiLanguageEn">English</sys:String>
  <sys:String x:Key="MenuUiLanguageJa">日本語</sys:String>
  <sys:String x:Key="MenuUiLanguageZhTw">繁體中文</sys:String>

  <!-- Item-picker dialog -->
  <sys:String x:Key="ItemPickerWindowTitle">瀏覽物品</sys:String>
  <sys:String x:Key="ItemPickerSearchPlaceholder">依 ItemKey、string id 或本地化名稱篩選…</sys:String>
  <sys:String x:Key="ItemPickerColIcon">圖示</sys:String>
  <sys:String x:Key="ItemPickerColKey">ItemKey</sys:String>
  <sys:String x:Key="ItemPickerColStringKey">String ID</sys:String>
  <sys:String x:Key="ItemPickerColNameEnglish">名稱 (eng)</sys:String>
  <sys:String x:Key="ItemPickerColCopy">複製</sys:String>
  <sys:String x:Key="ItemPickerCopyKeyTip">將數值 ItemKey 複製到剪貼簿</sys:String>
  <sys:String x:Key="ItemPickerCopyStringKeyTip">將 iteminfo 的內部 string id 複製到剪貼簿</sys:String>
  <sys:String x:Key="ItemPickerCopyNameTip">將英文名稱複製到剪貼簿</sys:String>
  <sys:String x:Key="ItemPickerCopyNameSecondaryTip">將次要語言名稱複製到剪貼簿</sys:String>

  <!-- Find-items dialog -->
  <sys:String x:Key="MenuFindItems">尋找物品(_F)…</sys:String>
  <sys:String x:Key="FindItemsWindowTitle">尋找物品 (跨背包)</sys:String>
  <sys:String x:Key="FindItemsSearchPlaceholder">依 ItemKey、物品名稱、背包名稱或 ItemNo 篩選…</sys:String>
  <sys:String x:Key="FindItemsColIcon">圖示</sys:String>
  <sys:String x:Key="FindItemsColBag">背包</sys:String>
  <sys:String x:Key="FindItemsColSlot">格位</sys:String>
  <sys:String x:Key="FindItemsColItemKey">ItemKey</sys:String>
  <sys:String x:Key="FindItemsColItemName">名稱 (eng)</sys:String>
  <sys:String x:Key="FindItemsColStack">堆疊</sys:String>
  <sys:String x:Key="FindItemsColFlags">旗標</sys:String>
  <sys:String x:Key="FindItemsColItemNo">ItemNo</sys:String>
  <sys:String x:Key="FindItemsColAction">動作</sys:String>
  <sys:String x:Key="FindItemsGotoButton">前往</sys:String>
  <sys:String x:Key="FindItemsGotoTip">把主視窗跳轉到這個物品的精確位置 — 鑽進 InventorySaveData → _inventorylist[N] → _itemList[M]。此對話框會保持開啟。</sys:String>
  <sys:String x:Key="FindItemsCopyKeyTip">將數值 ItemKey 複製到剪貼簿</sys:String>
  <sys:String x:Key="FindItemsCopyNameTip">將英文物品名稱複製到剪貼簿</sys:String>
  <sys:String x:Key="FindItemsFlagLockedTip">_isLocked = true</sys:String>
